@model MinaTolEntidades.DtoViajes.PrecioCombustible
@{
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var usuario = @ViewBag.UserToken.UserName;
}

<div class="container-fluid" style="padding: 15px;">

    <!-- ================= FORM SOLO PARA GUARDAR ================= -->
    @using (Html.BeginForm("", "", FormMethod.Post, new { id = "frmPrecioCombustible", onsubmit = "return false;" }))
    {
        @Html.HiddenFor(x => x.Id, new { @id = "id" })
        @Html.HiddenFor(x => x.Estatus, new { Value = 1, @id = "estatus" })
        @Html.HiddenFor(x => x.CreatedBy, new { Value = usuario, @id = "createdBy" })
        @Html.HiddenFor(x => x.UpdatedBy, new { Value = usuario, @id = "updatedBy" })
        @Html.HiddenFor(x => x.CreatedDt, new { Value = fechaActual, @id = "createdDt" })
        @Html.HiddenFor(x => x.UpdatedDt, new { Value = fechaActual, @id = "updatedDt" })

        <div class="panel panel-primary">
            <div class="panel-heading">
                <i class="fa fa-fire"></i> Configurar Precio Actual de Combustible
            </div>
            <div class="panel-body">

                <div class="row">
                    <div class="col-md-6">
                        <label>Precio del Combustible</label>
                        @Html.TextBoxFor(x => x.Precio, new { @class = "form-control", @id = "precio", placeholder = "0.00" })
                    </div>

                    <div class="col-md-6">
                        <label>
                            @Html.CheckBoxFor(x => x.PrecioActivo, new { @id = "precioActivo" })
                            Marcar como precio activo
                        </label>
                    </div>
                </div>

                <div class="text-center" style="margin-top:15px;">
                    <button type="button" onclick="SaveOrUpdatePrecioCombustible()" class="btn btn-success">
                        Guardar
                    </button>
                </div>

            </div>
        </div>
    }

    <!-- ================= HISTORIAL FUERA DEL FORM ================= -->
    <div class="panel panel-info">
        <div class="panel-heading">
            Historial de Precios
        </div>
        <div class="panel-body table-responsive">
            <table id="tablePreciosCombustible" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Precio</th>
                        <th>Precio Actual</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

</div>

<style>
    /* Estilos originales se mantienen pero se modifican los específicos */

    /* NUEVO: Forzar texto blanco en los badges de Precio Actual */
    .label-success,
    .label-default {
        color: white !important;
        padding: 3px 8px;
        border-radius: 3px;
        font-size: 11px;
    }

        /* Asegurar que el texto dentro de los labels sea blanco */
        .label-success i,
        .label-default i,
        .label-success span,
        .label-default span {
            color: white !important;
        }

    /* Estilos para botones dentro de la tabla - TEXTO BLANCO */
    .btn-sm {
        padding: 3px 8px;
        font-size: 11px;
        border-radius: 3px;
        color: white !important; /* FORZAR TEXTO BLANCO */
    }

    .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
        color: white !important; /* FORZAR TEXTO BLANCO */
    }

    .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
        color: white !important; /* FORZAR TEXTO BLANCO */
    }

        /* Asegurar que los iconos dentro de botones también sean blancos */
        .btn-sm i,
        .btn-primary i,
        .btn-danger i {
            color: white !important;
        }

        /* Hover effects para botones - mantener texto blanco */
        .btn-primary:hover,
        .btn-danger:hover,
        .btn-sm:hover {
            color: white !important;
            opacity: 0.85;
        }

    /* Para la columna de Precio Actual en la tabla */
    #tablePreciosCombustible tbody td:nth-child(3) {
        color: white !important;
    }

    /* Si los labels tienen texto adicional */
    .label-success,
    .label-default {
        color: white !important;
        font-weight: normal !important;
    }

    /* Resto de tus estilos existentes se mantienen igual */
    #tablePreciosCombustible,
    #tablePreciosCombustible *,
    .dataTables_wrapper,
    .dataTables_wrapper *,
    .dataTables_info,
    .dataTables_paginate,
    .dataTables_length,
    .dataTables_filter {
        color: #333333 !important;
    }

        #tablePreciosCombustible thead th {
            color: #333333 !important;
            background-color: #f5f5f5 !important;
            font-weight: bold !important;
        }

        #tablePreciosCombustible tbody td {
            color: #333333 !important;
            background-color: #ffffff !important;
        }

            /* EXCEPCIÓN: Forzar que los badges de estado sean blancos */
            #tablePreciosCombustible tbody td .label-success,
            #tablePreciosCombustible tbody td .label-default {
                color: white !important;
            }

            /* EXCEPCIÓN: Forzar que los botones tengan texto blanco */
            #tablePreciosCombustible tbody td .btn-primary,
            #tablePreciosCombustible tbody td .btn-danger,
            #tablePreciosCombustible tbody td .btn-sm {
                color: white !important;
            }

        #tablePreciosCombustible tbody tr:hover td {
            background-color: #f5f5f5 !important;
        }

        /* Resto de estilos DataTables... */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_processing,
        .dataTables_wrapper .dataTables_paginate {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button {
                color: #333333 !important;
                background-color: #ffffff !important;
                border: 1px solid #ddd !important;
            }

                .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                    background-color: #337ab7 !important;
                    color: white !important;
                    border-color: #337ab7 !important;
                }

                .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                    background-color: #f5f5f5 !important;
                    color: #333333 !important;
                }

            .dataTables_wrapper .dataTables_filter input {
                color: #333333 !important;
                background-color: #ffffff !important;
                border: 1px solid #ddd !important;
            }

            .dataTables_wrapper .dataTables_length select {
                color: #333333 !important;
                background-color: #ffffff !important;
                border: 1px solid #ddd !important;
            }
</style>

<script>
    $(document).ready(function () {
        // Función para formatear moneda
        function formatCurrencyInput(selector) {
            $(selector).on('input', function () {
                let input = $(this).val();
                let value = input.replace(/[^0-9.]/g, '');

                let parts = value.split('.');
                if (parts.length > 2) {
                    value = parts[0] + '.' + parts.slice(1).join('');
                }

                if (parts.length > 1 && parts[1].length > 2) {
                    value = parts[0] + '.' + parts[1].substring(0, 2);
                }

                $(this).val(value);
            }).on('blur', function () {
                let value = $(this).val();
                if (value && value.trim() !== '') {
                    let num = parseFloat(value);
                    if (!isNaN(num)) {
                        let formatted = num.toLocaleString('es-MX', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        });
                        $(this).val(formatted);
                    }
                }
            }).on('focus', function () {
                let value = $(this).val().replace(/[^0-9.]/g, '');
                $(this).val(value);
            });
        }

        // Inicializar formateo
        formatCurrencyInput('#precio');

        // Configuración de DataTable
        $("#tablePreciosCombustible").DataTable({
            responsive: true,
            scrollX: true,
            autoWidth: false,
            processing: true,
            paging: true,
            searching: true,
            ordering: true,
            destroy: true,
            columns: [
                { data: 'id', title: 'ID', visible: false },
                {
                    data: 'precio',
                    title: 'Precio',
                    render: function (data, type, row) {
                        if (data == null || data === "") return "$0.00";
                        return "$" + parseFloat(data).toLocaleString('es-MX', { minimumFractionDigits: 2 });
                    }
                },
                {
                    data: 'precioActivo',
                    title: 'Precio Actual',
                    render: function (data, type, row) {
                        if (data == 1 || data === true) {
                            return '<span class="label label-success" style="color: white !important;"><i class="fa fa-check" style="color: white !important;"></i> Precio Actual</span>';
                        } else {
                            return '<span class="label label-default" style="color: white !important;"><i class="fa fa-clock-o" style="color: white !important;"></i> Precio NO Actual</span>';
                        }
                    }
                },
                {
                    data: null,
                    title: 'Acciones',
                    orderable: false,
                    render: function (data, type, row) {
                        return '<button class="btn btn-sm btn-primary btnEditarCombustible" data-id="' + row.id + '">' +
                            '<i class="fa fa-edit"></i> Editar</button> ' +
                            '<button class="btn btn-sm btn-danger btnEliminarCombustible" data-id="' + row.id + '">' +
                            '<i class="fa fa-trash"></i> Eliminar</button>';
                    }
                }
            ],
            order: [[0, 'desc']],
            language: {
                "decimal": ",",
                "thousands": ".",
                "processing": "Procesando...",
                "lengthMenu": "Mostrar _MENU_ entradas",
                "zeroRecords": "No se encontraron resultados",
                "emptyTable": "Ningún dato disponible en esta tabla",
                "info": "Mostrando _START_ a _END_ de _TOTAL_ entradas",
                "infoEmpty": "Mostrando 0 a 0 de 0 entradas",
                "infoFiltered": "(filtrado de un total de _MAX_ entradas)",
                "search": "Buscar:",
                "loadingRecords": "Cargando...",
                "paginate": {
                    "first": "Primero",
                    "last": "Último",
                    "next": "Siguiente",
                    "previous": "Anterior"
                },
                "aria": {
                    "sortAscending": ": activar para ordenar la columna de manera ascendente",
                    "sortDescending": ": activar para ordenar la columna de manera descendente"
                }
            }
        });

        GetAllPrecioCombustible();
    });

    function GetAllPrecioCombustible() {
        GetMVC("/Administracion/GetAllPrecioCombustible", function (r) {
            if (r.IsSuccess) {
                // Filtrar solo los registros con Estatus = 1
                var datosFiltrados = r.Response.filter(function (item) {
                    return item.estatus === true || item.Estatus === true;
                });

                // Mapear solo los datos filtrados
                MapingPropertiesDataTable("tablePreciosCombustible", datosFiltrados);
            } else {
                swal({
                    title: 'Error',
                    text: 'Error al cargar los precios: ' + r.ErrorMessage,
                    type: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function SaveOrUpdatePrecioCombustible() {
        if ($("#frmPrecioCombustible").valid()) {
            var precioRaw = $("#precio").val().replace(/[^\d.]/g, '');
            var precioNum = parseFloat(precioRaw);

            var parametro = {
                Id: $("#id").val() || 0,
                Precio: precioNum,
                PrecioActivo: $("#precioActivo").is(":checked"),
                Estatus: 1,
                CreatedBy: $("#createdBy").val(),
                CreatedDt: $("#createdDt").val(),
                UpdatedBy: $("#updatedBy").val(),
                UpdatedDt: $("#updatedDt").val(),
            };
            swal({
                title: "¡Registro guardado!",
                text: "El precio del combustible se ha guardado correctamente.",
                type: "success",
                confirmButtonText: 'OK'
            }, function () {
                LimpiarFormulario();
                GetAllPrecioCombustible(); // recarga tabla sin reload
            });
            PostMVC('/Administracion/SaveOrUpdatePrecioCombustible', parametro, function (r) {
            });
        } else {
            swal({
                type: 'warning',
                title: 'Campos incompletos',
                text: 'Por favor complete todos los campos requeridos.',
                confirmButtonText: 'Aceptar'
            });
        }
    }

    function LimpiarFormulario() {
        $("#frmPrecioCombustible")[0].reset();
        $("#precio").val('');
        $("#precioActivo").prop('checked', false);
    }

    function EditarPrecioCombustible(id) {
        if ($("#genericModal").length) {
            $("#genericModal").modal("hide");
            $("#boddyGeericModal").empty();
            $("#genericModal").removeData('bs.modal');
        }

        $('body').removeClass('modal-open');
        $('.modal-backdrop').remove();

        $("#titleGenerciModal").text("Editar Precio de Combustible");

        setTimeout(function () {
            $("#boddyGeericModal").load("/Administracion/PartialConfigurarCombustible/" + id, function () {
                $("#genericModal").modal({
                    backdrop: 'static',
                    keyboard: false
                }).modal("show");
            });
        }, 300);
    }

    $(document).on('click', '.btnEliminarCombustible', function () {
        const id = $(this).data('id');
        EliminarPrecioCombustible(id);
    });

    $(document).on('click', '.btnEditarCombustible', function () {
        const id = $(this).data('id');
        EditarPrecioCombustible(id);
    });

    function EliminarPrecioCombustible(id) {
        swal({
            title: '¿Estás seguro?',
            text: "¿Desea eliminar el siguiente registro?",
            type: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }, function (isConfirmed) {
            if (isConfirmed) {
                var parametro = { Id: id };
                swal("Eliminado", "Registro eliminado", "success");
                window.location.reload();

                PostMVC('/Administracion/DeletePrecioCombustible', parametro, function (r) {
                    if (r.IsSuccess) {
                        swal({
                            title: 'Eliminado',
                            text: 'El precio del combustible ha sido eliminado.',
                            type: 'success',
                            confirmButtonText: 'OK'
                        }, function () {
                            window.location.reload();
                        });
                    } else {
                        swal({
                            title: 'Error',
                            text: 'Error al eliminar el registro',
                            type: 'error',
                            confirmButtonText: 'Aceptar'
                        });
                    }
                });
            }
        });
    }
</script>