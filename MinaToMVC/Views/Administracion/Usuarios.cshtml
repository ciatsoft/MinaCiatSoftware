@model MinaTolEntidades.Security.Usuario
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Card del formulario -->
    <div class="panel panel-primary" style="margin-top: 20px;">
        <div class="panel-heading">
            <h3 class="panel-title">
                <i class="fa fa-users"></i> Formulario de Usuarios
            </h3>
        </div>
        <div class="panel-body">
            @using (Html.BeginForm("SaveOrUpdateUsuario", "Administracion", FormMethod.Post, new { enctype = "multipart/form-data", name = "frmUsuario", id = "frmUsuario" }))
            {
                @Html.HiddenFor(x => x.Estatus)
                @Html.HiddenFor(x => x.CreatedDt, new { Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"), id = "createdDt" })
                @Html.HiddenFor(x => x.CreatedBy, new { Value = ViewBag.UserToken.UserName, id = "createdBy" })
                @Html.HiddenFor(x => x.UpdatedBy, new { Value = ViewBag.UserToken.UserName, id = "updatedBy" })
                @Html.HiddenFor(x => x.UpdatedDt, new { Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"), id = "updatedDt" })

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label style="color: #000000;"><i class="fa fa-id-card"></i> ID Usuario:</label>
                            @Html.TextBoxFor(x => x.Id, new { @class = "form-control", @readonly = "readonly", id = "id" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label style="color: #000000;"><i class="fa fa-user"></i> Nombre:</label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", id = "nombre", placeholder = "Ingrese el nombre" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label style="color: #000000;"><i class="fa fa-user-circle"></i> UserName:</label>
                            @Html.TextBoxFor(x => x.UserName, new { @class = "form-control", id = "username", placeholder = "Ingrese el username" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label style="color: #000000;"><i class="fa fa-envelope"></i> Email:</label>
                            @Html.TextBoxFor(x => x.Email, new { @class = "form-control", id = "email", placeholder = "correo@ejemplo.com" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label style="color: #000000;"><i class="fa fa-lock"></i> Contraseña:</label>
                            <div class="input-group">
                                @Html.PasswordFor(x => x.Password, new
                                {
                                    @class = "form-control",
                                    id = "password",
                                    placeholder = "Ingrese la contraseña"
                                })
                                <span class="input-group-btn">
                                    <button class="btn btn-default" type="button" id="togglePassword" style="height: 34px;">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <hr />
                        <button type="button" id="btnGuardaru" onclick="SaveOrUpdateUsuario()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>

                        @if (ViewBag.EsEdicion == true)
                        {
                            <button type="button" id="btnPermisos" class="btn btn-primary">
                                <i class="fa fa-key"></i> Permisos
                            </button>
                        }

                        <a href="/Administracion/Usuarios" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Card de la tabla -->
    <div class="panel panel-info" style="margin-top: 20px;">
        <div class="panel-heading">
            <h3 class="panel-title">
                <i class="fa fa-table"></i> Listado de Usuarios
            </h3>
        </div>
        <div class="panel-body">
            <div class="table-responsive">
                <table id="tblUsuarios" class="table table-bordered table-striped table-hover" style="width: 100%;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>UserName</th>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Estatus</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos generales */
    .panel-primary .panel-heading {
        background-color: #337ab7;
        border-color: #337ab7;
    }

    .panel-info .panel-heading {
        background-color: #5bc0de;
        border-color: #5bc0de;
        color: white;
    }

    .panel-heading .panel-title i {
        margin-right: 8px;
    }

    /* Labels en negro */
    .form-group label {
        color: #000000 !important;
        font-weight: 600;
        margin-bottom: 5px;
    }

        .form-group label i {
            margin-right: 5px;
            color: #337ab7;
        }

    /* Botones */
    .btn i {
        margin-right: 5px;
    }

    /* Tabla */
    .table-responsive {
        overflow-x: auto;
    }

    .table th {
        background-color: #f5f5f5;
        text-align: center;
        vertical-align: middle;
        color: #000000;
        font-weight: 600;
    }

    .table td {
        vertical-align: middle;
        text-align: center;
        color: #000000;
    }

    /* DataTables personalizado */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #000000 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #000000 !important;
        }

    /* Inputs */
    .form-control {
        color: #000000;
    }

        .form-control[readonly] {
            background-color: #f9f9f9;
            color: #000000;
        }

    /* Placeholder */
    ::-webkit-input-placeholder {
        color: #999999;
    }

    :-moz-placeholder {
        color: #999999;
    }

    ::-moz-placeholder {
        color: #999999;
    }

    :-ms-input-placeholder {
        color: #999999;
    }

    /* Panel body */
    .panel-body {
        background-color: #ffffff;
    }

    /* Botones de acción en tabla */
    .btn-custom-clean {
        background-color: #337ab7;
        color: white;
        border: none;
        padding: 5px 10px;
        border-radius: 4px;
        margin: 2px;
    }

        .btn-custom-clean:hover {
            background-color: #286090;
            color: white;
        }

    .btn-custom-cancel {
        background-color: #d9534f;
        color: white;
        border: none;
        padding: 5px 10px;
        border-radius: 4px;
        margin: 2px;
    }

        .btn-custom-cancel:hover {
            background-color: #c9302c;
            color: white;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .col-md-3 {
            margin-bottom: 15px;
        }

        .btn {
            margin-bottom: 10px;
        }
    }
    /* Estilos para el toggle de contraseña */
    .input-group .btn {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    #togglePassword {
        background-color: #f5f5f5;
        border-color: #ccc;
        color: #333;
    }

        #togglePassword:hover {
            background-color: #e6e6e6;
            border-color: #adadad;
        }

        #togglePassword i {
            margin-right: 0;
        }

    /* Prevenir autocompletado */
    input[type="password"] {
        -webkit-text-security: disc;
    }

    /* Deshabilitar autocompletado del navegador */
    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    input:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        box-shadow: 0 0 0 30px white inset !important;
    }
</style>

<script type="text/javascript">
    var UsuariosJson = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
</script>

<script src="@(Url.Content("~/Scripts/Seguridad/Usuario.js"))"></script>
