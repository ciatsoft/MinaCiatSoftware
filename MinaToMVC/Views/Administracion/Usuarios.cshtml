@model MinaTolEntidades.Security.Usuario
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="contenedorMaterial"></div>

<!-- ================= FORMULARIO DE USUARIOS ================= -->
<form id="frmUsuario" name="frmUsuario" method="post" enctype="multipart/form-data">
    <div class="container-fluid" style="padding: 20px 15px;">

        <!-- Panel Principal con fondo blanco y texto negro -->
        <div class="panel panel-default" style="background-color: #ffffff;">
            <div class="panel-body" style="background-color: #ffffff; color: #333333;">

                <!-- Título -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important;">
                            <i class="fa fa-users"></i> Usuarios
                        </h1>
                    </div>
                </div>

                <!-- Campos Ocultos -->
                @Html.HiddenFor(x => x.Estatus)
                @Html.HiddenFor(x => x.CreatedDt, new { Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"), id = "createdDt" })
                @Html.HiddenFor(x => x.CreatedBy, new { Value = ViewBag.UserToken.UserName, id = "createdBy" })
                @Html.HiddenFor(x => x.UpdatedBy, new { Value = ViewBag.UserToken.UserName, id = "updatedBy" })
                @Html.HiddenFor(x => x.UpdatedDt, new { Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"), id = "updatedDt" })

                <!-- Fila 1: ID, Nombre, UserName, Email -->
                <div class="row" style="margin-top:15px;">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-id-card-o"></i> ID Usuario:
                            </label>
                            @Html.TextBoxFor(x => x.Id, new { @class = "form-control", @readonly = "readonly", id = "id", disabled = "disabled" })
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-user"></i> Nombre:
                            </label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", id = "nombre", placeholder = "Ingrese el nombre" })
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-user-circle-o"></i> UserName:
                            </label>
                            @Html.TextBoxFor(x => x.UserName, new { @class = "form-control", id = "username", placeholder = "Ingrese el username" })
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-envelope-o"></i> Email:
                            </label>
                            @Html.TextBoxFor(x => x.Email, new { @class = "form-control", id = "email", placeholder = "correo@ejemplo.com" })
                        </div>
                    </div>
                </div>

                <!-- Fila 2: Contraseña -->
                <div class="row">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-lock"></i> Contraseña:
                            </label>
                            <div class="input-group">
                                @Html.PasswordFor(x => x.Password, new
                                {
                                    @class = "form-control",
                                    id = "password",
                                    placeholder = "Escriba nueva contraseña para cambiarla",
                                    autocomplete = "new-password"
                                })
                                <span class="input-group-btn">
                                    <button class="btn btn-default" type="button" id="togglePassword">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                </span>
                            </div>
                            <small class="text-muted" style="color: #666666;">
                                Dejar en blanco para conservar la contraseña actual
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Botones de Acción del Formulario -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" onclick="SaveOrUpdateUsuario()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>

                        @if (ViewBag.EsEdicion == true)
                        {
                            <button type="button" id="btnPermisos" class="btn btn-primary">
                                <i class="fa fa-key"></i> Permisos
                            </button>
                        }

                        <a href="/Administracion/Usuarios" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- ================= TABLA DE USUARIOS ================= -->
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary" style="background-color: #ffffff;">
        <div class="panel-heading" style="background-color: #337ab7; color: #ffffff;">
            <i class="fa fa-table"></i> Listado de Usuarios
        </div>
        <div class="panel-body table-responsive" style="background-color: #ffffff;">
            <table id="tblUsuarios" class="table table-bordered table-striped">
                <thead>
                    <tr style="background-color: #f5f5f5;">
                        <th style="color: #333333;">ID</th>
                        <th style="color: #333333;">UserName</th>
                        <th style="color: #333333;">Nombre</th>
                        <th style="color: #333333;">Correo</th>
                        <th style="color: #333333;">Estatus</th>
                        <th style="color: #333333;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script type="text/javascript">
    var UsuariosJson = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
</script>

<script src="@(Url.Content("~/Scripts/Seguridad/Usuario.js"))"></script>

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label {
        color: #333333 !important;
    }

    /* Estilos para el toggle de contraseña */
    .input-group .btn {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    #togglePassword {
        background-color: #f5f5f5;
        border-color: #ccc;
        color: #333;
    }

        #togglePassword:hover {
            background-color: #e6e6e6;
            border-color: #adadad;
        }

        #togglePassword i {
            margin-right: 0;
        }

    /* Prevenir autocompletado */
    input[type="password"] {
        -webkit-text-security: disc;
    }

    /* Deshabilitar autocompletado del navegador */
    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    input:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        box-shadow: 0 0 0 30px white inset !important;
    }

    /* Texto del placeholder */
    .text-muted {
        color: #666666 !important;
    }
</style>