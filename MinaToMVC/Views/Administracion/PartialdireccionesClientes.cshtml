<div class="modal-header bg-dark text-white">
    <h5 class="modal-title">Direcciones</h5>
</div>

<div class="modal-body">

    <!-- ================= FORMULARIO ================= -->
    <form id="formDireccion">

        <input type="hidden" id="createdByParcialUbicacion" />
        <input type="hidden" id="createdDtParcialUbicacion" />
        <input type="hidden" id="updatedByParcialUbicacion" />
        <input type="hidden" id="updatedDtParcialUbicacion" />
        <input type="hidden" id="idCliente" />
        <input type="hidden" id="idDireccionCliente" value="0" />

        <div class="row g-3 mt-2">

            <div class="col-md-6">
                <label>Nombre del Cliente</label>
                <input type="text" class="form-control" id="nombreCliente" disabled />
            </div>

            <div class="col-md-6">
                <label>Calle</label>
                <input type="text" class="form-control" id="txtcalle" required />
            </div>

            <div class="col-md-6">
                <label>No. Interno</label>
                <input type="text" class="form-control" id="txtnointerno" required />
            </div>

            <div class="col-md-6">
                <label>No. Externo</label>
                <input type="text" class="form-control" id="txtnoexterno" required />
            </div>

            <div class="col-md-6">
                <label>Colonia</label>
                <input type="text" class="form-control" id="txtcolonia" required />
            </div>

            <div class="col-md-6">
                <label>C.P.</label>
                <input type="number" class="form-control" id="txtcp" required />
            </div>

            <div class="col-md-6">
                <label>Delegación</label>
                <input type="text" class="form-control" id="txtdelegacion" required />
            </div>

            <div class="col-md-6">
                <label>Municipio</label>
                <input type="text" class="form-control" id="txtmunicipio" required />
            </div>

            <div class="col-md-6">
                <label>Estado</label>
                <input type="text" class="form-control" id="txtestado" required />
            </div>

        </div>

        <div class="modal-footer mt-3">
            <button type="button" class="btn btn-danger" onclick="closeModal()">Cerrar</button>
            <button type="button" class="btn btn-success" onclick="GuardarDireccion()">Guardar</button>
        </div>

    </form>

    <hr />

    <!-- ================= TABLA SEPARADA ================= -->
    <div class="mt-3">
        <h5>Direcciones registradas</h5>
        <table id="tbDirecciones" class="table table-bordered table-striped" style="width:100%">
            <thead></thead>
            <tbody></tbody>
        </table>
    </div>

</div>