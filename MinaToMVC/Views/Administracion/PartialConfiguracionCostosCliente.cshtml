@{
    var precios = (List<MinaTolEntidades.DtoClientes.ClienteTipoMaterial>)ViewBag.Precios;
    var direccionesClientes = (List<MinaTolEntidades.DtoClientes.DireccionCliente>)ViewBag.DireccionClientes;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
}

<div class="container-fluid px-4 py-3">

    <input type="hidden" id="clienteId" value="@Request["clienteId"]" />
    <input type="hidden" id="materialId" value="@Request["materialId"]" />
    <input type="hidden" id="createdBy" value="@usuarioToken.UserName" />
    <input type="hidden" id="updatedBy" value="@usuarioToken.UserName" />
    <input type="hidden" id="createdDt" value="@fechaActual" />
    <input type="hidden" id="updatedDt" value="@fechaActual" />

    <input type="hidden" id="id" value="0" />
    <input type="hidden" id="idDireccion" />
    <input type="hidden" id="direccion" />
    <input type="hidden" id="PrecioCombustibleActual" />

    <!-- HEADER -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body bg-light">
            <div class="row text-center">
                <div class="col-md-6">
                    <h6 class="text-primary mb-1">Cliente</h6>
                    <strong>@ViewBag.ClienteNombre</strong>
                </div>
                <div class="col-md-6">
                    <h6 class="text-primary mb-1">Material</h6>
                    <strong>@ViewBag.MaterialNombre</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- FORM -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <div class="row">

                <!-- COLUMNA IZQUIERDA -->
                <div class="col-md-6">

                    <div class="form-group mb-3">
                        <label>Dirección</label>
                        <select id="ddlDirecciones" class="form-control"></select>
                    </div>

                    <div class="form-group mb-3">
                        <label>Precio Material M3</label>
                        <input type="text" id="p-mat-m3" class="form-control text-end" />
                    </div>

                    <div class="form-group mb-3">
                        <label>Precio Flete M3</label>
                        <input type="text" id="p-flete-m3" class="form-control text-end" />
                    </div>

                    <div class="form-group mb-3">
                        <label>KM Cargado</label>
                        <input type="number" id="km-cargado" class="form-control text-end" />
                    </div>

                    <div class="form-group mb-3">
                        <label>KM Vacío</label>
                        <input type="number" id="km-basio" class="form-control text-end" />
                    </div>

                </div>

                <!-- COLUMNA DERECHA -->
                <div class="col-md-6">

                    <div class="form-group mb-3">
                        <label>Carga Diesel (Lt)</label>
                        <input type="number" id="carga-diesel" class="form-control text-end" />
                    </div>

                    <div class="form-group mb-3">
                        <label>Casetas</label>
                        <input type="text" id="casetas" class="form-control text-end" />
                    </div>

                    <div class="form-group mb-3">
                        <label>Mano de Obra</label>
                        <input type="text" id="mano-obra" class="form-control text-end" />
                    </div>

                    <div class="form-check form-switch mt-4">
                        <input type="checkbox" id="precioActual" class="form-check-input">
                        <label class="form-check-label">Precio Actual</label>
                    </div>

                </div>
            </div>

            <!-- RESULTADOS -->
            <hr class="my-4">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Precio M3</label>
                    <input type="text" id="precio-m3" class="form-control text-end" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Total Diesel</label>
                    <input type="text" id="total-diesel" class="form-control text-end" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Total KM Recorridos</label>
                    <input type="text" id="total-km-recorridos" class="form-control text-end" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Material Viajes (30 M3)</label>
                    <input type="text" id="material-viajes" class="form-control text-end" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Subtotal Ingreso</label>
                    <input type="text" id="subtotal-ingreso" class="form-control text-end" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Total Gastos</label>
                    <input type="text" id="total-gastos" class="form-control text-end" />
                </div>

            </div>

            <div class="text-end mt-3">
                <button class="btn btn-success px-5" onclick="AgregarPreciosMaterialACliente()">
                    Guardar configuración
                </button>
            </div>

        </div>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-semibold">
            Historial de configuraciones por dirección
        </div>
        <div class="card-body">
            <table id="tblDireccionMaterial" class="table table-striped table-hover w-100"></table>
        </div>
    </div>
</div>

<script>
let timeout;

// ================= MONEDA =================
function formatCurrency(value) {
    if (isNaN(value) || value === 0) return '$ 0.00';
    return '$ ' + value.toLocaleString('es-MX', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
}

function currencyToNumber(currencyValue) {
    if (!currencyValue) return 0;
    return parseFloat(currencyValue.replace(/[^0-9.-]+/g, '')) || 0;
}

// ================= CALCULOS =================
function calcular() {

    const pMatM3 = $('#p-mat-m3').data('raw-value') || 0;
    const pFleteM3 = $('#p-flete-m3').data('raw-value') || 0;
    const kmCargado = parseFloat($('#km-cargado').val()) || 0;
    const kmBasio = parseFloat($('#km-basio').val()) || 0;
    const diesel = parseFloat($('#carga-diesel').val()) || 0;
    const manoObra = $('#mano-obra').data('raw-value') || 0;
    const casetas = $('#casetas').data('raw-value') || 0;
    const precioCombustible = parseFloat($('#PrecioCombustibleActual').val()) || 0;

    const precioM3 = pMatM3 + pFleteM3;
    const totalKm = kmCargado + kmBasio;
    const totalDiesel = diesel * precioCombustible;
    const materialViajes = pMatM3 * 30;
    const subtotalIngreso = precioM3 * 30;
    const totalGastos = totalDiesel + manoObra + casetas + materialViajes;

    $('#precio-m3').val(formatCurrency(precioM3));
    $('#total-km-recorridos').val(totalKm.toFixed(1));
    $('#total-diesel').val(formatCurrency(totalDiesel));
    $('#material-viajes').val(formatCurrency(materialViajes));
    $('#subtotal-ingreso').val(formatCurrency(subtotalIngreso));
    $('#total-gastos').val(formatCurrency(totalGastos));
}

function debounceCalculo() {
    clearTimeout(timeout);
    timeout = setTimeout(calcular, 300);
}

// ================= MONEDA INPUTS =================
function initMoneda(id) {
    const $el = $('#' + id);
    $el.data('raw-value', 0);

    $el.on('input', function () {
        let val = $(this).val().replace(/[^0-9.]/g, '');
        $(this).data('raw-value', parseFloat(val) || 0);
        debounceCalculo();
    }).on('blur', function () {
        $(this).val(formatCurrency($(this).data('raw-value')));
    }).on('focus', function () {
        $(this).val($(this).data('raw-value'));
    });
}

// ================= TABLA =================
function cargarDataTable(data) {
    if ($.fn.DataTable.isDataTable('#tblDireccionMaterial')) {
        $('#tblDireccionMaterial').DataTable().destroy();
    }

    $('#tblDireccionMaterial').DataTable({
        data: data,
        columns: [
            { title: 'Dirección', data: 'direccion' },
            { title: 'Material', data: 'tipoMaterial.nombreTipoMaterial' },
            { title: 'Cliente', data: 'cliente.nombre' },
            {
                title: 'Total',
                data: 'total_Gastos',
                render: d => formatCurrency(d)
            },
            {
                data: null,
                render: (d, t, row) => `
                <button class="btn btn-sm btn-primary btnEditar" data-id="${row.id}">Editar</button>
                <button class="btn btn-sm btn-danger btnEliminar" data-id="${row.id}">Eliminar</button>`
            }
        ]
    });
}

// ================= FUNCION QUE FALTABA =================
function ClienteTipoMaterialByDireccionMaterialAndCliente(idDireccion) {

    const parametros = {
        Cliente: { Id: $('#clienteId').val() },
        TipoMaterial: { Id: $('#materialId').val() },
        IdDireccion: idDireccion
    };

    PostMVC('/Administracion/GetClienteTipoMaterialByDireccion', parametros, function (r) {
        if (r.IsSuccess) {
            cargarDataTable(r.Response);
        }
    });
}

// ================= DIRECCIONES =================
function DropListDirecciones() {
    $('#ddlDirecciones').off('change').on('change', function () {
        const id = $(this).val();
        const text = $(this).find('option:selected').text();

        $('#idDireccion').val(id);
        $('#direccion').val(text);

        if (id) {
            ClienteTipoMaterialByDireccionMaterialAndCliente(id);
        }
    });
}

// ================= PRECIO COMBUSTIBLE =================
function GetPrecioActivoCombustible() {
    GetMVC('/Administracion/GetPrecioActivoCombustible', function (r) {
        if (r.IsSuccess) {
            $('#PrecioCombustibleActual').val(r.Response.precio);
        }
    });
}

// ================= INIT =================
$(document).ready(function () {

    initMoneda('p-mat-m3');
    initMoneda('p-flete-m3');
    initMoneda('mano-obra');
    initMoneda('casetas');

    $('#km-cargado, #km-basio, #carga-diesel').on('input', debounceCalculo);

    DropListDirecciones();
    GetPrecioActivoCombustible();

    const clienteId = $('#clienteId').val();

    if (clienteId) {
        SearchDireccionesCliente(clienteId);

        setTimeout(function () {
            const $ddl = $('#ddlDirecciones');
            if ($ddl.find('option').length > 1) {
                $ddl.prop('selectedIndex', 1).trigger('change');
            }
        }, 500);
    }
});
</script>