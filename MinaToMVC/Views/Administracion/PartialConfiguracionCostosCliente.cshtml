@{
    var precios = (List<MinaTolEntidades.DtoClientes.ClienteTipoMaterial>)ViewBag.Precios;
    var direccionesClientes = (List<MinaTolEntidades.DtoClientes.DireccionCliente>)ViewBag.DireccionClientes;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
}

<div class="container" onmouseover="debounceCalculations()">
    <!-- Input oculto para el clienteId y materialId -->
    <input type="hidden" id="clienteId" value="@Request["clienteId"]" />
    <input type="hidden" id="materialId" value="@Request["materialId"]" />
    <input type="hidden" id="createdBy" value="@usuarioToken.UserName" />
    <input type="hidden" id="updatedBy" value="@usuarioToken.UserName" />
    <input type="hidden" id="createdDt" value="@fechaActual" />
    <input type="hidden" id="updatedDt" value="@fechaActual" />

    <!-- Etiquetas para mostrar el nombre del cliente y material -->
    <div class="row mb-3">
        <div class="col-6">
            <h3 class="form-label font-weight-bold">Cliente: @ViewBag.ClienteNombre</h3>
        </div>
        <div class="col-6">
            <h3 class="form-label font-weight-bold">Material: @ViewBag.MaterialNombre</h3>
        </div>
    </div>
    <input type="hidden" id="id" value="0" readonly/>
    <div class="row">
        <div class="col-4">
            <label>Direcciones:</label>
            <select id="ddlDirecciones" name="ddlDirecciones" class="form-control">
                <option value="" disabled selected>Selecciona una opcion</option>
            </select>
            <input type="hidden" id="idDireccion" class="form-control" />
            <input type="hidden" id="direccion" class="form-control" />
        </div>
        <div class="col-4">
            <label for="p-mat-m3">P. Mat. M3</label>
            <input type="text" id="p-mat-m3" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="p-flete-m3">P. Flete M3</label>
            <input type="text" id="p-flete-m3" class="form-control" />
        </div>
        <div class="col-4">
            <label for="precio-m3">Precio M3</label>
            <input type="text" id="precio-m3" class="form-control" readonly/>
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="km-cargado">KM Cargado</label>
            <input type="number" id="km-cargado" class="form-control" />
        </div>
        <div class="col-4">
            <label for="km-basio">KM Basio</label>
            <input type="number" id="km-basio" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="total-km-recorridos">Total KM Recorridos</label>
            <input type="number" id="total-km-recorridos" class="form-control" readonly />
        </div>
        <div class="col-4">
            <label for="carga-diesel">Carga de Diesel (Lt)</label>
            <input type="number" id="carga-diesel" class="form-control" />
            <input type="hidden" id="PrecioCombustibleActual" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="total-diesel">Total Diesel ($)</label>
            <input type="text" id="total-diesel" class="form-control" readonly />
        </div>
        <div class="col-4">
            <label for="casetas">Casetas</label>
            <input type="text" id="casetas" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="mano-obra">Mano de Obra</label>
            <input type="text" id="mano-obra" class="form-control" />
        </div>
        <div class="col-4">
            <label for="material-viajes">Material Viajes (30 M3)</label>
            <input type="text" id="material-viajes" class="form-control" readonly />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="subtotal-ingreso">Subtotal Ingreso (Viajes 30 M3)</label>
            <input type="text" id="subtotal-ingreso" class="form-control" readonly />
        </div>
        <div class="col-4">
            <label for="total-gastos">Total Gastos</label>
            <input type="text" id="total-gastos" class="form-control" readonly />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-4">
            <label for="precioActual">Precio Actual</label>
            <input type="checkbox" id="precioActual" name="precioActual" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-8">
            <input type="button" value="Guardar" onclick="AgregarPreciosMaterialACliente()" class="btn btn-success" />
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-lg-8">
            <table class="table table-bordered table-striped" id="tblDireccionMaterial" style="width: 100%;"></table>
        </div>
    </div>
</div>

<script>
    // Variables globales
    let timeout;
    let dataTableInitialized = false;

    // Función para formatear números como moneda
    function formatCurrency(value) {
        if (isNaN(value) || value === 0) return '$ 0.00';
        return '$ ' + value.toLocaleString('es-MX', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    // Función para convertir formato moneda a número
    function currencyToNumber(currencyValue) {
        if (!currencyValue || currencyValue.trim() === '' || currencyValue === '$ ') return 0;
        const numericValue = parseFloat(currencyValue.replace(/[^0-9.-]+/g, ''));
        return isNaN(numericValue) ? 0 : numericValue;
    }

    // Función para calcular los totales generales
    function calcularTotales() {
        try {
            // Obtener precio de combustible
            var precioActivoCombustible = parseFloat(document.getElementById('PrecioCombustibleActual').value) || 0;

            // Obtener valores (los campos de moneda ya deben estar como números puros para cálculos)
            const pMatM3 = parseFloat($('#p-mat-m3').data('raw-value')) || 0;
            const pFleteM3 = parseFloat($('#p-flete-m3').data('raw-value')) || 0;
            const kmCargado = parseFloat(document.getElementById('km-cargado').value) || 0;
            const kmBasio = parseFloat(document.getElementById('km-basio').value) || 0;
            const cargaDiesel = parseFloat(document.getElementById('carga-diesel').value) || 0;
            const manoObra = parseFloat($('#mano-obra').data('raw-value')) || 0;
            const casetas = parseFloat($('#casetas').data('raw-value')) || 0;

            // Cálculos intermedios
            const totalpreciom3 = pMatM3 + pFleteM3;
            const totalKmRecorridos = kmCargado + kmBasio;
            const totalpreciokm = cargaDiesel * precioActivoCombustible;
            const totalGastos = totalpreciokm + manoObra + casetas;

            // Actualizar campos con formato moneda
            document.getElementById('precio-m3').value = formatCurrency(totalpreciom3);
            document.getElementById('total-diesel').value = formatCurrency(totalpreciokm);
            document.getElementById('total-km-recorridos').value = totalKmRecorridos.toFixed(1);
            document.getElementById('total-gastos').value = formatCurrency(totalGastos);

            return { totalpreciom3, pMatM3, pFleteM3, totalGastos };
        } catch (error) {
            console.error('Error en calcularTotales:', error);
            return { totalpreciom3: 0, pMatM3: 0, pFleteM3: 0, totalGastos: 0 };
        }
    }

    // Función para calcular el subtotal
    function calcularSubtotal(resultados) {
        try {
            const { totalpreciom3, pMatM3, totalGastos } = resultados;

            // Cálculos
            const materialviajesprecio = pMatM3 * 30;
            const subtotalIngreso = 30 * totalpreciom3;
            const totalgasto = totalGastos + (pMatM3 * 30);

            // Actualizar campos
            document.getElementById('material-viajes').value = formatCurrency(materialviajesprecio);
            document.getElementById('subtotal-ingreso').value = formatCurrency(subtotalIngreso);
            document.getElementById('total-gastos').value = formatCurrency(totalgasto);
        } catch (error) {
            console.error('Error en calcularSubtotal:', error);
        }
    }

    // Función principal de cálculos con debounce
    function debounceCalculations() {
        clearTimeout(timeout);
        timeout = setTimeout(() => {
            const resultados = calcularTotales();
            calcularSubtotal(resultados);
        }, 300);
    }

    // Inicializar eventos para los campos de entrada
    function inicializarEventos() {
        // Campos que deben disparar cálculos
        const camposCalculo = [
            'p-mat-m3',
            'p-flete-m3',
            'km-cargado',
            'km-basio',
            'carga-diesel',
            'mano-obra',
            'casetas'
        ];

        // Agregar eventos a todos los campos
        camposCalculo.forEach(id => {
            const elemento = document.getElementById(id);
            if (elemento) {
                elemento.addEventListener('input', debounceCalculations);
            }
        });
    }

    // Función para formatear campos de entrada como moneda (solo para campos de moneda)
    function inicializarCamposMoneda() {
        // Campos que son moneda (inputs de dinero)
        const camposMonedaInput = ['p-mat-m3', 'p-flete-m3', 'mano-obra', 'casetas'];

        // Campos que son resultados (solo lectura)
        const camposMonedaResultado = ['precio-m3', 'total-diesel', 'material-viajes', 'subtotal-ingreso', 'total-gastos'];

        // Inicializar campos de entrada
        camposMonedaInput.forEach(selector => {
            const $elemento = $('#' + selector);

            // Inicializar valor raw
            const currentValue = $elemento.val();
            if (currentValue && !isNaN(parseFloat(currentValue))) {
                $elemento.data('raw-value', parseFloat(currentValue));
                $elemento.val(formatCurrency(parseFloat(currentValue)));
            } else {
                $elemento.data('raw-value', 0);
            }

            $elemento.on('input', function () {
                let value = $(this).val().replace(/[^0-9.]/g, '');

                // Verificar si es un número válido
                if (value && !isNaN(value) && value !== '') {
                    const numValue = parseFloat(value);
                    $(this).data('raw-value', numValue);
                } else {
                    $(this).data('raw-value', 0);
                }

                // Disparar cálculos
                debounceCalculations();
            }).on('blur', function () {
                let rawValue = $(this).data('raw-value') || 0;
                $(this).val(formatCurrency(rawValue));
            }).on('focus', function () {
                let rawValue = $(this).data('raw-value') || 0;
                $(this).val(rawValue > 0 ? rawValue.toString() : '');
            });
        });

        // Inicializar campos de resultado (solo lectura)
        camposMonedaResultado.forEach(selector => {
            const elemento = document.getElementById(selector);
            if (elemento && !elemento.value) {
                elemento.value = formatCurrency(0);
            }
        });
    }

    function BotonesEditarEliminar() {
        // Evento delegado para botón Eliminar
        $(document).on('click', '.btnEliminarTipoMaterial', function () {
            const id = $(this).data('id');
            Swal.fire({
                title: '¿Estás seguro?',
                text: "¡No podrás revertir esta acción!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    PostMVC('/Administracion/DeletTipoMaterial/', { Id: id }, function (r) {
                        if (r.IsSuccess) {
                            // Recargar tabla si hay dirección seleccionada
                            const idDireccion = $('#idDireccion').val();
                            if (idDireccion) {
                                ClienteTipoMaterialByDireccionMaterialAndCliente(idDireccion);
                            } else {
                                TablaVacia();
                            }

                            Swal.fire(
                                '¡Eliminado!',
                                'El registro ha sido eliminado.',
                                'success'
                            );
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: r.ErrorMessage || 'No se pudo eliminar el registro',
                            });
                            console.error(r);
                        }
                    });
                }
            });
        });

        // Evento delegado para botón Editar
        $(document).on('click', '.btnEditarTipoMaterial', function () {
            const id = $(this).data('id');

            // Busca el registro correspondiente en la tabla
            const table = $('#tblDireccionMaterial').DataTable();
            const data = table.rows().data().toArray();
            const registro = data.find(x => x.id === id);

            if (registro) {
                precargarFormulario(registro);
                // Scroll al formulario
                $('html, body').animate({
                    scrollTop: $(".container").offset().top
                }, 500);
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'No se encontró la información del registro seleccionado.',
                });
            }
        });
    }

    function precargarFormulario(registro) {
        // Campos básicos
        $('#id').val(registro.id || 0);
        $('#idDireccion').val(registro.idDireccion || '');
        $('#direccion').val(registro.direccion || '');

        // Seleccionar en dropdown
        $('#ddlDirecciones').val(registro.idDireccion || '');

        // Configurar valores raw para cálculos y mostrar formateados
        $('#p-mat-m3').data('raw-value', registro.p_Mta_M3 || 0).val(formatCurrency(registro.p_Mta_M3 || 0));
        $('#p-flete-m3').data('raw-value', registro.p_Flete_M3 || 0).val(formatCurrency(registro.p_Flete_M3 || 0));
        $('#mano-obra').data('raw-value', registro.mano_De_Obra || 0).val(formatCurrency(registro.mano_De_Obra || 0));
        $('#casetas').data('raw-value', registro.casetas || 0).val(formatCurrency(registro.casetas || 0));

        // Campos numéricos simples
        $('#km-cargado').val(registro.kM_Cargado || 0);
        $('#km-basio').val(registro.kM_Basico || 0);
        $('#carga-diesel').val(registro.carga_Disel || 0);

        // Campos de resultado (solo lectura)
        $('#precio-m3').val(formatCurrency(registro.precio_M3 || 0));
        $('#total-diesel').val(formatCurrency(registro.total_Diesel_Precio_XLT || 0));
        $('#material-viajes').val(formatCurrency(registro.material_Viajes_De_30M3 || 0));
        $('#subtotal-ingreso').val(formatCurrency(registro.subtotal_Ingreso_Viajes_M3 || 0));
        $('#total-gastos').val(formatCurrency(registro.total_Gastos || 0));

        // Campos que no son moneda
        $('#total-km-recorridos').val(registro.total_KM_Recorridos || 0);

        // Checkbox de precio actual
        $('#precioActual').prop('checked', registro.precioActivo === true);

        console.log("Formulario precargado con:", registro);

        // Ejecutar cálculos para verificar
        setTimeout(() => {
            const resultados = calcularTotales();
            calcularSubtotal(resultados);
        }, 100);
    }

    function TablaVacia() {
        if ($.fn.DataTable.isDataTable('#tblDireccionMaterial')) {
            $('#tblDireccionMaterial').DataTable().destroy();
        }

        $('#tblDireccionMaterial').DataTable({
            data: [],
            columns: [
                { title: 'ID', data: 'id', visible: false },
                { title: 'Dirección', data: 'direccion' },
                { title: 'Material', data: 'tipoMaterial.nombreTipoMaterial' },
                { title: 'Cliente', data: 'cliente.nombre' },
                {
                    title: 'Total de Importe',
                    data: 'total_Gastos',
                    render: function (data) {
                        return data ? '$' + data.toLocaleString('es-MX') : '$0';
                    }
                },
                {
                    data: 'precioActivo',
                    title: 'Precio Actual',
                    render: function (data, type, row) {
                        if (data == 1 || data === true) {
                            return '<span style="color: green; font-size: 20px;">●</span> <span style="color: black;">Precio Actual</span>';
                        } else {
                            return '<span style="color: red; font-size: 20px;">●</span> <span style="color: black;">Precio NO Actual</span>';
                        }
                    }
                },
                {
                    data: null,
                    title: 'Acciones',
                    orderable: false,
                    render: function (data, type, row) {
                        return `
                            <button class="btn btn-sm btn-primary btnEditarTipoMaterial" data-id="${row.id}" title="Editar">
                                Editar
                            </button>
                            <button class="btn btn-sm btn-danger btnEliminarTipoMaterial" data-id="${row.id}" title="Eliminar">
                                Eliminar
                            </button>`;
                    }
                }
            ],
            scrollX: true,
            autoWidth: false,
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-MX.json'
            },
            pageLength: 50,
        });
        dataTableInitialized = true;
    }

    function DropListDirecciones() {
        $('#ddlDirecciones').off('change').on('change', function () {
            var optionSeleccionada = $(this).find('option:selected');
            var idSeleccionado = optionSeleccionada.val();
            var nombreSeleccionado = optionSeleccionada.text();

            $('#idDireccion').val(idSeleccionado);
            $('#direccion').val(nombreSeleccionado);

            if (idSeleccionado) {
                ClienteTipoMaterialByDireccionMaterialAndCliente(idSeleccionado);
            } else {
                TablaVacia();
            }
        });
    }

    function ClienteTipoMaterialByDireccionMaterialAndCliente(id) {
        var idCliente = $("#clienteId").val();
        var idMaterial = $("#materialId").val();

        PostMVC('/Administracion/ClienteTipoMaterialByDireccionMaterialAndCliente',
            {
                Id: id,
                IdCliente: idCliente,
                IdMaterial: idMaterial
            },
            function (r) {
                if (r.IsSuccess) {
                    var data = r.Response;
                    console.log('Datos recibidos:', data);
                    cargarDataTable(data);
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: r.ErrorMessage || 'Error al cargar los datos',
                    });
                    TablaVacia();
                }
            }
        );
    }

    function cargarDataTable(data) {
        if ($.fn.DataTable.isDataTable('#tblDireccionMaterial')) {
            $('#tblDireccionMaterial').DataTable().destroy();
        }

        $('#tblDireccionMaterial').DataTable({
            data: data,
            columns: [
                { title: 'ID', data: 'id', visible: false },
                { title: 'Dirección', data: 'direccion' },
                { title: 'Material', data: 'tipoMaterial.nombreTipoMaterial' },
                { title: 'Cliente', data: 'cliente.nombre' },
                {
                    title: 'Total de Importe',
                    data: 'total_Gastos',
                    render: function (data) {
                        return '$' + (data ? data.toLocaleString('es-MX') : '0');
                    }
                },
                {
                    data: 'precioActivo',
                    title: 'Precio Actual',
                    render: function (data, type, row) {
                        if (data == 1 || data === true) {
                            return '<span style="color: green; font-size: 20px;">●</span> <span style="color: black;">Precio Actual</span>';
                        } else {
                            return '<span style="color: red; font-size: 20px;">●</span> <span style="color: black;">Precio NO Actual</span>';
                        }
                    }
                },
                {
                    data: null,
                    title: 'Acciones',
                    orderable: false,
                    render: function (data, type, row) {
                        return `
                            <button class="btn btn-sm btn-primary btnEditarTipoMaterial" data-id="${row.id}" title="Editar">
                                Editar
                            </button>
                            <button class="btn btn-sm btn-danger btnEliminarTipoMaterial" data-id="${row.id}" title="Eliminar">
                                Eliminar
                            </button>`;
                    }
                }
            ],
            scrollX: true,
            responsive: true,
            autoWidth: false,
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-MX.json'
            },
            pageLength: 50,
        });
        dataTableInitialized = true;
    }

    function GetPrecioActivoCombustible() {
        GetMVC('/Administracion/GetPrecioActivoCombustible', function (r) {
            if (r.IsSuccess) {
                var datos = r.Response;
                $("#PrecioCombustibleActual").val(datos.precio || 0);
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar el precio del combustible: ' + (r.ErrorMessage || ''),
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function SearchDireccionesCliente(clienteId) {
        PostMVC('/Administracion/GetDireccionesCliente', { Id: clienteId }, function (r) {
            if (r.IsSuccess) {
                const data = r.Response;
                const $select = $('#ddlDirecciones');
                $select.empty();

                $select.append($('<option>', {
                    value: '',
                    disabled: true,
                    selected: true,
                    text: 'Seleccionar Dirección'
                }));

                $.each(data, function (index, direccion) {
                    const textoDireccion = `${direccion.calle || ''}, ${direccion.colonia || ''}, ${direccion.municipio || ''}, ${direccion.estado || ''}`;

                    $select.append($('<option>', {
                        value: direccion.id,
                        text: textoDireccion
                    }));
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: r.ErrorMessage || 'Error al cargar las direcciones',
                });
            }
        });
    }

    // Función para enviar al servidor
    function AgregarPreciosMaterialACliente() {
        // Validaciones básicas
        const idDireccion = $('#idDireccion').val();
        if (!idDireccion || idDireccion === '0') {
            Swal.fire({
                icon: 'warning',
                title: 'Campo requerido',
                text: 'Debe seleccionar una dirección',
            });
            return;
        }

        // Obtener IDs
        const clienteId = $('#clienteId').val();
        const tipoMaterialId = $('#materialId').val();

        if (!clienteId || clienteId === '0') {
            Swal.fire({
                icon: 'warning',
                title: 'Campo requerido',
                text: 'No se encontró el ID del cliente',
            });
            return;
        }

        if (!tipoMaterialId || tipoMaterialId === '0') {
            Swal.fire({
                icon: 'warning',
                title: 'Campo requerido',
                text: 'No se encontró el ID del material',
            });
            return;
        }

        // Preparar datos - VERSIÓN CORREGIDA
        var data = {
            Id: parseInt($('#id').val()) || 0,
            IdDireccion: idDireccion.toString(),
            Direccion: $('#direccion').val() || '',
            P_Mta_M3: parseFloat($('#p-mat-m3').data('raw-value')) || 0,
            P_Flete_M3: parseFloat($('#p-flete-m3').data('raw-value')) || 0,
            Precio_M3: currencyToNumber($('#precio-m3').val()),
            KM_Cargado: parseFloat($('#km-cargado').val()) || 0,
            KM_Basico: parseFloat($('#km-basio').val()) || 0,
            Total_KM_Recorridos: parseFloat($('#total-km-recorridos').val()) || 0,
            Carga_Disel: parseFloat($('#carga-diesel').val()) || 0,
            Total_Diesel_Precio_XLT: currencyToNumber($('#total-diesel').val()),
            Casetas: parseFloat($('#casetas').data('raw-value')) || 0,
            Mano_De_Obra: parseFloat($('#mano-obra').data('raw-value')) || 0,
            Material_Viajes_De_30M3: currencyToNumber($('#material-viajes').val()),
            Subtotal_Ingreso_Viajes_M3: currencyToNumber($('#subtotal-ingreso').val()),
            Total_Gastos: currencyToNumber($('#total-gastos').val()),
            PrecioActivo: $('#precioActual').is(':checked'),
            // Enviar solo los IDs, no objetos completos
            Cliente: {
                Id: parseInt(clienteId),
            },
            TipoMaterial: {
                Id: parseInt(tipoMaterialId),
            },
            CreatedBy: $('#createdBy').val() || '',
            UpdatedBy: $('#updatedBy').val() || '',
            CreatedDt: $('#createdDt').val() || '',
            UpdatedDt: $('#updatedDt').val() || ''
        };

        console.log('Datos a enviar (corregidos):', data);

        // Determinar endpoint
        const endpoint = '/Administracion/SaveOrUpdateClienteTipoMaterial';

        // Usar $.ajax directamente para mejor control del error
        $.ajax({
            url: endpoint,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(response) {
                try {
                    const r = typeof response === 'string' ? JSON.parse(response) : response;
                    if (r.IsSuccess) {
                        Swal.fire({
                            icon: 'success',
                            title: '¡Éxito!',
                            text: data.Id > 0 ? 'Registro actualizado correctamente' : 'Registro guardado correctamente',
                        }).then(() => {
                            // Recargar la tabla
                            if (idDireccion) {
                                ClienteTipoMaterialByDireccionMaterialAndCliente(idDireccion);
                            }
                            // Limpiar formulario si era nuevo
                            if (data.Id === 0) {
                                limpiarFormulario();
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: r.ErrorMessage || 'Error al guardar el registro',
                        });
                    }
                } catch (e) {
                    console.error('Error parsing response:', e);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Error al procesar la respuesta del servidor',
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error('Error en la petición:', {
                    status: status,
                    error: error,
                    responseText: xhr.responseText,
                    statusCode: xhr.status
                });

                let errorMessage = 'Error al guardar el registro. ';
                if (xhr.responseText) {
                    try {
                        const response = JSON.parse(xhr.responseText);
                        errorMessage += response.ErrorMessage || response.Message || xhr.responseText;
                    } catch(e) {
                        errorMessage += xhr.responseText.substring(0, 200);
                    }
                } else {
                    errorMessage += `Código: ${xhr.status} - ${error}`;
                }

                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: errorMessage,
                });
            }
        });
    }

    // Función para limpiar formulario
    function limpiarFormulario() {
        $('#id').val('0');
        $('#p-mat-m3, #p-flete-m3, #mano-obra, #casetas').each(function () {
            $(this).data('raw-value', 0).val('');
        });
        $('#km-cargado, #km-basio, #carga-diesel').val('');
        $('#precioActual').prop('checked', false);
        // Resetear campos de resultado
        $('[id$="-m3"], #total-diesel, #material-viajes, #subtotal-ingreso, #total-gastos, #total-km-recorridos').val('');
        // Ejecutar cálculos para resetear
        setTimeout(() => {
            ejecutarCalculosInmediatos();
        }, 50);
    }

    // Cuando el documento esté listo
    $(document).ready(function () {
        // Remover el onmouseover del contenedor - causa problemas
        $('.container').off('mouseover');

        // Inicializar campos moneda
        inicializarCamposMoneda();

        // Inicializar eventos
        inicializarEventos();

        // Cargar datos iniciales
        var clienteId = $("#clienteId").val();
        if (clienteId) {
            SearchDireccionesCliente(clienteId);
        }

        // Obtener precio de combustible
        GetPrecioActivoCombustible();

        // Inicializar tabla vacía
        TablaVacia();

        // Inicializar eventos del dropdown
        DropListDirecciones();

        // Inicializar botones de editar/eliminar
        BotonesEditarEliminar();

        // Ejecutar cálculos iniciales
        setTimeout(() => {
            debounceCalculations();
        }, 500);
    });
</script>