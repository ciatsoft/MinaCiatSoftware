@{
    var trabajadorId = (long)ViewBag.TrabajadorId;
}

<style>
    /* Estilos personalizados para mantener la misma apariencia */
    .btn-custom-clean {
        background-color: #5bc0de;
        border-color: #46b8da;
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 12px;
        transition: all 0.3s ease;
    }

        .btn-custom-clean:hover {
            background-color: #31b0d5;
            border-color: #269abc;
            color: white;
        }

    .btn-custom-cancel {
        background-color: #d9534f;
        border-color: #d43f3a;
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 12px;
        transition: all 0.3s ease;
    }

        .btn-custom-cancel:hover {
            background-color: #c9302c;
            border-color: #ac2925;
            color: white;
        }

    .text-success {
        color: #3c763d;
    }

    .fw-bold {
        font-weight: bold;
    }

    .panel-custom {
        margin-bottom: 20px;
        background-color: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        box-shadow: 0 1px 1px rgba(0, 0, 0, 0.05);
    }

    .panel-custom-heading {
        padding: 10px 15px;
        border-bottom: 1px solid #ddd;
        background-color: #f5f5f5;
        border-top-left-radius: 3px;
        border-top-right-radius: 3px;
    }

        .panel-custom-heading h4 {
            margin: 0;
            color: #333;
        }

    .panel-custom-body {
        padding: 15px;
    }

    /* Estilos para DataTables */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        margin-bottom: 15px;
    }

        .dataTables_wrapper .dataTables_filter input {
            border: 1px solid #ccc;
            border-radius: 4px;
            padding: 5px 10px;
            margin-left: 10px;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 5px 12px;
            margin: 0 2px;
            border-radius: 4px;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7;
                color: white !important;
                border: 1px solid #2e6da4;
            }

    .table-bordered {
        border: 1px solid #ddd;
    }

    .table-striped > tbody > tr:nth-of-type(odd) {
        background-color: #f9f9f9;
    }
</style>

<input type="hidden" id="txtTrabajadorId" value="@trabajadorId" />

<div class="container-fluid" style="padding: 20px 15px;">
    <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <div class="panel-body">

            <!-- Título centrado -->
            <div class="row">
                <div class="col-md-12 text-center">
                    <h3 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                        <i class="fa fa-money"></i> Gestión de Salarios
                    </h3>
                </div>
            </div>

            <!-- Campos ocultos -->
            <input type="hidden" name="idregistro" id="idRegistro" value="0" />

            <!-- Campos del formulario -->
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="control-label" style="font-weight: bold;"><i class="fa fa-calendar"></i> Fecha Inicial:</label>
                        <input type="date" name="dtpFI" id="dtpFI" value="" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="control-label" style="font-weight: bold;"><i class="fa fa-calendar"></i> Fecha Final:</label>
                        <input type="date" name="drpFF" id="drpFF" value="" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="control-label" style="font-weight: bold;"><i class="fa fa-dollar"></i> Monto:</label>
                        <input type="text" name="txtMonto" id="txtMonto" value="" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="control-label" style="font-weight: bold;"><i class="fa fa-star"></i> ¿Es el salario actual?:</label>
                        <div style="padding-top: 8px;">
                            <input type="checkbox" name="chbEsSalarioActual" id="chbEsSalarioActual" value="" onchange="ChanegChebSalariOActual()" style="transform: scale(1.2); margin-right: 5px;" />
                            <span id="lblSalarioActual">No</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de acción -->
            <div class="row">
                <div class="col-md-12 text-center">
                    <button type="button" id="btnGuardarSalario" onclick="SaveOrUpdateSalario();" class="btn btn-success">
                        <i class="fa fa-save"></i> Guardar
                    </button>
                    <button type="button" id="btnGuardarCancelar" onclick="CancelarSalario();" class="btn btn-danger">
                        <i class="fa fa-times"></i> Cancelar
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <i class="fa fa-list"></i> Historial de Salarios
        </div>
        <div class="panel-body table-responsive">
            <table id="tableSalario" class="table table-bordered table-striped" style="width: 100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Fecha Inicial</th>
                        <th>Fecha Final</th>
                        <th>Monto</th>
                        <th>Salario Actual</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Script para actualizar el label del checkbox
        var chkSalarioActual = document.getElementById('chbEsSalarioActual');
        var lblSalarioActual = document.getElementById('lblSalarioActual');

        if (chkSalarioActual && lblSalarioActual) {
            function updateSalarioActualLabel() {
                lblSalarioActual.textContent = chkSalarioActual.checked ? 'Sí' : 'No';
                lblSalarioActual.style.color = chkSalarioActual.checked ? '#5cb85c' : '#d9534f';
            }
            chkSalarioActual.addEventListener('change', updateSalarioActualLabel);
            updateSalarioActualLabel();
        }

        $('#txtMonto').on('input', function () {
            // Permitir números y un punto decimal
            let input = $(this).val();

            // Remover todo excepto números y un punto decimal
            let value = input.replace(/[^0-9.]/g, '');

            // Permitir solo un punto decimal
            let parts = value.split('.');
            if (parts.length > 2) {
                value = parts[0] + '.' + parts.slice(1).join('');
            }

            // Limitar a 2 decimales
            if (parts.length > 1 && parts[1].length > 2) {
                value = parts[0] + '.' + parts[1].substring(0, 2);
            }

            $(this).val(value);

            // Formatear como moneda cuando pierde el foco
        }).on('blur', function () {
            let value = $(this).val();
            if (value && value.trim() !== '') {
                // Convertir a número y formatear
                let num = parseFloat(value);
                if (!isNaN(num)) {
                    let formatted = '$ ' + num.toLocaleString('es-MX', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                    $(this).val(formatted);
                }
            }
        }).on('focus', function () {
            // Al enfocar, quitar el formato para editar
            let value = $(this).val().replace(/[^0-9.]/g, '');
            $(this).val(value);
        });

        // Para enviar al servidor
        $('form').on('submit', function () {
            let rawValue = $('#txtMonto').val().replace(/[^0-9.]/g, '');
            if (rawValue) {
                let num = parseFloat(rawValue);
                if (!isNaN(num)) {
                    $('#txtMonto').val(num.toFixed(2));
                }
            }
        });
    });

    function CancelarSalario() {
        window.location.reload();
    }
</script>

