@model MinaTolEntidades.DtoEmpleados.Empleado
@{
    ViewBag.Title = "Alta/Edición Empleado";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var fechaActual2 = DateTime.Now.ToString("yyyy-MM-dd");
}

<div class="container-fluid" style="padding: 20px 15px;">
    @using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmEmpleado", @id = "frmEmpleado", onsubmit = "return false;" }))
    {
        @Html.HiddenFor(x => x.Id, new { id = "id" })
        @Html.HiddenFor(x => x.Estatus, new { id = "estatus" })
        @Html.HiddenFor(x => x.CreatedDt, new { id = "createdDt", @Value = fechaActual })
        @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", @Value = usuarioToken.UserName })
        @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", @Value = usuarioToken.UserName })
        @Html.HiddenFor(x => x.UpdatedDt, new { id = "updatedDt", @Value = fechaActual })

        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-users"></i> Empleados
                        </h1>
                    </div>
                </div>

                @if (ViewBag.EsEdicion == true)
                {
                    <div class="row" id="rowFotografia">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="control-label" style="font-weight: bold;"><i class="fa fa-camera"></i> Fotografía:</label>
                                <input class="form-control" type="file" id="fotografia" accept="image/*" style="display:none;" />
                                <button type="button" class="btn btn-info form-control" onclick="document.getElementById('fotografia').click()" style="margin-top: 5px;">
                                    <i class="fa fa-folder-open"></i> Seleccionar Foto
                                </button>
                                <div id="preview-container" class="mt-2" style="display:none; margin-top: 10px;">
                                    <img id="preview-image" class="img-thumbnail" style="max-width:200px; max-height:200px;" />
                                    <button type="button" class="btn btn-danger btn-sm" onclick="eliminarFoto()" style="margin-top: 5px;">
                                        <i class="fa fa-trash"></i> Eliminar
                                    </button>
                                </div>
                                <div id="no-image-message" class="text-muted mt-1" style="margin-top: 10px;">
                                    No hay imagen seleccionada
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-user"></i> Nombre:</label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", @type = "text", id = "nombre", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-user"></i> Apellido Paterno:</label>
                            @Html.TextBoxFor(x => x.ApellidoPaterno, new { @class = "form-control", @type = "text", id = "apellidoPaterno", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-user"></i> Apellido Materno:</label>
                            @Html.TextBoxFor(x => x.ApellidoMaterno, new { @class = "form-control", @type = "text", id = "apellidoMaterno", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-phone"></i> Teléfono:</label>
                            @Html.TextBoxFor(x => x.Telefono, new { @class = "form-control", @type = "text", id = "telefono", required = "required" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-envelope"></i> Email:</label>
                            @Html.TextBoxFor(x => x.Email, new { @class = "form-control", @type = "text", id = "email", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-id-card"></i> Número del Seguro Social:</label>
                            @Html.TextBoxFor(x => x.NSS, new { @class = "form-control", @type = "text", id = "nss", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-calendar"></i> Día Nómina:</label>
                            @Html.DropDownListFor(x => x.DiaNomina,
                                ViewBag.DiaNominaOptions as IEnumerable<SelectListItem>,
                                "Selecciona una opcion",
                                new { @class = "form-control", required = "required", id = "diaNomina" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-building"></i> Departamento:</label>
                            @Html.DropDownListFor(x => x.IdDepartamento,
                                new SelectList((IEnumerable<SelectListItem>)ViewBag.Departamentos, "Value", "Text"),
                                "Selecciona un departamento",
                                new { @class = "form-control", id = "ddlDepartamento" })
                        </div>
                    </div>
                    @Html.HiddenFor(x => x.NombreDepartamento, new { id = "nombreDepartamento" })
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-comment"></i> Comentario:</label>
                            @Html.TextBoxFor(x => x.Comentario, new { @class = "form-control", @type = "text", id = "comentario", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-calendar-plus"></i> Fecha de Contratación:</label>
                            @Html.TextBoxFor(x => x.FechaContratacion, new { @class = "form-control", id = "fechaContratacion", Value = fechaActual2, @readonly = "readonly" })
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" id="btnGuardar" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Empleado/AltaEdicion" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                        @if (ViewBag.EsEdicion == true)
                        {
                            <button type="button" id="btnDocumentosEmpleado" class="btn btn-info">
                                <i class="fa fa-file"></i> Documentación
                            </button>
                        }
                    </div>
                </div>

            </div>
        </div>
    }

    <div class="container-fluid" style="padding: 0 15px 20px 15px;">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <i class="fa fa-list"></i> Listado de Empleados
            </div>
            <div class="panel-body table-responsive">
                <table id="tblEmpleados" class="table table-bordered table-striped" style="width: 100%;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre Completo</th>
                            <th>NSS</th>
                            <th>Departamento</th>
                            <th>Teléfono</th>
                            <th>Fecha de Contratación</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    <div style="display: flex; justify-content: flex-end; align-items: center; gap: 10px; margin-top: -20px;">
        <button id="btnGenerarPDF" class="btn btn-success">
            <i class="fa fa-file-pdf-o"></i> Generar Reporte PDF
        </button>
        <button id="btnGenerarExcel" class="btn btn-success">
            <i class="fa fa-file-excel-o"></i> Generar Reporte Excel
        </button>
    </div>
</div>

<script src="@(Url.StaticFile("Scripts/Trabajador/AltaEdicion.js"))"></script>

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label {
        color: #333333 !important;
    }
</style>