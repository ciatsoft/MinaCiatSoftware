@model MinaTolEntidades.DtoEmpleados.Empleado
@{
    ViewBag.Title = "Alta/Edición Empleado";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var fechaActual2 = DateTime.Now.ToString("yyyy-MM-dd");

}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>

<div class="content">
    @using (Html.BeginForm("SaveOrUpdateEmpleado", "Empleado", FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmEmpleado", @id = "frmEmpleado" }))
    {
        @Html.HiddenFor(x => x.Id, new { id = "id" })
        @Html.HiddenFor(x => x.Estatus, new { id = "estatus" })
        @Html.HiddenFor(x => x.CreatedDt, new { id = "createdDt", @Value = fechaActual })
        @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", @Value = usuarioToken.UserName })
        @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", @Value = usuarioToken.UserName })
        @Html.HiddenFor(x => x.UpdatedDt, new { id = "updatedDt", @Value = fechaActual })

        <br />
        <center><h1>Empleados</h1></center>
        <div class="tabla-consultas-empleados">
            <div class="rectangulos" style="width: 100%;">
                <div class="row">
                    <div class="col-lg-3">
                        <label>Nombre:</label>
                        @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", @type = "text", id = "nombre", required = "required" })
                    </div>
                    <div class="col-lg-3">
                        <label>Apellido Paterno:</label>
                        @Html.TextBoxFor(x => x.ApellidoPaterno, new { @class = "form-control", @type = "text", id = "apellidoPaterno", required = "required" })
                    </div>
                    <div class="col-lg-3">
                        <label>Apellido Materno:</label>
                        @Html.TextBoxFor(x => x.ApellidoMaterno, new { @class = "form-control", @type = "text", id = "apellidoMaterno", required = "required" })
                    </div>
                    <div class="col-lg-3">
                        <label>Telefono:</label>
                        @Html.TextBoxFor(x => x.Telefono, new { @class = "form-control", @type = "text", id = "telefono", required = "required" })
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-3">
                        <label>Email:</label>
                        @Html.TextBoxFor(x => x.Email, new { @class = "form-control", @type = "text", id = "email", required = "required" })
                    </div>
                    <div class="col-lg-3">
                        <label>Numero del Seguro Social:</label>
                        @Html.TextBoxFor(x => x.NSS, new { @class = "form-control", @type = "text", id = "nss", required = "required" })
                    </div>
                    <div class="col-lg-3">
                        @*SELECT CONFIG*@
                        <label>Dia Nomina:</label>
                        @Html.DropDownListFor(x => x.DiaNomina,
                            ViewBag.DiaNominaOptions as IEnumerable<SelectListItem>,
                            "Selecciona una opcion",
                            new { @class = "form-control", required = "required", id = "diaNomina" })
                    </div>
                    <div class="col-lg-3">
                        @*SELECT MAPEADO DE AREA DE TRABAJO*@
                        <label>Departamento:</label>
                        @Html.DropDownListFor(x => x.IdDepartamento,
                            new SelectList((IEnumerable<SelectListItem>)ViewBag.Departamentos, "Value", "Text"),
                            "Selecciona un departamento",
                            new { @class = "form-control", id = "ddlDepartamento" })
                    </div>
                    @Html.HiddenFor(x => x.NombreDepartamento, new { id = "nombreDepartamento" })
                </div>
                <div class="row">
                    <div class="col-lg-3">
                        <label>Comentario:</label>
                        @Html.TextBoxFor(x => x.Comentario, new { @class = "form-control", @type = "text", id = "comentario", required = "required" })
                    </div>
                    <div class="col-lg-3">
                        <label>Fecha de Contratacion:</label>
                        @Html.TextBoxFor(x => x.FechaContratacion, new { @class = "form-control", id = "fechaContratacion", Value = fechaActual2, @readonly = "readonly" })
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-12 d-flex justify-content-between">
                        <div>
                            <input id="btnGuardar" type="submit" value="Guardar" class="btn btn-success btn-lg-custom" />
                        </div>
                        <a href="/Taller/Inventario_Taller" class="btn btn-custom-cancel btn-lg-custom">Cancelar</a>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (ViewBag.EsEdicion == true)
    {
        <input id="btnDocumentosEmpleado" type="submit" value="Documentacion" class="btn btn-custom-clean" />
    }
    <br />
    <br />
    <table id="tblEmpleados" class="table table-bordered table-striped" style="width: 100%;"></table>
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 20px;">
        <div class="mb-2" style="text-align: right;">
            <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
                Generar Reporte PDF
            </button>
        </div>
    </div>
</div>
<script src="@(Url.StaticFile("Scripts/Trabajador/AltaEdicion.js"))"></script>
