@model MinaTolEntidades.DtoEmpleados.Documentos
@{
    ViewBag.Title = "ListaDocumentos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
}

<div class="container-fluid" style="padding: 20px 15px;">
    @using (Html.BeginForm("SaveOrUpdateDocumento", "Empleado", FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmDocumento", @id = "frmDocumento" }))
    {
        @Html.HiddenFor(x => x.Id, new { @id = "id" })
        @Html.HiddenFor(x => x.Estatus)
        @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy" })
        @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy" })
        @Html.HiddenFor(x => x.CreatedDt, new { id = "CreatedDt" })
        @Html.HiddenFor(x => x.UpdatedDt, new { id = "UpdatedDt" })

        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-file-text"></i> Documentos
                        </h1>
                    </div>
                </div>

                <!-- Campos del formulario -->
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-tag"></i> Nombre:</label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", @type = "text", id = "nombre", required = "required" })
                        </div>
                    </div>

                    @Html.HiddenFor(x => x.Nombre, new { id = "nombre" })

                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-align-left"></i> Descripción:</label>
                            @Html.TextBoxFor(x => x.Descripcion, new { @class = "form-control", @type = "text", id = "descripcion", required = "required" })
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-calendar"></i> Fecha:</label>
                            <input class="form-control" type="text" id="fecha" value="@fechaActual" readonly />
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="submit" id="btnGuardar" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Empleado/ListaDocumentos" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>

            </div>
        </div>
    }
</div>

<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <i class="fa fa-list"></i> Listado de Documentos
        </div>
        <div class="panel-body table-responsive">
            <table id="tblDocumentos" class="table table-bordered table-striped" style="width: 100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script src="@(Url.StaticFile("Scripts/Trabajador/Documento.js"))"></script>

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label {
        color: #333333 !important;
    }
</style>