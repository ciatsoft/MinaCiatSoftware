@{
    ViewBag.Title = "Iniciar Sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <!-- Basic -->
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <!-- Mobile Metas -->
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <title>@ViewBag.Title</title>

    <link rel="icon" href="~/Assets/img/Logo.ico" type="image/x-icon">

    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/font-awesome.css" rel="stylesheet" />
    <link href="~/Content/sweetalert.css" rel="stylesheet" />

    <style>
        body {
            background-image: url('@Url.Content("~/Assets/img/minalogin.jpg")') !important;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            position: relative;
        }

        /* Overlay oscuro para mejorar legibilidad */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            z-index: 0;
        }

        .container-fluid, .row, main {
            position: relative;
            z-index: 1;
        }

        /* Estilos del panel */
        .panel-formal {
            border: none;
            border-radius: 12px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.4);
            overflow: hidden;
        }

        /* Encabezado NEGRO */
        .panel-formal > .panel-heading {
            background: #000000;
            border: none;
            padding: 35px 20px;
        }

        /* Cuerpo BLANCO */
        .panel-formal > .panel-body {
            background-color: #ffffff;
            padding: 40px 35px;
        }

        /* Pie NEGRO */
        .panel-formal > .panel-footer {
            background-color: #000000;
            border-top: 1px solid #222;
            padding: 20px;
        }

        /* Estilos para inputs */
        .input-group {
            margin-bottom: 20px;
        }

        /* Iconos NEGROS */
        .input-group-addon {
            background-color: #f8f9fa !important;
            border: 2px solid #ddd !important;
            border-right: none !important;
            color: #000000 !important;
            padding: 12px 15px !important;
            font-size: 18px !important;
            transition: all 0.3s ease;
        }

        .form-control {
            background-color: #ffffff !important;
            border: 2px solid #ddd !important;
            border-left: none !important;
            color: #333 !important;
            height: 52px !important;
            font-size: 15px !important;
            box-shadow: none !important;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #000000 !important;
            box-shadow: none !important;
        }

        .form-control:focus + .input-group-addon {
            border-color: #000000 !important;
        }

        .form-control::placeholder {
            color: #999 !important;
            font-size: 14px;
        }

        /* Botón de mostrar/ocultar contraseña */
        .btn-toggle-password {
            background-color: #f8f9fa !important;
            border: 2px solid #ddd !important;
            border-left: none !important;
            color: #000000 !important;
            height: 52px !important;
            padding: 0 15px !important;
            transition: all 0.3s ease;
        }

        .btn-toggle-password:hover {
            background-color: #e9ecef !important;
            color: #333 !important;
        }

        /* Botón de login NEGRO con letras BLANCAS */
        .btn-login {
            background: #000000;
            border: none;
            color: #ffffff;
            font-weight: 600;
            letter-spacing: 1px;
            padding: 14px;
            font-size: 16px;
            border-radius: 6px;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-login:hover {
            background: #222222;
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
            color: #ffffff;
        }

        /* Checkbox y enlaces */
        .checkbox-custom label {
            color: #666;
            font-weight: normal;
            font-size: 13px;
        }

        .checkbox-custom input[type="checkbox"] {
            margin-right: 8px;
        }

        .link-forgot {
            color: #000000;
            font-size: 13px;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .link-forgot:hover {
            color: #333;
            text-decoration: none;
        }

        hr {
            border-top: 1px solid #e0e0e0;
            margin: 25px 0;
        }

        /* Textos en el footer */
        .footer-text {
            color: #888;
        }

    </style>
</head>
<body>
    @RenderBody()

    <!-- SCRIPTS - ORDEN CORRECTO -->
    <script src="~/Scripts/jquery-1.9.0.js"></script>
    <script src="~/Scripts/bootstrap.js"></script>
    <script src="~/Scripts/jquery.validate.js"></script>
    <script src="~/Scripts/sweetalert.min.js"></script>
    <script src="@(Url.StaticFile("Scripts/Home/Autenticacion.js"))"></script>
</body>
</html>