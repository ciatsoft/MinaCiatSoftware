@{
    ViewBag.Title = "Mina San Miguel";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <title>@ViewBag.Title</title>

    <link rel="icon" href="@Url.Content("~/Assets/img/Logo.ico")" type="image/x-icon" />

    <!-- Bootstrap core CSS - LOCAL -->
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/font-awesome.css" rel="stylesheet" />
    <link href="~/Content/sweetalert.css" rel="stylesheet" />
    <link href="~/Content/DataTables/css/jquery.dataTables.css" rel="stylesheet">
    <link href="~/Content/DataTables/css/responsive.dataTables.css" rel="stylesheet">

    <style>
body{background:#000;color:#fff}

/* NAVBAR */
.navbar{
    background:#000;
    border:0;
    margin:0;
}

.navbar-nav>li>a{
    color:#fff!important;
    padding:18px 12px;
    font-weight:600;
}

.navbar-nav>li>a:hover{
    background:#333!important;
}

/* DROPDOWN SOLO ESTILO */
.dropdown-menu{
    background:#fff;
    min-width:220px;
}

.dropdown-menu>li>a{
    color:#000!important;
    padding:8px 15px;
}

.dropdown-menu>li>a:hover{
    background:#f5f5f5!important;
}

/* HERO */
.slider_section{
    background:linear-gradient(rgba(0,0,0,.8),rgba(0,0,0,.8)),
    url("@Url.Content("~/Assets/img/minas.png")") center/cover fixed;
    min-height:calc(100vh - 140px);
    padding:40px 0;
}

/* FOOTER */
.footer,.contacto-ciat{
    background:#002c53;
    color:#fff;
    padding:20px 0;
}

/* ================= MOBILE REAL BS3 ================= */
@@media (max-width:767px){

    .navbar-collapse{
        position:absolute;
        top:60px;
        left:0;
        right:0;
        background:#000;
        z-index:9999;
    }

    .navbar-nav>li{
        float:none!important;
        width:100%;
    }

    .navbar-nav>li>a{
        padding:14px 20px!important;
    }

    /* el submenu ahora baja correctamente */
    .dropdown-menu{
        position:static!important;
        float:none;
        width:100%;
        background:#fff!important;
    }
}
/* ===== 1) HOVER SOLO EN DESKTOP ===== */
@@media (min-width:768px){
    .navbar-nav > li.dropdown:hover > .dropdown-menu{
        display:block;
        margin-top:0;
    }
}

/* ===== 2) BOTÓN HAMBURGUESA BLANCO ===== */
.navbar-toggle{
    border-color:#fff!important;
}
.navbar-toggle .icon-bar{
    background:#fff!important;
}

/* ===== 3) COLLAPSE TRANSPARENTE PARA VER LA IMAGEN ===== */
@@media (max-width:767px){
    .navbar-collapse{
        background:#000!important;   /* clave */
    }

    .navbar{
        background:rgba(0,0,0);        /* nav con transparencia */
    }
}
/* ===== FIX DEFINITIVO CAMBIO MOBILE -> DESKTOP BS3 ===== */
@@media (min-width:768px){
    .navbar-collapse{
        position:relative!important;
        top:auto!important;
        left:auto!important;
        right:auto!important;
        background:transparent!important;
        overflow:visible!important;
        height:auto!important;
    }

    .dropdown-menu{
        position:absolute!important;
    }
}
        /* ===== FIX COLOR AL HACER CLICK EN ITEM PADRE DEL DROPDOWN ===== */
        .navbar-nav > li > a:focus,
        .navbar-nav > li > a:active,
        .navbar-nav > li.open > a,
        .navbar-nav > li.open > a:focus,
        .navbar-nav > li.open > a:hover {
            background: #181818 !important;
            color: #fff !important;
        }
    </style>

    <script src="~/Scripts/jquery-1.9.0.js"></script>
    <script src="~/Scripts/bootstrap.js"></script>
    <script src="~/Scripts/jquery.validate.js"></script>
    <script src="~/Scripts/DataTables/jquery.dataTables.js"></script>
    <script src="~/Scripts/DataTables/dataTables.responsive.js"></script>
    <script src="~/Scripts/sweetalert.min.js"></script>
    <script src="@Url.StaticFile("Assets/script.js")"></script>
    <script src="@Url.StaticFile("Scripts/Comun/Comun.js")"></script>
    @RenderSection("scripts", required: false)
</head>

<body>
    <header class="header_section">
        <div class="container-fluid">
            <nav class="navbar">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbarSupportedContent">
                        <span class="sr-only">Toggle navigation</span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                </div>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="nav navbar-nav" id="mainNavbar">
                        <!-- Aquí se inyectan los <li> del menú dinámico -->
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <!-- CONTENIDO PRINCIPAL -->
    <section class="slider_section">
        <div class="container">
            @RenderBody()
        </div>
    </section>

    <!-- CONTACTO Y FOOTER -->
    <div class="contacto-ciat">
        <div class="container">
            <div class="row">
                <div class="col-md-4 text-center">
                    <strong style="font-size: 16px; display: block; margin-bottom: 8px;">
                        <i class="fa fa-user-circle" style="font-size: 18px;"></i> Director General
                    </strong>
                    <p style="font-size: 14px; margin-bottom: 4px;">
                        <i class="fa fa-user" style="font-size: 14px;"></i> Juan Carlos Tinoco Herrera
                    </p>
                    <p style="font-size: 14px; margin-bottom: 0;">
                        <i class="fa fa-phone" style="font-size: 14px;"></i> Tel: +52 782 132 9772
                    </p>
                </div>

                <div class="col-md-4 text-center">
                    <i class="fa fa-info-circle" style="font-size: 20px; margin-bottom: 5px; display: block;"></i>
                    <p style="font-size: 13px; line-height: 1.4; max-width: 90%; margin: 0 auto;">
                        Consultas sobre el funcionamiento del sistema, contactar a CIATSoftware
                    </p>
                </div>

                <div class="col-md-4 text-center">
                    <strong style="font-size: 16px; display: block; margin-bottom: 8px;">
                        <i class="fa fa-lightbulb-o" style="font-size: 18px;"></i> Directora Innovación
                    </strong>
                    <p style="font-size: 14px; margin-bottom: 4px;">
                        <i class="fa fa-user" style="font-size: 14px;"></i> Cesia Santiago Trejo
                    </p>
                    <p style="font-size: 14px; margin-bottom: 0;">
                        <i class="fa fa-phone" style="font-size: 14px;"></i> Tel: +52 228 182 7906
                    </p>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container text-center">
            <i class="fa fa-copyright" style="font-size: 14px;"></i>
            <span class="text-muted" style="font-size: 13px;">2024 Desarrollado por CIATSoftware</span>
        </div>
    </footer>

    <!-- MODAL -->
    <div class="modal fade" id="genericModal" role="dialog">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title" id="titleGenerciModal"></h4>
                </div>
                <div class="modal-body" id="boddyGeericModal">
                    <p>Some text in the modal.</p>
                </div>
            </div>
        </div>
    </div>
    <script>
        $(document).ready(function () {
            $("#mainNavbar").load("@Url.Action("PartialMenus", "Home")");
        });
    </script>
</body>

</html>