@{
    ViewBag.Title = "Mina San Miguel";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <title>@ViewBag.Title</title>

    <link rel="icon" href="@Url.Content("~/Assets/img/Logo.ico")" type="image/x-icon" />

    <!-- Bootstrap core CSS - LOCAL -->
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/font-awesome.css" rel="stylesheet" />
    <link href="~/Content/sweetalert.css" rel="stylesheet" />

    <!-- Tus estilos personalizados -->
    <link href="@Url.Content("~/Assets/css/style.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Assets/css/estiloClientes.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Assets/css/responsive.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Assets/css/estiloVentas.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Assets/css/jquery.dataTables.min.css")" rel="stylesheet" />

    <style>
        /* Fondo negro para toda la página */
        body {
            background-color: #000000 !important;
            color: #ffffff;
        }

        /* Header negro */
        .header_section {
            background-color: #000000;
            border-bottom: 1px solid #333;
        }

        /* Navbar negra - TAMAÑO AJUSTADO */
        .navbar {
            background-color: #000000 !important;
            border: none;
            margin-bottom: 0;
            min-height: 60px;
        }

        .navbar-brand {
            padding: 5px 15px;
        }

        .navbar-brand img {
            height: 45px;
            width: auto;
        }

        /* Links del menú principal - TAMAÑO OPTIMIZADO */
        .navbar-nav > li > a {
            color: #ffffff !important;
            font-size: 14px;
            font-weight: 600;
            padding: 20px 12px;
            transition: all 0.3s ease;
        }

        .navbar-nav > li > a:hover,
        .navbar-nav > li > a:focus {
            background-color: #333333 !important;
            color: #ffffff !important;
        }

        /* Iconos en menú principal */
        .navbar-nav > li > a i {
            margin-right: 6px;
            font-size: 14px;
        }

        /* DROPDOWN MENU - FONDO BLANCO Y LETRAS NEGRAS */
        .dropdown-menu {
            background-color: #ffffff !important;
            border: 1px solid #dddddd !important;
            border-radius: 4px;
            box-shadow: 0 6px 12px rgba(0,0,0,0.175);
            min-width: 220px;
        }

        /* Items del dropdown - TAMAÑO AJUSTADO */
        .dropdown-menu > li > a {
            color: #333333 !important;
            padding: 8px 15px;
            font-size: 13px;
            font-weight: normal;
            border-bottom: 1px solid #eeeeee;
            transition: all 0.2s ease;
        }

        .dropdown-menu > li > a:hover,
        .dropdown-menu > li > a:focus {
            background-color: #f5f5f5 !important;
            color: #000000 !important;
            padding-left: 20px;
        }

        /* Iconos en dropdown - negros */
        .dropdown-menu > li > a i {
            margin-right: 8px;
            color: #333333 !important;
            font-size: 13px;
            width: 18px;
        }

        /* Caret (flecha) del dropdown */
        .dropdown-toggle .caret {
            margin-left: 5px;
            border-top-color: #ffffff;
            border-bottom-color: #ffffff;
        }

        /* Botón toggler para móvil */
        .navbar-toggle {
            background-color: #333333;
            border: 1px solid #555555;
            margin-top: 12px;
            margin-bottom: 12px;
        }

        .navbar-toggle .icon-bar {
            background-color: #ffffff;
            width: 22px;
            height: 2px;
            border-radius: 1px;
        }

        /* Slider section */
        .slider_section {
            background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url("@Url.Content("~/Assets/img/minas.png")") fixed center center;
            background-size: cover;
            padding: 40px 0;
            min-height: calc(100vh - 160px);
        }

        /* Contacto - MANTENIENDO AZULES */
        .contacto-ciat {
            background-color: #002c53 !important;
            color: #ffffff;
            padding: 20px;
        }

        .contacto-ciat i {
            margin-right: 5px;
        }

        /* Footer - TONOS AZULES COMO AL PRINCIPIO */
        .footer {
            background-color: #002c53 !important;
            color: #ffffff;
            padding: 15px 0;
            border-top: 1px solid #004080;
        }

        .footer .text-muted {
            color: #cccccc !important;
        }

            .dropdown-menu {
                min-width: 200px;
            }
        }


            .dropdown-menu {
                position: static;
                float: none;
                width: 100%;
                background-color: #ffffff !important;
                margin-left: 15px;
                border: none !important;
                box-shadow: none;
            }

            .dropdown-menu > li > a {
                padding: 8px 15px 8px 30px;
            }

            .dropdown-menu > li > a:hover {
                padding-left: 35px;
            }

            .navbar-nav {
                margin: 0;
            }

            .contacto-ciat .row > div {
                margin-bottom: 15px;
            }

            .slider_section {
                padding: 20px 0;
            }
        }

    </style>
</head>

<body>
