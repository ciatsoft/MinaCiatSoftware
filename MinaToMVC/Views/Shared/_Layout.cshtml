                                <li><a href="@Url.Action("locales", "Viajes")"><i class="fa fa-truck"></i> Viajes Almacenes</a></li>
                                <li><a href="@Url.Action("Concreteras", "Viajes")"><i class="fa fa-building-o"></i> Viajes Concreteras</a></li>
                                <li><a href="@Url.Action("ReportesViajesLocales", "Viajes")"><i class="fa fa-file-text-o"></i> Generar Reportes</a></li>
                                <li><a href="@Url.Action("PreFactura", "Viajes")"><i class="fa fa-file-text-o"></i> Pre-Factura</a></li>
                            </ul>
                        </li>
                        <li class="dropdown">
                            <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="fa fa-users"></i> RRHH <span class="caret"></span>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a href="@Url.Action("AltaEdicion", "Empleado")"><i class="fa fa-id-card-o"></i> Empleados</a></li>
                                <li><a href="@Url.Action("ListaDocumentos", "Empleado")"><i class="fa fa-folder-open-o"></i> Catálogo Documentos</a></li>
