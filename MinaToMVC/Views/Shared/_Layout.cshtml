                                <li><a href="@Url.Action("NominaEmpleado", "RH")"><i class="fa fa-calculator"></i> Generar Nóminas</a></li>
                                <li><a href="@Url.Action("BajaEmpleados", "RH")"><i class="fa fa-book"></i> Historial Bajas</a></li>
                            </ul>
                        </li>
                        <li class="dropdown">
                            <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="fa fa-wrench"></i> Taller <span class="caret"></span>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a href="@Url.Action("Vehiculos", "Taller")"><i class="fa fa-car"></i> Vehículos</a></li>
                                <li><a href="@Url.Action("Inventario_Taller", "Taller")"><i class="fa fa-shopping-cart"></i> Inventario Taller</a></li>
                                <li><a href="@Url.Action("CategoriaInventario", "Taller")"><i class="fa fa-tags"></i> Categorías</a></li>
                            </ul>
                        </li>
                        <li class="dropdown">
                            <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="fa fa-book"></i> Catálogos <span class="caret"></span>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a href="@Url.Action("UnidadMedida", "Catalog")"><i class="fa fa-arrows-h"></i> Unidades Medida</a></li>
                                <li><a href="@Url.Action("TipoVehiculo", "Catalog")"><i class="fa fa-truck"></i> Tipo Vehículo</a></li>
                                <li><a href="@Url.Action("AreaTrabajo", "Catalog")"><i class="fa fa-briefcase"></i> Área Trabajo</a></li>
                                <li><a href="@Url.Action("Roll", "Catalog")"><i class="fa fa-user-o"></i> Roles</a></li>
