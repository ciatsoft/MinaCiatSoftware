@{
    ViewBag.Title = "Locales";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var estatus = new List<string> { "Activo", "Inactivo" };

    var tipoMateriales = (List<MinaTolEntidades.DtoClientes.ClienteTipoMaterial>)ViewBag.TipoMaterial;
    var trabajadores = (List<MinaTolEntidades.DtoSucursales.DtoTrabajador>)ViewBag.Trabajadores;
    var vehiculos = (List<MinaTolEntidades.DtoClientes.Vehiculo>)ViewBag.Vehiculos;
    var clientes = (List<MinaTolEntidades.DtoClientes.Cliente>)ViewBag.Clientes;
    var unidadmedida = (List<MinaTolEntidades.DtoSucursales.UnidadMedida>)ViewBag.UnidadDeMedida;
    var ubicaciones = (List<MinaTolEntidades.DtoCatalogos.DtoUbicacion>)ViewBag.Ubicaciones;
    var ViajeLocal = (MinaTolEntidades.DtoViajes.DtoViajeLocal)Model;
}

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label, label {
        color: #333333 !important;
        font-weight: bold;
    }

    /* Botón imprimir */
    .btn-imprimir {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #000000 !important;
        padding: 5px 10px;
        border-radius: 4px;
        margin: 2px;
    }

        .btn-imprimir:hover {
            background-color: #e0a800;
            border-color: #d39e00;
            color: #000000 !important;
        }

    /* Panel styles */
    .panel-custom {
        margin-bottom: 20px;
        background-color: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        box-shadow: 0 1px 1px rgba(0,0,0,0.05);
    }

    .panel-custom-heading {
        padding: 10px 15px;
        border-bottom: 1px solid #ddd;
        background-color: #f5f5f5;
        border-top-left-radius: 3px;
        border-top-right-radius: 3px;
    }

        .panel-custom-heading h4 {
            margin: 0;
            color: #333;
        }

    .panel-custom-body {
        padding: 15px;
    }
</style>

<form enctype="multipart/form-data" id="frmViajesInternos" method="post" name="frmViajesInternos">
    <!-- Campos ocultos para los datos automáticos -->
    <input type="hidden" id="txtCreatedBy" value="@User.Identity.Name" />
    <input type="hidden" id="txtCreatedDt" value="@DateTime.Now" />
    <input type="hidden" id="txtUpdatedBy" value="@User.Identity.Name" />
    <input type="hidden" id="txtUpdatedDt" value="@DateTime.Now" />
    <input type="hidden" id="txtViajeinterno" />
    <input type="hidden" id="totalKMRecorridos" value="0" />
    <input type="hidden" id="totalImporte" value="0" />

    <div class="container-fluid" style="padding: 20px 15px;">
        <!-- Panel Principal -->
        <div class="panel panel-default" style="background-color: #ffffff;">
            <div class="panel-body" style="background-color: #ffffff; color: #333333;">

                <!-- Título -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important;">
                            <i class="fa fa-truck"></i> Viajes de Almacenes
                        </h1>
                    </div>
                </div>

                <!-- Fila 1 -->
                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-hashtag"></i> Folio:
                            </label>
                            <input type="text" id="Folio" name="Folio" class="form-control" value="@ViewBag.Folio" disabled />
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-map-marker"></i> Ubicación Origen:
                            </label>
                            <select id="ddlUOrigen" name="ddlUOrigen" class="form-control" disabled>
                                @foreach (var i in ubicaciones)
                                {
                                    <option value="@i.Id">@i.NombreUbicacion</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-building-o"></i> Cliente:
                            </label>
                            <select id="ddlCliente" class="form-control">
                                <option value="" disabled selected>Selecciona una opcion</option>
                                @foreach (var i in clientes.Where(c => c.TipoCliente == 1).OrderBy(c => c.Nombre))
                                {
                                    <option value="@i.Id">@i.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-cube"></i> Tipo de Material:
                            </label>
                            <select id="ddlTipoMaterial" class="form-control">
                                <option value="" disabled selected>Selecciona una opcion</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Fila 2 -->
                <div class="row">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-location-arrow"></i> Direccion Destino:
                            </label>
                            <select id="ddlDireccionesCliente" class="form-control">
                                <option value="" disabled selected>Selecciona una opcion</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-user"></i> Transportista:
                            </label>
                            <select id="ddlTransportistas" class="form-control">
                                @foreach (var i in trabajadores)
                                {
                                    <option value="@i.Id">@i.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-car"></i> Vehículo:
                            </label>
                            <select id="ddlVehiculo" class="form-control">
                                @foreach (var i in vehiculos)
                                {
                                    <option value="@i.Id">@($"{i.TipoVehiculo.Nombre}, {i.Color}, {i.Placa}")</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-ruler"></i> Unidad De Medida:
                            </label>
                            <select id="ddlUnidadM" class="form-control" disabled>
                                @foreach (var unidad in unidadmedida)
                                {
                                    <option value="@unidad.Id">@unidad.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Fila 3 - Fecha -->
                <div class="row">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-calendar"></i> Fecha:
                            </label>
                            <input type="date" id="dtpFechaViaje" name="dtpFechaViaje" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Fila 4 - Observaciones -->
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label class="control-label">
                                <i class="fa fa-comment-o"></i> Observaciones:
                            </label>
                            <textarea name="txtObservaciones" id="txtObservaciones" class="form-control" rows="4"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Botones -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" id="btnGuardar" onclick="SaveOrUpdateViajeLocal()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <button type="button" id="btnEliminar" onclick="EliminarViajeLocal()" class="btn btn-danger" style="display:none;">
                            <i class="fa fa-trash"></i> Eliminar
                        </button>
                        <a href="/Viajes/Locales" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de Viajes Locales -->
        <div class="container-fluid" style="padding: 0 15px 20px 15px;">
            <div class="panel panel-primary" style="background-color: #ffffff;">
                <div class="panel-heading" style="background-color: #337ab7; color: #ffffff;">
                    <i class="fa fa-table"></i> Listado de Viajes de Almacenes
                </div>
                <div class="panel-body table-responsive" style="background-color: #ffffff;">
                    <table id="tblViajesLocales" class="table table-bordered table-striped" style="width: 100%;">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th style="color: #333333;">Id</th>
                                <th style="color: #333333;">Folio</th>
                                <th style="color: #333333;">Origen</th>
                                <th style="color: #333333;">Transportista</th>
                                <th style="color: #333333;">Material</th>
                                <th style="color: #333333;">Vehículo</th>
                                <th style="color: #333333;">Cliente</th>
                                <th style="color: #333333;">Unidad Medida</th>
                                <th style="color: #333333;">Fecha</th>
                                <th style="color: #333333;">Observaciones</th>
                                <th style="color: #333333;">Estatus</th>
                                <th style="color: #333333;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</form>

<script src="@(Url.StaticFile("Scripts/Viajes/Locales.js"))"></script>

<script>
    var viajeLocalJson = JSON.parse('@Html.Raw((Newtonsoft.Json.JsonConvert.SerializeObject(ViajeLocal)))');
</script>