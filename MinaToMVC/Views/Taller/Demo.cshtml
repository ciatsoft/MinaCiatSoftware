
@{
    ViewBag.Title = "Demo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var fechaActual = DateTime.Now.ToString("dd-MM-yyyy");
}
<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />

<div class="content">
    <center><h1>Sistema de Reparacion de Vehiculos</h1></center>
    <div class="tabla-consultas-empleados">
        <div class="rectangulos" style="width: 100%;">
            <div class="row">
                <div class="col-lg-3">
                    <label>Fecha:</label>
                    <input class="form-control" type="text" id="fecha" value="@fechaActual" readonly />
                </div>
                <div class="col-lg-3">
                    <label>Vehiculo:</label>
                    <select class="form-control">
                        <option>Seleccione...</option>
                        <option>Camión de Volteo Kenworth T800</option>
                        <option>Camión Freightliner 114SD</option>
                        <option>Camión Mack Granite</option>
                        <option>Camión International WorkStar</option>
                    </select>
                </div>
                <div class="col-lg-3">
                    <label>Chofer:</label>
                    <select class="form-control">
                        <option>Seleccione...</option>
                        <option>Juan Pérez</option>
                        <option>Carlos Hernández</option>
                        <option>Miguel Ramírez</option>
                        <option>Luis Torres</option>
                    </select>
                </div>
                <div class="col-lg-3">
                    <label>Tipo de servicio:</label>
                    <select class="form-control">
                        <option>Seleccione...</option>
                        <option>Preventivo</option>
                        <option>Correctivo</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-3">
                    <label>Recibio:</label>
                    <input type="text" class="form-control" value="Ing. Roberto García" disabled>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12 d-flex justify-content-between">
                    <div>
                        <input id="btnGuardar" type="submit" value="Guardar" class="btn btn-success btn-lg-custom" />
                    </div>
                    <a href="/Taller/Demo" class="btn btn-custom-cancel btn-lg-custom">Cancelar</a>
                </div>
            </div>
        </div>
    </div>
    <div class="row" style="margin-top:20px;">
        <div class="col-md-12">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo de Servicio</th>
                            <th>Cantidad de Piezas Reemplazadas</th>
                            <th>Recibió</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>2026-02-11</td>
                            <td>Preventivo</td>
                            <td>4</td>
                            <td>Ing. Roberto García</td>
                            <td>
                                <button class="btn btn-primary btn-sm"
                                        data-toggle="modal"
                                        data-target="#modalAsignar">
                                    Asignar Piezas
                                </button>
                                <button class="btn btn-success btn-sm" onclick="LiberaraVehiculo()">
                                    Liberar Vehiculo
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="modalAsignar" tabindex="-1">    
    <div class="tabla-consultas-roll">
        <div class="rectangulos" style="width: 100%;">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Asignar Piezas</h4>
                </div>
                <div class="modal-body">

                    <div class="form-group">
                        <label>Nombre de la Pieza</label>
                        <input type="text" class="form-control" placeholder="Ej. Balatas delanteras">
                    </div>

                    <div class="form-group">
                        <label>Comentarios</label>
                        <textarea class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Acción</label>
                        <select class="form-control">
                            <option>Seleccione...</option>
                            <option>Cambio</option>
                            <option>Reparación</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Subir imágenes (máximo 3)</label>
                        <input type="file" id="imagenes" class="form-control" multiple accept="image/*">
                        <small class="text-muted">Solo imágenes. Máximo 3 archivos.</small>
                    </div>
                    TABLA DE PIEZAS YA REGISTRADAS
                    <hr>
                    <h5><strong>Piezas ya registradas</strong></h5>

                    <div class="table-responsive">
                        <table class="table table-bordered table-condensed table-striped">
                            <thead>
                                <tr>
                                    <th>Pieza</th>
                                    <th>Acción</th>
                                    <th>Comentarios</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Balatas delanteras</td>
                                    <td>Cambio</td>
                                    <td>Desgaste excesivo</td>
                                </tr>
                                <tr>
                                    <td>Filtro de aire</td>
                                    <td>Cambio</td>
                                    <td>Mantenimiento preventivo</td>
                                </tr>
                                <tr>
                                    <td>Bomba hidráulica</td>
                                    <td>Reparación</td>
                                    <td>Presentaba fuga leve</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success">Guardar</button>
                    <a href="/Taller/Demo" class="btn btn-custom-cancel btn-lg-custom">Cancelar</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- JAVASCRIPT -->
<script>
    // Colocar fecha de hoy automáticamente
    document.addEventListener("DOMContentLoaded", function () {
        var hoy = new Date().toISOString().split('T')[0];
        document.getElementById("fechaHoy").value = hoy;
    });

    // Validar máximo 3 imágenes
    document.getElementById("imagenes").addEventListener("change", function () {
        if (this.files.length > 3) {
            alert("Solo puedes subir máximo 3 imágenes.");
            this.value = "";
        }
    });
</script>
