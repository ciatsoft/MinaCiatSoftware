@{
    ViewBag.Title = "InventarioPiezasNoUtilizadas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled, .form-control[readonly] {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label, label, .form-label {
        color: #333333 !important;
        font-weight: bold;
    }

    /* Botón cancelar personalizado */
    .btn-custom-cancel {
        background-color: #d9534f !important;
        border-color: #d43f3a !important;
        color: #ffffff !important;
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

        .btn-custom-cancel:hover {
            background-color: #c9302c !important;
            border-color: #ac2925 !important;
            color: #ffffff !important;
            opacity: 0.9;
            text-decoration: none;
        }

    /* Botón custom clean */
    .btn-custom-clean {
        background-color: #5bc0de !important;
        border-color: #46b8da !important;
        color: #ffffff !important;
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

        .btn-custom-clean:hover {
            background-color: #31b0d5 !important;
            border-color: #269abc !important;
            color: #ffffff !important;
            opacity: 0.9;
            text-decoration: none;
        }

    /* Botones de reporte */
    #btnGenerarPDF, #btnGenerarExcel {
        background-color: #28a745 !important;
        color: white !important;
        border: none !important;
        padding: 8px 16px !important;
        border-radius: 4px !important;
        cursor: pointer !important;
        width: 180px !important;
        transition: all 0.3s ease !important;
    }

        #btnGenerarPDF:hover, #btnGenerarExcel:hover {
            background-color: #218838 !important;
            color: white !important;
            opacity: 0.9 !important;
        }

    /* Panel con fondo blanco */
    .panel, .panel-default, .panel-primary {
        background-color: #ffffff !important;
    }

    .panel-body {
        background-color: #ffffff !important;
        color: #333333 !important;
    }

    .panel-heading {
        background-color: #337ab7 !important;
        color: #ffffff !important;
    }

    /* Títulos */
    h1, h2, h3, h4, h5, h6 {
        color: #005c8a !important;
    }

    /* Enlaces */
    a {
        color: #337ab7 !important;
    }

        a:hover {
            color: #23527c !important;
        }

    /* Texto general */
    body, .content, .container-fluid {
        background-color: #f5f5f5 !important;
    }

    /* Alineación de botones */
    .align-items-end {
        align-items: flex-end;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin-right: -15px;
        margin-left: -15px;
    }

    .col-auto {
        flex: 0 0 auto;
        width: auto;
        max-width: 100%;
        padding-right: 15px;
        padding-left: 15px;
    }

    .mb-2 {
        margin-bottom: 0.5rem;
    }

    .mt-3 {
        margin-top: 1rem;
    }

    /* Tabla responsive */
    .table-responsive {
        overflow-x: auto;
        margin-bottom: 20px;
    }
</style>

<div class="container-fluid" style="padding: 20px 15px;">
    <!-- Panel Principal con fondo blanco -->
    <div class="panel panel-default" style="background-color: #ffffff;">
        <div class="panel-body" style="background-color: #ffffff; color: #333333;">
            <div class="row">
                <div class="col-md-12 text-center">
                    <h1 class="text-primary" style="color: #005c8a !important;">
                        <i class="fa fa-cube"></i> Inventario de Piezas No Reutilizables
                    </h1>
                </div>
            </div>

            <!-- Filtros -->
            <div class="row" style="margin-top: 20px; align-items: flex-end;">
                <div class="col-md-3 col-sm-6">
                    <div class="form-group">
                        <label class="control-label form-label" style="color: #333333; font-weight: bold;">
                            <i class="fa fa-calendar"></i> Fecha Inicio:
                        </label>
                        <input type="date" id="fechaInicio" name="fechaInicio" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="form-group">
                        <label class="control-label form-label" style="color: #333333; font-weight: bold;">
                            <i class="fa fa-calendar"></i> Fecha Fin:
                        </label>
                        <input type="date" id="fechaFin" name="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="col-md-6 col-sm-12">
                    <div class="form-group" style="margin-top: 24px;">
                        <button id="btnFiltrar" type="button" class="btn btn-primary">
                            <i class="fa fa-search"></i> Buscar
                        </button>
                        <a href="/Taller/InventarioPiezasNoUtilizadas" class="btn btn-danger" style="margin-left: 10px;">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Piezas Retiradas -->
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary" style="background-color: #ffffff;">
        <div class="panel-heading" style="background-color: #337ab7; color: #ffffff;">
            <i class="fa fa-table"></i> Listado de Piezas Retiradas
        </div>
        <div class="panel-body table-responsive" style="background-color: #ffffff;">
            <table id="tblPiezasRetiradas" class="table table-bordered table-striped" style="width: 100%;">
                <thead>
                    <tr style="background-color: #f5f5f5;">
                        <th style="color: #333333;">ID</th>
                        <th style="color: #333333;">Reparacion</th>
                        <th style="color: #333333;">Nombre</th>
                        <th style="color: #333333;">Categoria</th>
                        <th style="color: #333333;">Marca</th>
                        <th style="color: #333333;">Cantidad</th>
                        <th style="color: #333333;">Fecha</th>
                        <th style="color: #333333;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Botones de Reporte -->
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-default" style="background-color: #ffffff;">
        <div class="panel-body" style="background-color: #ffffff; color: #333333;">
            <div class="row">
                <div class="col-md-12">
                    <button id="btnGenerarPDF" class="btn btn-success" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; width: 180px;">
                        <i class="fa fa-file-pdf-o"></i> Generar Reporte PDF
                    </button>
                    <button id="btnGenerarExcel" class="btn btn-success" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; width: 180px; margin-left: 10px;">
                        <i class="fa fa-file-excel-o"></i> Generar Reporte Excel
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="@(Url.StaticFile("Scripts/Taller/InventarioPiezasNoReutilizables.js"))"></script>