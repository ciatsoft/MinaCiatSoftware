
@{
    ViewBag.Title = "InventarioPiezasReutilizables";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />

<div class="content">
    <br />
    <center><h1>Inventario de Piezas Reutilizables</h1></center>
    <br />
    <div class="row align-items-end">
        @* FILTRADO POR FECHA *@
        <div class="col-auto">
            <label for="fechaInicioLabel" class="form-label">Fecha:</label>
            <input type="date" id="fechaInicio" name="fechaInicio" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-auto">
            <label for="fechaFinLabel" class="form-label">Fecha:</label>
            <input type="date" id="fechaFin" name="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-auto">
            <input id="btnFiltrar" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
            <a href="/Taller/InventarioPiezasNoUtilizadas" class="btn btn-custom-cancel" style="margin-top: -30px; margin-left: 10px">Cancelar</a>
        </div>
    </div>
    <br />
    <table id="tblPiezasRetiradas" class="table table-bordered table-striped" style="width: 100%;"></table>
    <br />
    <div class="mb-2" style="text-align: left;">
        <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte PDF
        </button>
        <button id="btnGenerarExcel" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte Excel
        </button>
    </div>
</div>

<script src="@(Url.StaticFile("Scripts/Taller/InventarioPiezasReutilizables.js"))"></script>