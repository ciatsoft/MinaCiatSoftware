<div class="container-fluid" style="padding: 20px 15px;">
    <!-- Panel Principal con fondo blanco -->
    <div class="panel panel-default" style="background-color: #ffffff;">
        <div class="panel-body" style="background-color: #ffffff; color: #333333;">
            @using (Html.BeginForm("SaveOrUpdateReparacionVehiculos", "Taller", FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmReparacionVehiculos", @id = "frmReparacionVehiculos" }))
            {
                @Html.HiddenFor(x => x.Id, new { id = "id" })
                @Html.HiddenFor(x => x.Estatus, new { id = "estatus" })
                @Html.HiddenFor(x => x.CreatedDt, new { id = "createdDt", @Value = Model != null && Model.CreatedDt != null && Model.CreatedDt > DateTime.MinValue ? Model.CreatedDt.ToString("yyyy-MM-dd HH:mm:ss") : DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") })
                @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", @Value = Model != null && !string.IsNullOrEmpty(Model.CreatedBy) ? Model.CreatedBy : usuarioToken.UserName })
                @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", @Value = usuarioToken.UserName })
                @Html.HiddenFor(x => x.UpdatedDt, new { id = "updatedDt", @Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") })

                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important;">
                            <i class="fa fa-wrench"></i> Reparación de Vehículos
                        </h1>
                    </div>
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-calendar"></i> Fecha:
                            </label>
                            <input type="text" id="fecha" name="Fecha" class="form-control"
                                   readonly="readonly" required="required"
                                   value="@fechaFormateada" />
                        </div>
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-car"></i> Origen de Vehículo:
                            </label>
                            @Html.DropDownListFor(x => x.TipoVehiculo,
                                tipoVehiculoSelectList,
                                new { @class = "form-control", id = "ddlTiposVehiculos", @required = "required" })
                        </div>
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-truck"></i> Vehículo:
                            </label>
                            <select id="ddlVehiculo" name="IdVehiculo" class="form-control" required>
                                <option value="" disabled selected>Selecciona un Vehículo</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-user"></i> Chofer:
                            </label>
                            @Html.DropDownListFor(x => x.IdEmpleado,
                                trabajadoresSelectList,
                                new { @class = "form-control", id = "ddlEmpleados", @required = "required" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-gear"></i> Tipo de Servicio:
                            </label>
                            @Html.DropDownListFor(x => x.TipoServicio,
                                tipoServicioSelectList,
                                new { @class = "form-control", id = "ddlTipoServicio", @required = "required" })
                        </div>
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <div class="form-group">
                            <label class="control-label" style="color: #333333; font-weight: bold;">
                                <i class="fa fa-user-circle"></i> Recibió:
                            </label>
                            @Html.TextBoxFor(x => x.Recibio, new
                            {
                                @class = "form-control",
                                @type = "text",
                                id = "recibido",
                                @readonly = "readonly",
                                @Value = Model != null && !string.IsNullOrEmpty(Model.Recibio) ? Model.Recibio : usuarioToken.UserName,
                                @required = "required"
                            })
                        </div>
                    </div>
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-12 text-center">
                        <button type="submit" id="btnGuardar" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Taller/ReparacionVehiculos" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Tabla de Historial de Reparaciones -->
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary" style="background-color: #ffffff;">
        <div class="panel-heading" style="background-color: #337ab7; color: #ffffff;">
            <i class="fa fa-history"></i> Historial de Reparaciones
        </div>
        <div class="panel-body table-responsive" style="background-color: #ffffff;">
            <div class="row" style="margin-bottom: 15px; align-items: flex-end;">
                <div class="col-md-3 col-sm-6">
                    <div class="form-group">
                        <label class="control-label form-label" style="color: #333333; font-weight: bold;">
                            <i class="fa fa-calendar"></i> Fecha Inicio:
                        </label>
                        <input type="date" id="fechaInicio" name="fechaInicio" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="form-group">
                        <label class="control-label form-label" style="color: #333333; font-weight: bold;">
                            <i class="fa fa-calendar"></i> Fecha Fin:
                        </label>
                        <input type="date" id="fechaFin" name="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="col-md-6 col-sm-12">
                    <div class="form-group" style="margin-top: 24px;">
                        <button id="btnFiltrar" type="button" class="btn btn-primary">
                            <i class="fa fa-search"></i> Buscar
                        </button>
                        <a href="/Taller/ReparacionVehiculos" class="btn btn-danger" style="margin-left: 10px;">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>
            </div>
            <table id="tblReparacionVehiculos" class="table table-bordered table-striped" style="width: 100%;"> </table>
        </div>
    </div>
</div>

<!-- Tabla de Estatus y Asignación de Refacciones -->
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary" style="background-color: #ffffff;">
        <div class="panel-heading" style="background-color: #337ab7; color: #ffffff;">
            <i class="fa fa-cube"></i> Estatus y Asignación de Refacciones
        </div>
        <div class="panel-body table-responsive" style="background-color: #ffffff;">
            <table id="tblAllRegistersReparacionVehiculos" class="table table-bordered table-striped" style="width: 100%;"> </table>
        </div>
    </div>
</div>

<!-- Botones de Reporte -->
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-default" style="background-color: #ffffff;">
        <div class="panel-body" style="background-color: #ffffff; color: #333333;">
            <div class="row">
                <div class="col-md-12">
                    <button id="btnGenerarPDF" class="btn btn-success" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; width: 180px;">
                        <i class="fa fa-file-pdf-o"></i> Generar Reporte PDF
                    </button>
                    <button id="btnGenerarExcel" class="btn btn-success" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; width: 180px; margin-left: 10px;">
                        <i class="fa fa-file-excel-o"></i> Generar Reporte Excel
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Pasar datos del modelo a JavaScript
    var modeloEdicion = @Html.Raw(Json.Encode(Model));
    var esNuevoRegistro = @(esNuevoRegistro ? "true" : "false");

    $(document).ready(function() {
        if (esNuevoRegistro) {
            setTimeout(function() {
                if ($("#ddlTiposVehiculos").val() !== "") {
                    $("#ddlTiposVehiculos").val("");
                }
                if ($("#ddlTipoServicio").val() !== "") {
                    $("#ddlTipoServicio").val("");
                }
                if ($("#ddlEmpleados").val() !== "") {
                    $("#ddlEmpleados").val("");
                }
            }, 100);
        }
    });
</script>

<script src="@(Url.StaticFile("Scripts/Taller/ReparacionVehiculos.js"))"></script>