@model MinaTolEntidades.DtoTaller.ReparacionVehiculos
@{
    ViewBag.Title = "ReparacionVehiculos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var trabajadores = (List<MinaTolEntidades.DtoSucursales.DtoTrabajador>)ViewBag.Trabajadores;
    var tiposVehiculos = (List<string>)ViewBag.TiposVehiculos;
    var tiposServicio = (List<string>)ViewBag.TipoServicio;
    var esNuevoRegistro = ViewBag.EsNuevoRegistro ?? true;

    string fechaFormateada = "";
    if (Model != null && Model.Fecha != null && Model.Fecha > DateTime.MinValue)
    {
        fechaFormateada = Model.Fecha.ToString("yyyy-MM-dd HH:mm:ss");
    }
    else
    {
        fechaFormateada = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
    }

    var tipoVehiculoSelectList = new List<SelectListItem>();
    bool tieneTipoVehiculo = Model != null && Model.TipoVehiculo > 0;
    bool tieneTipoServicio = Model != null && Model.TipoServicio > 0;
    bool tieneEmpleado = Model != null && Model.IdEmpleado > 0;

    tipoVehiculoSelectList.Add(new SelectListItem
    {
        Value = "",
        Text = "Selecciona un Tipo de Vehiculo",
        Selected = !tieneTipoVehiculo,
        Disabled = true
    });

    foreach (var tipoVehiculo in tiposVehiculos)
    {
        var splitTipoVehiculos = tipoVehiculo.ToString().Split(':');
        tipoVehiculoSelectList.Add(new SelectListItem
        {
            Value = splitTipoVehiculos[0].Trim(),
            Text = splitTipoVehiculos[1].Trim(),
            Selected = tieneTipoVehiculo && Model.TipoVehiculo.ToString() == splitTipoVehiculos[0].Trim()
        });
    }

    var tipoServicioSelectList = new List<SelectListItem>();
    tipoServicioSelectList.Add(new SelectListItem
    {
        Value = "",
        Text = "Selecciona un Tipo de Servicio",
        Selected = !tieneTipoServicio,
        Disabled = true
    });

    foreach (var tipoServicio in tiposServicio)
    {
        var splitTipoServicio = tipoServicio.Split(':');
        tipoServicioSelectList.Add(new SelectListItem
        {
            Value = splitTipoServicio[0].Trim(),
            Text = splitTipoServicio[1].Trim(),
            Selected = tieneTipoServicio && Model.TipoServicio.ToString() == splitTipoServicio[0].Trim()
        });
    }

    var trabajadoresSelectList = new List<SelectListItem>();
    trabajadoresSelectList.Add(new SelectListItem
    {
        Value = "",
        Text = "Selecciona un Chofer",
        Selected = !tieneEmpleado,
        Disabled = true
    });

    foreach (var i in trabajadores)
    {
        trabajadoresSelectList.Add(new SelectListItem
        {
            Value = i.Id.ToString(),
            Text = i.Nombre,
            Selected = tieneEmpleado && Model.IdEmpleado == i.Id
        });
    }
}

