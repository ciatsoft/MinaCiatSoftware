@model MinaTolEntidades.DtoTaller.ReparacionVehiculos
@{
    ViewBag.Title = "ResumenReparacionVehiculo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />

<!-- Pasar datos del servidor al cliente -->
<script type="text/javascript">
    // Datos del modelo
    var modeloReparacion = @Html.Raw(Json.Encode(Model));

    // Datos de configuración desde ViewBag
    var configuracion = {
        tipoVehiculos: @Html.Raw(Json.Encode(ViewBag.TiposVehiculos)),
        tipoServicio: @Html.Raw(Json.Encode(ViewBag.TipoServicio))
    };
</script>

<div class="content">
    <div class="row">
        <div class="col-lg-6">
            <a href="/Taller/ReparacionVehiculos" class="btn btn-custom-cancel btn-lg-custom">Regresar</a>
        </div>
    </div>
    <center><h1>Resumen de Reparacion</h1></center>
    <br />
    <div class="tabla-consultas-empleados">
        <div class="rectangulos" style="width: 100%;">
            <div class="row">
                <div class="col-lg-3">
                    <label>Id Reparación</label>
                    @Html.TextBoxFor(x => x.Id, new { id = "id", @class = "form-control", @readonly = "readonly" })
                </div>
                <div class="col-lg-3">
                    <label>Tipo de Vehiculo</label>
                    @Html.HiddenFor(x => x.TipoVehiculo, new { id = "tipoVehiculo" })
                    <input type="text" id="tipoVehiculoDesc" class="form-control" readonly style="background-color: #f0f0f0;" />
                </div>
                <div class="col-lg-3">
                    <label>Vehículo</label>
                    @Html.HiddenFor(x => x.IdVehiculo, new { id = "vehiculo" })
                    <input type="text" id="vehiculoDesc" class="form-control" readonly style="background-color: #f0f0f0;" />
                </div>
                <div class="col-lg-3">
                    <label>Tipo Servicio</label>
                    @Html.HiddenFor(x => x.TipoServicio, new { id = "tipoServicio" })
                    <input type="text" id="tipoServicioDesc" class="form-control" readonly style="background-color: #f0f0f0;" />
                </div>
                @Html.HiddenFor(x => x.Estado, new { id = "estado" })
            </div>
            <div class="row">
                <div class="col-lg-10">
                    @if (Model.Estado == 1 || Model.Estado == 2)
                    {
                        <input type="button" value="Retirar Piezas"
                               class="btn btn-custom-cancel btn-lg-custom"
                               onclick="ModalRetirarPiezas(@Model.Id, @Model.TipoVehiculo, @Model.IdVehiculo)" />

                        <input style="margin-left:96px;" type="button"
                               value="Asignar Piezas"
                               class="btn btn-success btn-lg-custom"
                               onclick="ModalAsignarPiezas(0, @Model.Id, @Model.TipoVehiculo, @Model.IdVehiculo)" />
                    }
                    else if (Model.Estado == 3 || Model.Estado == 4)
                    {
                        <div class="alert alert-warning" style="display: inline-block; margin: 0; padding: 8px 15px; background-color: #fff3cd; border-left: 4px solid #ffc107; border-radius: 4px;">
                            <strong style="color: #856404;">⚠️ Servicio Terminado / Liberado</strong>
                            <span style="color: #856404; font-size: 12px; display: block;">No se pueden retirar o asignar piezas</span>
                        </div>
                    }
                </div>
                <div class="col-lg-2" style="align-items:end;">
                    @if (Model.Estado == 1)
                    {
                        <input style="align-items: end;" type="button"
                               value="Comenzar Reparacion"
                               class="btn btn-success btn-lg-custom"
                               onclick="ActualizarEstado(@Model.Id, 2)" />
                    }
                    else if (Model.Estado == 2)
                    {
                        <input style="align-items: end;" type="button"
                               value="Reparacion Terminada"
                               class="btn btn-custom-clean"
                               onclick="ActualizarEstado(@Model.Id, 3)" />
                    }
                    else if (Model.Estado == 3 || Model.Estado == 4)
                    {
                        <div class="alert alert-info" style="margin: 0; padding: 8px 12px; background-color: #d1ecf1; border-left: 4px solid #17a2b8; border-radius: 4px;">
                            <strong style="color: #0c5460;">📋 Reparacion @(Model.Estado == 3 ? "Terminada" : "Liberada")</strong>
                            <span style="color: #0c5460; font-size: 12px; display: block;">
                                @(Model.Estado == 3 ? "Lista para liberar vehiculo" : "Vehiculo liberado")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <center><h1>Piezas Retiradas</h1></center>
    <br />
    <table id="tblPiezasRetiradas" class="table table-bordered table-striped" style="width: 100%;"></table>
    <br />
    <center><h1>Piezas Instaladas</h1></center>
    <br />
    <table id="tblPiezasAsignadas" class="table table-bordered table-striped" style="width: 100%;"></table>
    <br />
    <div class="mb-2" style="text-align: left;">
        <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte PDF
        </button>
        <button id="btnGenerarExcel" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte Excel
        </button>
    </div>
</div>
<script src="@(Url.StaticFile("Scripts/Taller/ResumenReparacionVehiculo.js"))"></script>