@model MinaTolEntidades.DtoVentaPublicoGeneral.Deducciones
@{
    ViewBag.Title = "PartialDeducciones";
    var gastos = (List<MinaTolEntidades.DtoCatalogos.DtoTipoGasto>)ViewBag.Gastos;
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now;
    var fechaActualStr = fechaActual.ToString("yyyy-MM-ddTHH:mm:ss");
    var fechaSoloStr = fechaActual.ToString("yyyy-MM-dd");
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />

@using (Html.BeginForm("SaveOrUpdateDeducciones", "VentaPublicoGeneral", FormMethod.Post, new { enctype = "multipart/form-data", @id = "frmDeducciones" }))
{
    @Html.HiddenFor(x => x.Id, new { @id = "id" })
    @Html.HiddenFor(x => x.UsuarioName, new { @id = "user" })
    @Html.HiddenFor(x => x.Estatus)
    @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", Value = usuarioToken.UserName })
    @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", Value = usuarioToken.UserName })
    @Html.HiddenFor(x => x.NombreGasto, new { @id = "nombreGasto" })

    @* Campos de fecha como strings para que el modelo los reciba correctamente *@
    <input type="hidden" id="CreatedDt" name="CreatedDt" value="@fechaActual" />
    <input type="hidden" id="UpdatedDt" name="UpdatedDt" value="@fechaActual" />

    <div class="content">
        <br />
        <div class="tabla-consultas-roll">
            <div class="rectangulos" style="width: 100%;">
                <h2>Crear Deducción</h2>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-lg-4">
                        <label>Tipo de Gasto:</label>
                        @Html.DropDownListFor(x => x.TipoGastoId,
                            new SelectList(gastos, "Id", "Nombre", Model.TipoGastoId),
                            "Seleccione un Tipo De Gasto",
                            new { @class = "form-control", @id = "ddlTipoGasto" })
                    </div>

                    <div class="col-lg-4">
                        <label>Descripción:</label>
                        @Html.TextBoxFor(x => x.Descripcion, new { @class = "form-control", @id = "descripcion" })
                    </div>

                    <div class="col-lg-4">
                        <label>Monto:</label>
                        @Html.TextBoxFor(x => x.Monto, new
                        {
                            @class = "form-control",
                            @id = "monto",
                            @type = "number",
                            @step = "0.01",
                            @min = "0"
                        })
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4">
                        <label>Usuario:</label>
                        <input type="text" class="form-control" value="@usuarioToken.UserName" readonly />
                    </div>
                    <div class="col-lg-4">
                        <label>Fecha:</label>
                        <input type="text" class="form-control" id="fecha" name="Fecha" value="@fechaSoloStr" readonly />
                    </div>
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-12">
                        <input type="button" value="Guardar" onclick="SaveOrUpdateDeducciones()" class="btn btn-success" />
                        <a href="/VentaPublicoGeneral/Index" class="btn btn-custom-cancel">Cancelar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    $(document).ready(function () {
        $("#user").val('@usuarioToken.UserName');

        $("#ddlTipoGasto").change(function () {
            const selectedText = $("#ddlTipoGasto option:selected").text();
            const selectedValue = $(this).val();
            $("#nombreGasto").val(selectedValue ? selectedText : "");
        });
    });

    function SaveOrUpdateDeducciones() {
        if ($("#frmDeducciones").valid()) {
            const isUpdating = $("#id").val() && $("#id").val() != 0;
            const currentUser = $("#user").val();

            // Obtener los valores de los hidden inputs
            var createdDtValue = $("#CreatedDt").val();
            var updatedDtValue = $("#UpdatedDt").val();

            const parametro = {
                Id: parseInt($("#id").val()) || 0,
                TipoGastoId: parseInt($("#ddlTipoGasto").val()) || 0,
                NombreGasto: $("#nombreGasto").val() || "",
                Descripcion: $("#descripcion").val() || "",
                Monto: parseFloat($("#monto").val()) || 0,
                UsuarioName: currentUser,
                Fecha: $("#fecha").val(),
                CreatedBy: currentUser,
                CreatedDt: $("#fecha").val(),
                UpdatedBy: currentUser,
                UpdatedDt: $("#fecha").val(),
                Estatus: $("#Estatus").val() === "true" || $("#Estatus").val() === "True" || true,
                Corte_Id: null
            };

            // Verificar en consola que los valores son correctos
            console.log("Datos a enviar:", parametro);

            Swal.fire({
                title: isUpdating ? '¿Desea actualizar el registro?' : '¿Desea guardar el nuevo registro?',
                html: `
                    <strong>Tipo de Gasto:</strong> ${$("#ddlTipoGasto option:selected").text()}<br/>
                    <strong>Nombre del Gasto:</strong> ${parametro.NombreGasto}<br/>
                    <strong>Descripción:</strong> ${parametro.Descripcion}<br/>
                    <strong>Monto:</strong> $${parametro.Monto.toFixed(2)}<br/>
                    <strong>Usuario:</strong> ${parametro.UsuarioName}<br/>
                    <strong>Fecha:</strong> ${parametro.Fecha}<br/>
                `,
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: isUpdating ? 'Actualizar' : 'Guardar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    PostMVC("/VentaPublicoGeneral/SaveOrUpdateDeducciones", parametro, function (success, response) {
                        if (success) {
                            Swal.fire('Éxito', isUpdating ? 'Datos actualizados correctamente.' : 'Datos guardados exitosamente.', 'success')
                                .then(() => window.location.href = '/VentaPublicoGeneral/Index');
                        } else {
                            Swal.fire('Error', 'Error al guardar los datos: ' + (response.ErrorMessage || JSON.stringify(response)), 'error');
                        }
                    });
                }
            });
        } else {
            Swal.fire('Advertencia', 'Por favor, complete todos los campos obligatorios.', 'warning');
        }
    }
</script>