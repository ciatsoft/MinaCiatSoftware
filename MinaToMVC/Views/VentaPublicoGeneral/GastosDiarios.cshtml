
@{
    ViewBag.Title = "GastosDiarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />

<div class="content">
    <div class="rectangulos" style="width: 100%;">
        <center><h1>Historial de Gastos/Deducciones</h1></center>
        <div class="row align-items-end">
            @* FILTRADO POR FECHA *@
            <div class="col-auto">
                <label for="fechaFiltro" class="form-label">Fecha:</label>
                <input type="date" id="fechaDeducciones" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <input type="hidden" id="userNameDeducciones" name="userName" class="form-control" value="@ViewBag.UserToken.UserName" readonly />
                <input type="hidden" id="userIdDeducciones" name="userId" class="form-control" value="@ViewBag.UserToken.UserID" readonly />
            </div>

            <div class="col-auto">
                <input id="btnDeducciones" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
                <a href="/VentaPublicoGeneral/GastosDiarios" class="btn btn-custom-cancel" style="margin-top: -30px; margin-left: 10px">Cancelar</a>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <table class="table table-bordered table-striped" id="tableDeducciones" style="width: 100%;"></table>
        </div>
    </div>
    <div class="mb-2" style="text-align: left;">
        <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte PDF
        </button>
        <button id="btnGenerarExcel" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte Excel
        </button>
    </div>
    <br />
    <div class="rectangulos" style="width: 100%;">
        <center><h1>Historial de Gastos/Deducciones por Rango de Fechas</h1></center>
        <div class="row align-items-end">
            @* FILTRADO POR FECHA *@
            <div class="col-auto">
                <label for="fechaFiltroRango1" class="form-label">Fecha Inicio:</label>
                <input type="date" id="fechaDeduccionesInicio" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label for="fechaFiltroRango2" class="form-label">Fecha Fin:</label>
                <input type="date" id="fechaDeduccionesFin" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <input type="hidden" id="userNameDeduccionesRango1" name="userName" class="form-control" value="@ViewBag.UserToken.UserName" readonly />
                <input type="hidden" id="userIdDeduccionesRango1" name="userId" class="form-control" value="@ViewBag.UserToken.UserID" readonly />
            </div>

            <div class="col-auto">
                <input id="btnDeduccionesRangoFecha" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
                <a href="/VentaPublicoGeneral/GastosDiarios" class="btn btn-custom-cancel" style="margin-top: -30px; margin-left: 10px">Cancelar</a>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <table class="table table-bordered table-striped" id="tableDeduccionesRangoFecha" style="width: 100%;"></table>
        </div>
    </div>
    <div class="mb-2" style="text-align: left;">
        <button id="btnGenerarPDFRangoFecha" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte PDF
        </button>
        <button id="btnGenerarExcelRangoFecha" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte Excel
        </button>
    </div>
    <br />
    <div class="rectangulos" style="width: 100%;">
        <center><h1>Historial de Gastos/Deducciones por Tipo</h1></center>
        <div class="row align-items-end">
            @* FILTRADO POR FECHA *@
            <div class="col-auto">
                <label for="fechaFiltro" class="form-label">Fecha:</label>
                <input type="date" id="fechaDeduccionesTipo" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <input type="hidden" id="userNameDeduccionesTipo" name="userName" class="form-control" value="@ViewBag.UserToken.UserName" readonly />
                <input type="hidden" id="userIdDeduccionesTipo" name="userId" class="form-control" value="@ViewBag.UserToken.UserID" readonly />
            </div>

            <div class="col-auto">
                <input id="btnDeduccionesTipo" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
                <a href="/VentaPublicoGeneral/GastosDiarios" class="btn btn-custom-cancel" style="margin-top: -30px; margin-left: 10px">Cancelar</a>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <table class="table table-bordered table-striped" id="tableDeduccionesTipo" style="width: 100%;"></table>
        </div>
    </div>
    <div class="mb-2" style="text-align: left;">
        <button id="btnGenerarPDFTipoGasto" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte PDF
        </button>
        <button id="btnGenerarExcelTipoGasto" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte Excel
        </button>
    </div>
</div>

<script src="@(Url.StaticFile("Scripts/VentaPublicoGeneral/GastosDiarios.js"))"></script>