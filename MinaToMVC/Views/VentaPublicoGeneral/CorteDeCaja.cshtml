
@{
    ViewBag.Title = "CorteDeCaja";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>

<style>
    .titulo-pequeno {
        font-size: 12px;
    }
</style>

<!-- En el head de tu HTML -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<div class="content">
    <br>
    <center><h1>Reporte Diario</h1></center>
    <div class="tabla-consultas-roll">
        <div class="rectangulos" style="width: 100%;">
            <div class="row align-items-end">
                @* FILTRADO POR FECHA *@

                <div class="col-auto">
                    <label for="fechaFiltro" class="form-label">Fecha:</label>
                    <input type="date" id="fechaFiltro" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-auto">
                    <label for="userName" class="form-label">Encargado:</label>
                    <input type="text" id="userName" name="userName" class="form-control" value="@ViewBag.UserToken.UserName" readonly />
                    <input type="hidden" id="userId" name="userId" class="form-control" value="@ViewBag.UserToken.UserID" readonly />
                </div>

                <div class="col-auto">
                    <input id="btnFiltrar" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
                </div>
            </div>
        </div>
        <br />
        <h2><label for="fechaFiltro" class="form-label">Ventas Aprobadas:</label></h2>
        <table id="tblVentas_Aprobadas" class="table table-bordered table-striped" style="width: 100%;"></table>
        <br />
        <h2><label for="fechaFiltro" class="form-label">Ventas Realizadas:</label></h2>
        <table id="tblVentas_Realizadas" class="table table-bordered table-striped" style="width: 100%;"></table>
        <br />
        <h2><label for="fechaFiltro" class="form-label">En Caja:</label></h2>
        <table id="tblEn_Caja" class="table table-bordered table-striped" style="width: 100%;"></table>
        <br />
        <h2><label for="fechaFiltro" class="form-label">Deducciones del Dia:</label></h2>
        <table id="tblDeducciones" class="table table-bordered table-striped" style="width: 100%;"></table>
        <br />
        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 20px;">
            <!-- Lado Izquierdo - Caja Chica -->
            <div style="flex: 1; margin-right: 10px;">
                <h2><label for="fechaFiltro" class="form-label">Caja Chica:</label></h2>
                <table id="tblCajaChica" class="table table-bordered table-striped" style="width: 100%;"></table>
            </div>

            <!-- Lado Derecho - Utilidad del Día -->
            <div style="flex: 1; margin-left: 10px;">
                <h2 style="text-align: right;"><label for="fechaFiltro" class="form-label">Utilidad del Día</label></h2>
                <div class="mb-2" style="text-align: right;">
                    <label for="ingreso" class="form-label" style="display: inline-block; margin-right: 5px;">Ingresos: $</label>
                    <input class="form-control" type="text" name="ingreso" id="ingreso" value="0" style="display: inline-block; width: auto; text-align: right;" disabled />
                </div>
                <div class="mb-2" style="text-align: right;">
                    <label for="caja" class="form-label" style="display: inline-block; margin-right: 5px;">Caja: $</label>
                    <input class="form-control" type="text" name="caja" id="caja" value="0" style="display: inline-block; width: auto; text-align: right;" disabled />
                </div>
                <div class="mb-2" style="text-align: right;">
                    <label for="deduccion" class="form-label" style="display: inline-block; margin-right: 5px;">Deducciones: $</label>
                    <input class="form-control" type="text" name="deduccion" id="deduccion" value="0" style="display: inline-block; width: auto; text-align: right;" disabled />
                </div>
                <div class="mb-2" style="text-align: right;">
                    <label for="total" class="form-label" style="display: inline-block; margin-right: 5px;">Total: $</label>
                    <input class="form-control" type="text" name="total" id="total" value="0" style="display: inline-block; width: auto; text-align: right;" disabled />
                </div>
                <div class="mb-2" style="text-align: right;">
                    <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
                        Generar Reporte PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="@(Url.StaticFile("Scripts/VentaPublicoGeneral/CorteDeCaja.js"))"></script>
