
@{
    ViewBag.Title = "VentaPorPlanta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />

<div class="content">
    <div class="rectangulos" style="width: 100%;">
        <center><h1>Venta por Fecha para Planta Individual</h1></center>
        <div class="row align-items-end">
            @* FILTRADO POR FECHA *@
            <div class="col-auto">
                <label for="fechaFiltro" class="form-label">Fecha:</label>
                <input type="date" id="fechaFiltro" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <input id="btnFiltrar" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
                <a href="/VentaPublicoGeneral/VentaPorPlanta" class="btn btn-custom-cancel" style="margin-top: -30px; margin-left: 10px">Cancelar</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <table class="table table-bordered table-striped" id="tableVentaPlanta" style="width: 100%;"></table>
        </div>
    </div>

    <div class="rectangulos" style="width: 100%;">
        <center><h1>Venta por Planta por Fecha de Rango</h1></center>
        <div class="row align-items-end">
            @* FILTRADO POR FECHA *@
            <div class="col-auto">
                <label for="fechaFiltro2" class="form-label">Fecha:</label>
                <input type="date" id="fechaFiltro2" name="fechaFiltro2" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <label for="fechaFiltro3" class="form-label">Fecha:</label>
                <input type="date" id="fechaFiltro3" name="fechaFiltro3" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <input id="btnFiltrar2" type="button" value="Buscar" class="btn btn-custom-clean" style="margin-top: -30px" />
                <a href="/VentaPublicoGeneral/VentaPorPlanta" class="btn btn-custom-cancel" style="margin-top: -30px; margin-left: 10px">Cancelar</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <table class="table table-bordered table-striped" id="tableVentaPlanta2" style="width: 100%;"></table>
        </div>
    </div>
    <div class="mb-2" style="text-align: right;">
        <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte PDF
        </button>
        <button id="btnGenerarExcel" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 150px;">
            Generar Reporte Excel
        </button>
    </div>
</div>
<div style="height: 300px;">
</div>
<script src="@(Url.StaticFile("Scripts/VentaPublicoGeneral/VentaPlanta.js"))"></script>
<script>
    window.addEventListener('DOMContentLoaded', () => {
        const now = new Date();
        const fechaInput = document.getElementById('fecha');

        // Formatea la fecha a YYYY-MM-DD
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');

        const formattedDate = `${year}-${month}-${day}`;
        fechaInput.value = formattedDate;
    });
</script>
