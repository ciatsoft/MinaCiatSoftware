@model MinaTolEntidades.DtoVentaPublicoGeneral.Prepago
@{
    ViewBag.Title = "PartialPrepago";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>

@using (Html.BeginForm("SaveOrUpdatePrepago", "VentaPublicoGeneral", FormMethod.Post, new { enctype = "multipart/form-data", @id = "frmPrepago" }))
{
    @Html.HiddenFor(x => x.Id, new { @id = "id" })
    @Html.HiddenFor(x => x.Estatus)
    @Html.HiddenFor(x => x.CreatedBy, new { @Value = usuarioToken.UserName, @id = "createdByModal" })
    @Html.HiddenFor(x => x.UpdatedBy, new { @Value = usuarioToken.UserName, @id = "updatedByModal" })
    @Html.HiddenFor(x => x.CreatedDt, new { @Value = fechaActual, @id = "createdDtModal" })
    @Html.HiddenFor(x => x.UpdatedDt, new { @Value = fechaActual, @id = "updatedDtModal" })

    <div class="content">
        <br />
        <div class="tabla-consultas-roll">
            <div class="rectangulos" style="width: 100%;">
                <h2>Crear Valera de Prepago</h2>

                <!-- Sección de campos de auditoría visibles -->
                <div class="row" style="margin-top: 20px;">
                    <div class="col-lg-4">
                        <label>Folio:</label>
                        @Html.TextBoxFor(x => x.Folio, new { @class = "form-control no-select", @type = "number", id = "folioModal", @readonly = "readonly" })
                    </div>
                </div>

                <!-- Campos del formulario -->
                <div class="row" style="margin-top: 20px;">
                    <!-- Primera fila -->
                    <div class="col-lg-4">
                        <label>Tipo de Material:</label>
                        @{
                            var materialesList = new SelectList(ViewBag.Materiales, "Id", "NombreTipoMaterial");
                            var materialesWithDefault = new List<SelectListItem>();
                            materialesWithDefault.Add(new SelectListItem { Text = "Selecciona un material", Value = ""});
                            materialesWithDefault.AddRange(materialesList.Select(m => new SelectListItem { Text = m.Text, Value = m.Value }));
                        }

                        @Html.DropDownListFor(x => x.IdMaterial,
                            materialesWithDefault,
                            new { @class = "form-control", id = "idMaterial" })
                    </div>

                    <div class="col-lg-4">
                        <label>Cantidad de M3 Totales:</label>
                        @Html.TextBoxFor(x => x.CantidadM3, new { @class = "form-control no-select", @type = "number", id = "cantidadM3" })
                    </div>

                    <div class="col-lg-4">
                        <label>Precio Por Unidad:</label>
                        @Html.TextBoxFor(x => x.PrecioUnidad, new { @class = "form-control no-select", @type = "number", id = "precioUnidad", @readonly = "readonly" })
                    </div>
                </div>

                <div class="row">
                    <!-- Segunda fila -->
                    <div class="col-lg-4">
                        <label>Total a Pagar:</label>
                        @Html.TextBoxFor(x => x.ImporteVenta, new { @class = "form-control", @readonly = "readonly", @id = "importeVenta" })
                    </div>

                    <div class="col-lg-4">
                        <label>RFID:</label>
                        @Html.TextBoxFor(x => x.RFID, new { @class = "form-control no-select", id = "rfidModal" })
                    </div>

                    <div class="col-lg-4">
                        <label>Cliente:</label>
                        @Html.TextBoxFor(x => x.NombreCliente, new { @class = "form-control no-select", id = "nombreClienteModal", @readonly = "readonly" })
                        @Html.HiddenFor(x => x.IdCliente, new { id = "idCliente" })
                    </div>
                </div>

                <div class="row">
                    <!-- Tercera fila -->
                    <div class="col-lg-4">
                        <label>Cantidad de Vales:</label>
                        @Html.TextBoxFor(x => x.CantidadVales, new { @class = "form-control no-select", @type = "number", id = "cantidadVales" })
                    </div>

                    <div class="col-lg-4">
                        <label>Fecha:</label>
                        @Html.TextBoxFor(x => x.Fecha, new { @class = "form-control no-select", id = "fechaModal", @readonly = "readonly" })
                    </div>

                    <div class="col-lg-4">
                        <label>Usuario:</label>
                        <input type="text" class="form-control" value="@usuarioToken.UserName" readonly />
                    </div>
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-12">
                        <input type="button" value="Guardar" id="btnGuardarPrepago" class="btn btn-success" />
                        <a href="/VentaPublicoGeneral/Index" class="btn btn-custom-cancel">Cancelar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
$(document).ready(function() {
    var precioMaterial = 0;

    // 1. Establecer fecha actual al cargar
    function establecerFechaActual() {
        const now = new Date();
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        const formattedDate = `${year}-${month}-${day}`;
        $('#fechaModal').val(formattedDate);
    }
    establecerFechaActual();

    // 2. Configuración de eventos RFID
    function configurarEventosRFID() {
        var rfidTimeout;

        $("#rfidModal").on('input', function() {
            const valorRFID = $(this).val().trim();

            clearTimeout(rfidTimeout);

            if(valorRFID.length >= 8) {
                rfidTimeout = setTimeout(function() {
                    buscarClientePorRFID(valorRFID);
                }, 800);
            }
        });

        $("#rfidModal").on('change', function() {
            const valorRFID = $(this).val().trim();
            if(valorRFID.length >= 8) {
                buscarClientePorRFID(valorRFID);
            }
        });
    }
    configurarEventosRFID();

    // Función para buscar cliente por RFID
    function buscarClientePorRFID(rfid) {

        const $idCliente = $('#idCliente');
        const $nombreCliente = $('#nombreClienteModal');
        const $rfidInput = $('#rfidModal');

        $.ajax({
            url: '@Url.Action("SearchClienteByRFID", "VentaPublicoGeneral")',
            type: 'GET',
            data: { rfid: rfid },
            dataType: 'json',
            success: function(respuesta) {
                console.log("Respuesta del servidor (SearchClienteByRFID):", respuesta);

                if (respuesta.IsSuccess && respuesta.Response) {
                    const cliente = respuesta.Response;
                    $idCliente.val(cliente.id || '');
                    $nombreCliente.val(cliente.nombre || '');
                } else {
                    $idCliente.val('');
                    $nombreCliente.val('');
                    console.warn("No se encontró cliente con RFID:", rfid);
                    Swal.fire({
                        icon: 'info',
                        title: 'Aviso',
                        text: 'No se encontró un cliente con ese RFID',
                        timer: 3000
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error("Error en la solicitud AJAX:", {
                    status: status,
                    error: error,
                    responseText: xhr.responseText
                });
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Error al buscar el cliente. Intente nuevamente.',
                    timer: 3000
                });
            }
        });
    }

    // Resto del código original
    $('#ddlMateriales').change(function() {
        $('#idMaterial').val($(this).val());
        ObtenerPrecioMaterial();
    });

    var initialValue = $('#idMaterial').val();
    if (initialValue) {
        $('#ddlMateriales').val(initialValue);
    }

    $("#cantidadM3").on("input", function() {
        ObtenerPrecioMaterial();
    });

    $("#idMaterial").on("change", function() {
        ObtenerPrecioMaterial();
    });

    function ObtenerPrecioMaterial() {
        var materialSeleccionado = $("#idMaterial").val();
        var cantidadM3 = parseFloat($("#cantidadM3").val()) || 0;

        if (!materialSeleccionado) {
            console.warn("No hay material seleccionado aún.");
            $("#precioMaterial").val(0);
            $("#precioUnidad").val(0);
            actualizarTotal();
            return;
        }

        GetMVC("/VentaPublicoGeneral/GetPreciosBymaterialId/" + materialSeleccionado, function(r) {
            if (r.IsSuccess && Array.isArray(r.Response) && r.Response.length > 0) {
                const preciosActivos = r.Response.filter(item => item.esPrecioActivo === true);

                if (preciosActivos.length > 0) {
                    var datos = preciosActivos[0];
                    var cantidadMenudeo = parseFloat(datos.cantidad) || 0;

                    precioMaterial = (cantidadM3 > cantidadMenudeo)
                        ? parseFloat(datos.precioMayoreo) || 0
                        : parseFloat(datos.precioMenudeo) || 0;

                    $("#precioMaterial").val(precioMaterial);
                    $("#precioUnidad").val(precioMaterial);
                } else {
                    console.warn("No hay precios activos.");
                    precioMaterial = 0;
                    $("#precioMaterial").val(0);
                    $("#precioUnidad").val(0);
                }

                actualizarTotal();
            } else {
                console.error("Error al obtener precios:", r);
                precioMaterial = 0;
                $("#precioMaterial").val(0);
                $("#precioUnidad").val(0);
                actualizarTotal();
            }
        });
    }

    function actualizarTotal() {
        var cantidad = parseFloat($("#cantidadM3").val()) || 0;
        var total = parseFloat(precioMaterial) * cantidad;

        if (!isNaN(total)) {
            $("#importeVenta").val(total.toFixed(2));
        } else {
            $("#importeVenta").val("");
        }
    }

    $("#btnGuardarPrepago").click(async function() {
        // Validar cantidad de vales
        var cantidadVales = parseInt($("#cantidadVales").val());
        if (isNaN(cantidadVales) || cantidadVales <= 0) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Debe ingresar una cantidad válida de vales (mayor a 0)',
                confirmButtonText: 'Aceptar'
            });
            return;
        }

        // Obtener el folio base
        var folioBase = $("#folioModal").val();
        var numeroFolio = parseInt(folioBase) || 0;

        // Crear array para guardar todos los vales
        var valesParaGuardar = [];

        for (var i = 0; i < cantidadVales; i++) {
            var vale = {
                Id: $("#id").val(),
                Estatus: $("#Estatus").val(),
                CreatedBy: $("#createdByModal").val(),
                UpdatedBy: $("#updatedByModal").val(),
                CreatedDt: $("#createdDtModal").val(),
                UpdatedDt: $("#updatedDtModal").val(),
                Folio: (numeroFolio + i).toString().padStart(5, '0'),
                IdMaterial: $("#idMaterial").val(),
                CantidadM3: $("#cantidadM3").val(),
                M3Faltantes: $("#cantidadM3").val(),
                PrecioUnidad: $("#precioUnidad").val(),
                ImporteVenta: $("#importeVenta").val(),
                RFID: $("#rfidModal").val(),
                IdCliente: $("#idCliente").val(),
                NombreCliente: $("#nombreClienteModal").val(),
                CantidadVales: cantidadVales.toString(),
                Fecha: $("#fechaModal").val(),
                NoVale: (i + 1),
                NombreMaterial: $("#idMaterial option:selected").text(),
                UserName: "@usuarioToken.UserName"
            };
            valesParaGuardar.push(vale);
        }

        // Deshabilitar botón
        $("#btnGuardarPrepago").prop("disabled", true).text("Guardando...");

        try {
            // Enviar TODOS los vales en un solo arreglo
            const response = await enviarVales(valesParaGuardar);

            if (!response.success) {
                throw new Error(response.message || "Error al guardar vales");
            }

            // Si se guardó correctamente, generar el PDF
            generarPDF(valesParaGuardar);

            // Redirigir después de generar el PDF
            window.location.href = '/VentaPublicoGeneral/Index';

        } catch (error) {
            console.error("Error:", error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Error: ' + error.message,
                confirmButtonText: 'Aceptar'
            });
        } finally {
            $("#btnGuardarPrepago").prop("disabled", false).text("Guardar");
        }
    });

    // Función para enviar todos los vales en un arreglo
    function enviarVales(vales) {
        return new Promise((resolve, reject) => {
            $.ajax({
                url: '/VentaPublicoGeneral/SaveOrUpdatePrepagos',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ prepagos: vales }),
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Éxito',
                            text: response.message,
                            confirmButtonText: 'Aceptar'
                        }).then(() => {
                            window.location.href = '/VentaPublicoGeneral/Index';
                        });
                        resolve(response);
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message,
                            confirmButtonText: 'Aceptar'
                        });
                        reject(response);
                    }
                },
                error: function (xhr) {
                    var errorMsg = xhr.responseText || "Error en la solicitud AJAX";
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: "Error: " + errorMsg,
                        confirmButtonText: 'Aceptar'
                    });
                    reject({
                        success: false,
                        message: errorMsg
                    });
                }
            });
        });
    }

    function generarPDF(vales) {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({
            orientation: 'portrait',
            unit: 'mm',
            format: 'a4'
        });

        // Configuración de estilo
        const primaryColor = [128, 128, 128]; // Gris
        const secondaryColor = [76, 175, 80]; // Verde

        // Margen superior e izquierdo
        const marginLeft = 10;
        const marginTop = 10;

        // Tamaño de cada vale
        const valeWidth = 190;
        const valeHeight = 88; // Aumenté la altura para acomodar la leyenda

        // Espacio entre vales
        const spaceBetween = 10;

        // Cargar imagen del logo
        const logoPath = '/MinaToMVC/Assets/img/Logo.ico';
        const logoWidth = 15;
        const logoHeight = 15;

        // Obtener fecha actual formateada
        const fechaActual = new Date();
        const opcionesFecha = { year: 'numeric', month: 'long', day: 'numeric' };
        const fechaFormateada = fechaActual.toLocaleDateString('es-MX', opcionesFecha);
        const leyendaFecha = `Calimaya, Estado de México a: ______________`;

        let valesEnPagina = 0;

        vales.forEach((vale, index) => {
            if (valesEnPagina >= 3) {
                doc.addPage();
                valesEnPagina = 0;
            }

            const yPos = marginTop + (valesEnPagina * (valeHeight + spaceBetween));

            // Encabezado con color gris
            doc.setFillColor(...primaryColor);
            doc.rect(marginLeft, yPos, valeWidth, 15, 'F');

            // Posicionamiento del título y logos
            const centerX = marginLeft + valeWidth / 2;
            const logoLeftX = centerX - 30;
            const logoRightX = centerX + 15;
            const titleY = yPos + 8;

            try {
                doc.addImage(logoPath, 'ICO', logoLeftX, yPos + 2, logoWidth, logoHeight);
                doc.addImage(logoPath, 'ICO', logoRightX, yPos + 2, logoWidth, logoHeight);
            } catch (e) {
                console.error("Error al cargar el logo:", e);
            }

            // Título
            doc.setFontSize(13);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(255, 255, 255);
            doc.text('PLANTA PROCESADORA DE MATERIALES PETREOS SAN MIGUEL, S.A. DE C.V.', centerX, titleY, { align: 'center' });

            // Número de vale
            doc.setFontSize(8);
            doc.text(`VALE No. ${vale.NoVale} de ${vale.CantidadVales}`, centerX, yPos + 13, { align: 'center' });

            // Restaurar color de texto
            doc.setTextColor(0, 0, 0);

            // Cuerpo del vale
            const labelStart = marginLeft + 30;
            const valueStart = marginLeft + 70;

            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            doc.text('FOLIO:', labelStart, yPos + 25);
            doc.text('FECHA:', labelStart, yPos + 32);
            doc.text('CLIENTE:', labelStart, yPos + 39);
            doc.text('MATERIAL:', labelStart, yPos + 46);
            doc.text('CANTIDAD M3:', labelStart, yPos + 53);
            doc.text('PRECIO UNITARIO:', labelStart, yPos + 60);
            doc.text('IMPORTE TOTAL:', labelStart, yPos + 67);

            // Valores
            doc.setFont('helvetica', 'normal');
            doc.text(vale.Folio, valueStart, yPos + 25);
            doc.text(vale.Fecha, valueStart, yPos + 32);
            doc.text(vale.NombreCliente, valueStart, yPos + 39);
            doc.text(vale.NombreMaterial, valueStart, yPos + 46);
            doc.text(vale.CantidadM3, valueStart, yPos + 53);
            doc.text(`$${parseFloat(vale.PrecioUnidad).toFixed(2)}`, valueStart, yPos + 60);
            doc.text(`$${parseFloat(vale.ImporteVenta).toFixed(2)}`, valueStart, yPos + 67);

            // Sección de firma
            doc.setDrawColor(...secondaryColor);
            doc.setLineWidth(0.5);
            doc.line(valueStart + 50, yPos + 75, valueStart + 100, yPos + 75);
            doc.setFontSize(8);
            doc.text('FIRMA Y SELLO', valueStart + 75, yPos + 80, { align: 'center' });

            // Leyenda de fecha (cursiva, debajo de la firma)
            doc.setFont('helvetica', 'italic');
            doc.setFontSize(10);
            doc.text(leyendaFecha, valueStart + 75, yPos + 85, { align: 'center' });

            // Borde del vale
            doc.setDrawColor(0, 0, 0);
            doc.rect(marginLeft, yPos, valeWidth, valeHeight);

            valesEnPagina++;
        });

        // Guardar el PDF
        doc.save(`vales_${vales[0].Folio}_a_${vales[vales.length - 1].Folio}.pdf`);
    }
});
</script>