@model int

<h3>Asociar materiales a la ubicación: <span id="lblNombreUbicacion">@ViewBag.NombreUbicacion</span></h3>
<input type="hidden" id="txtNombreUbicacion" value="@ViewBag.NombreUbicacion" />
<input type="hidden" id="txtIdUbicacion" value="@Model" />
<input type="hidden" id="CreatedBy" value="@ViewBag.CreatedBy" />
<input type="hidden" id="UpdatedBy" value="@ViewBag.UpdatedBy" />
<input type="hidden" id="CreatedDt" value="@ViewBag.CreatedDt" />
<input type="hidden" id="UpdatedDt" value="@ViewBag.UpdatedDt" />

<div class="row">
    <div class="col-md-6">
        <h2>TABLA DE MATERIALES</h2>
        <div class="row">
            <div class="col-lg-12">
                <table class="table table-bordered table-striped" id="tableTipodematerial" style="width: 100%;"></table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <h2>MATERIALES ASOCIADOS</h2>
        <div class="row">
            <div class="col-lg-12">
                <table class="table table-bordered table-striped" id="tableUbicacionTipodematerial" style="width: 100%;"></table>
            </div>
        </div>
    </div>
</div>

<!-- Spinner de carga -->
<div id="spinnerCarga" style="display: none; position: fixed; top: 50%; left: 50%; z-index: 9999; transform: translate(-50%, -50%);">
    <div class="spinner-border text-primary" role="status" style="width: 4rem; height: 4rem;"></div>
</div>

<script>
    // Evitar redeclaración
    if (typeof materialesAsociadosIds === 'undefined') {
        var materialesAsociadosIds = [];
    }
    var dataTableMateriales = null;
    var dataTableAsociados = null;

    $(document).ready(function () {
        const idUbicacion = $("#txtIdUbicacion").val();
        inicializarTablas(idUbicacion);

        // Reabrir modal si está en sessionStorage
        const datosModal = sessionStorage.getItem("abrirModalUbicacion");
        if (datosModal) {
            sessionStorage.removeItem("abrirModalUbicacion");
            // Aquí puedes reabrir tu modal si usas uno como Bootstrap Modal
            // $('#modalAsociarMaterial').modal('show');
        }
    });

    function mostrarCargando() {
        $("#spinnerCarga").show();
    }

    function ocultarCargando() {
        $("#spinnerCarga").hide();
    }

    function inicializarTablas(idUbicacion) {
        mostrarCargando();

        if ($.fn.DataTable.isDataTable("#tableTipodematerial")) {
            $("#tableTipodematerial").DataTable().destroy();
        }
        if ($.fn.DataTable.isDataTable("#tableUbicacionTipodematerial")) {
            $("#tableUbicacionTipodematerial").DataTable().destroy();
        }

        dataTableMateriales = $("#tableTipodematerial").DataTable({
            processing: true,
            serverSide: false,
            paging: true,
            searching: true,
            columns: [
                { data: "id", visible: false, title: "Id" },
                { data: "nombreTipoMaterial", title: "Nombre" },
                {
                    data: "id", title: "Agregar", render: function (data) {
                        return '<input type="button" value="Añadir Material" class="btn btn-custom-clean" style="padding: 10px 14px; font-size: 13px;" onclick="AgregarMaterial(' + data + ')" />'
                    }
                }
            ],
            language: languageES()
        });

        dataTableAsociados = $("#tableUbicacionTipodematerial").DataTable({
            processing: true,
            serverSide: false,
            paging: true,
            searching: true,
            columns: [
                { data: "id", visible: false, title: "Id" },
                { data: "materialId", visible: false, title: "IdMaterial" },
                { data: "nombreTipoMaterial", title: "Nombre" },
                {
                    data: "id", title: "Quitar", render: function (data) {
                        return '<input type="button" value="Quitar Material" class="btn btn-custom-cancel" style="padding: 10px 14px; font-size: 13px;" onclick="QuitarMaterial(' + data + ')" />'
                    }
                }
            ],
            language: languageES()
        });

        GetGetMaterialUbicacionByUbicacion(idUbicacion, function () {
            GetAllTipoMaterialUbicacion();
        });
    }

    function GetGetMaterialUbicacionByUbicacion(idUbicacion, callback) {
        GetMVC("/Catalog/GetGetMaterialUbicacionByUbicacion?id=" + idUbicacion, function (r) {
            if (r.IsSuccess) {
                materialesAsociadosIds = r.Response.map(item => item.materialId);
                dataTableAsociados.clear().rows.add(r.Response).draw();
                if (callback) callback();
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los materiales: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
                ocultarCargando();
            }
        });
    }

    function GetAllTipoMaterialUbicacion() {
        GetMVC("/Catalog/GetAllTipoMaterialUbicacion", function (r) {
            ocultarCargando();
            if (r.IsSuccess) {
                const materialesFiltrados = r.Response.filter(item =>
                    !materialesAsociadosIds.includes(item.id)
                );
                dataTableMateriales.clear().rows.add(materialesFiltrados).draw();
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los materiales: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }
    function AgregarMaterial(materialId) {
        mostrarCargando();

        const idUbicacion = $("#txtIdUbicacion").val();
        const nombreUbicacion = $("#txtNombreUbicacion").val();

        // Guardar bandera para abrir modal después del reload
        sessionStorage.setItem("abrirModalUbicacion", JSON.stringify({
            id: idUbicacion,
            nombre: nombreUbicacion
        }));

        const data = {
            UbicacionId: idUbicacion,
            MaterialId: materialId,
            CreatedBy: $("#CreatedBy").val(),
            CreatedDt: $("#CreatedDt").val(),
            UpdatedBy: $("#UpdatedBy").val(),
            UpdatedDt: $("#UpdatedDt").val()
        };

        PostMVC('/Catalog/SaveOrUpdateMaterialUbicacion', data, function (resultado) {
            if (resultado.IsSuccess) {
                location.reload(); // reload después del post
            } else {
                ocultarCargando();
                Swal.fire({
                    title: 'Error',
                    text: 'Error al agregar material: ' + resultado.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
        location.reload(); // reload después del post
    }

    function QuitarMaterial(id) {
        mostrarCargando();
        window.location.reload();


        const idUbicacion = $("#txtIdUbicacion").val();
        const nombreUbicacion = $("#txtNombreUbicacion").val();

        // Guardar bandera para abrir modal después del reload
        sessionStorage.setItem("abrirModalUbicacion", JSON.stringify({
            id: idUbicacion,
            nombre: nombreUbicacion
        }));


        const data = { Id: id };


        PostMVC('/Catalog/QuitMaterialUbicacion', data, function (resultado) {
            if (resultado.IsSuccess) {
                location.reload(); // reload después del post
                const idUbicacion = $("#txtIdUbicacion").val();
                GetGetMaterialUbicacionByUbicacion(idUbicacion, function () {
                    GetAllTipoMaterialUbicacion();
                    ocultarCargando();
                });
            } else {
                ocultarCargando();
                window.location.reload();
                Swal.fire({
                    title: 'Error',
                    text: 'Error al quitar material: ' + resultado.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
        location.reload(); // reload después del post

    }

    function languageES() {
        return {
            "decimal": ",",
            "thousands": ".",
            "processing": "Procesando...",
            "lengthMenu": "Mostrar _MENU_ entradas",
            "zeroRecords": "No se encontraron resultados",
            "emptyTable": "Ningún dato disponible en esta tabla",
            "info": "Mostrando _START_ a _END_ de _TOTAL_ entradas",
            "infoEmpty": "Mostrando 0 a 0 de 0 entradas",
            "infoFiltered": "(filtrado de un total de _MAX_ entradas)",
            "search": "Buscar:",
            "loadingRecords": "Cargando...",
            "paginate": {
                "first": "Primero",
                "last": "Último",
                "next": "Siguiente",
                "previous": "Anterior"
            }
        };
    }

</script>
