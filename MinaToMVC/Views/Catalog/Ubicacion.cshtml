@model MinaTolEntidades.DtoCatalogos.DtoUbicacion
@{
    ViewBag.Title = "Ubicacion";
    var ubicacion = (MinaTolEntidades.DtoCatalogos.DtoUbicacion)Model;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var estatus = new List<string> { "Activo", "Inactivo" };
}

<div class="container-fluid" style="padding: 20px 15px;">
    <form id="frmubicacion" name="frmubicacion" method="post" enctype="multipart/form-data">
        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-map-marker"></i> Ubicación
                        </h1>
                    </div>
                </div>

                <!-- Campos ocultos -->
                @Html.HiddenFor(x => x.Id)
                @Html.HiddenFor(x => x.Estatus)
                @Html.HiddenFor(x => x.CreatedBy)
                @Html.HiddenFor(x => x.UpdatedBy)
                @Html.HiddenFor(x => x.CreatedDt)
                @Html.HiddenFor(x => x.UpdatedDt)

                <!-- Campos del formulario -->
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-hashtag"></i> ID Ubicación:</label>
                            <input type="text" id="txtIdUbicacion" class="form-control" disabled />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-location-arrow"></i> Nombre de la ubicación:</label>
                            <input type="text" id="txtNombreUbicacion" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-align-left"></i> Descripción:</label>
                            <input type="text" id="txtDescripcionUbicacion" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-building"></i> Ubicación Interna:</label>
                            <div style="padding-top: 8px;">
                                <input type="checkbox" name="EsInterna" id="EsInterna" value="" style="transform: scale(1.2); margin-right: 5px;" />
                                <span id="lblEsInterna">No</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" id="btnGuardarUbicacion" onclick="SaveOrUpdateUbicacion()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Catalog/Ubicacion" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                        <button type="button" id="btnEliminarUbicacion" class="btn btn-danger" disabled onclick="EliminarUbicacion()">
                            <i class="fa fa-trash"></i> Eliminar
                        </button>
                        <button type="button" id="btnAsociar" class="btn btn-info" disabled onclick="AbrirModalMateriales($('#txtIdUbicacion').val(),$('#txtNombreUbicacion').val(),$('#CreatedBy').val(),$('#UpdatedBy').val(),$('#CreatedDt').val(),$('#UpdatedDt').val())">
                            <i class="fa fa-link"></i> Asociar Material
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <i class="fa fa-list"></i> Listado de Ubicaciones
        </div>
        <div class="panel-body table-responsive">
            <table id="tableUbicacion" class="table table-bordered table-striped" style="width: 100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Tipo de Mina</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    var UbicacionJson = JSON.parse('@Html.Raw((Newtonsoft.Json.JsonConvert.SerializeObject(ubicacion)))');
</script>

<script>
    // Script adicional para actualizar el texto del checkbox "EsInterna"
    document.addEventListener('DOMContentLoaded', function () {
        var chkEsInterna = document.getElementById('EsInterna');
        var lblEsInterna = document.getElementById('lblEsInterna');

        if (chkEsInterna && lblEsInterna) {
            function updateEsInternaLabel() {
                lblEsInterna.textContent = chkEsInterna.checked ? 'Sí' : 'No';
                lblEsInterna.style.color = chkEsInterna.checked ? '#5cb85c' : '#d9534f';
            }

            chkEsInterna.addEventListener('change', updateEsInternaLabel);
            updateEsInternaLabel();
        }
    });
</script>

<script src="@(Url.StaticFile("Scripts/Catalogos/Ubicacion.js"))"></script>

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label {
        color: #333333 !important;
    }

    /* Estilo para el texto del checkbox EsInterna */
    #lblEsInterna {
        font-weight: bold;
        transition: color 0.2s ease;
    }
</style>