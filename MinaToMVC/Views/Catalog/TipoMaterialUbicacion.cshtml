@{
    var unidadmedida = (List<MinaTolEntidades.DtoSucursales.UnidadMedida>)ViewBag.UnidadDeMedida;
    var tipoMaterial = (MinaTolEntidades.DtoCatalogos.DtoTipoMaterialUbicacion)Model;

    ViewBag.Title = "TipoMaterialUbicacion";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var estatus = new List<string> { "Activo", "Inactivo" };
}

<div class="container-fluid" style="padding: 20px 15px;">
    <form id="frmTipoMaterialUbicacion" name="frmTipoMaterialUbicacion" method="post" enctype="multipart/form-data">
        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-cubes"></i> Tipo de Material
                        </h1>
                    </div>
                </div>

                <!-- Campos ocultos -->
                <input type="hidden" id="txtidtipomaterial" class="form-control" />
                <input type="hidden" id="txtCreatedBy" name="CreatedBy" value="@User.Identity.Name" />
                <input type="hidden" id="txtCreatedDt" name="CreatedDt" value="@DateTime.Now" />
                <input type="hidden" id="txtUpdatedBy" name="UpdatedBy" value="@User.Identity.Name" />
                <input type="hidden" id="txtUpdatedDt" name="UpdatedDt" value="@DateTime.Now" />

                <!-- Campos del formulario -->
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-tag"></i> Nombre:</label>
                            <input type="text" id="txtNombreTipoMaterial" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-align-left"></i> Descripción:</label>
                            <textarea id="txtDescripcionTipoMaterial" class="form-control" rows="2" required></textarea>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-balance-scale"></i> Unidad de medida:</label>
                            <select id="ddlUnidadDeMedida" name="ddlUnidadDeMedida" class="form-control">
                                @foreach (var unidad in unidadmedida)
                                {
                                    <option value="@unidad.Id">@unidad.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" id="btnGuardaru" onclick="SaveOrUpdateTipoMaterialUbicacion()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Catalog/TipoMaterialUbicacion" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <i class="fa fa-list"></i> Listado de Tipos de Material
        </div>
        <div class="panel-body table-responsive">
            <table class="table table-bordered table-striped" id="tableTipodematerial" style="width: 100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Unidad Medida</th>
                        <th>Estatus</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    var tipoMaterialUbicacionJson = JSON.parse('@Html.Raw((Newtonsoft.Json.JsonConvert.SerializeObject(tipoMaterial)))');
</script>

<script>
    // Script adicional para actualizar el texto del estatus con el checkbox
    document.addEventListener('DOMContentLoaded', function () {
        var chkEstatus = document.getElementById('chbEstatus');
        var lblEstatus = document.getElementById('lblEstatus');

        if (chkEstatus && lblEstatus) {
            function updateEstatusLabel() {
                lblEstatus.textContent = chkEstatus.checked ? 'Activo' : 'Inactivo';
                lblEstatus.style.color = chkEstatus.checked ? '#5cb85c' : '#d9534f';
            }

            chkEstatus.addEventListener('change', updateEstatusLabel);
            updateEstatusLabel();
        }
    });
</script>

<script src="@(Url.StaticFile("Scripts/Catalogos/TipoMaterialUbicacion.js"))"></script>

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label {
        color: #333333 !important;
    }

    /* Estilo para el texto del estatus */
    #lblEstatus {
        font-weight: bold;
        transition: color 0.2s ease;
    }
</style>