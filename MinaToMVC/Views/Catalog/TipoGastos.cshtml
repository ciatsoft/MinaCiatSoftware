@model MinaTolEntidades.DtoCatalogos.DtoTipoGasto
@{
    ViewBag.Title = "TipoGastos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("SaveOrUpdateTipoGastos", "Catalog", FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmTipoGastos", @id = "frmTipoGastos" }))
{
    @Html.HiddenFor(x => x.Estatus)
    @Html.HiddenFor(x => x.CreatedDt, new { @Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") })
    @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy" })
    @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy" })
    @Html.HiddenFor(x => x.UpdatedDt, new { @Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") })

    <div class="container-fluid" style="padding: 20px 15px;">
        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-money"></i> Tipo de Gastos
                        </h1>
                    </div>
                </div>

                <!-- Campos del formulario -->
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-hashtag"></i> ID Tipo Gasto:</label>
                            @Html.TextBoxFor(x => x.Id, new { @class = "form-control", @min = "0", @readonly = "readonly", @Id = "id" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-tag"></i> Nombre:</label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", @Id = "nombre" })
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-align-left"></i> Descripción:</label>
                            @Html.TextBoxFor(x => x.Descripcion, new { @class = "form-control", @Id = "descripcion" })
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" id="btnGuardar" onclick="SaveOrUpdateTipoGastos()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Catalog/TipoGastos" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
}
<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <i class="fa fa-list"></i> Listado de Tipos de Gastos
        </div>
        <div class="panel-body table-responsive">
            <table id="tblTipoGastos" class="table table-bordered table-striped" style="width: 100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Estatus</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Antes de cargar el archivo .js -->
<script type="text/javascript">
    var TipoGastosJson = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
</script>

<script src="@(Url.StaticFile("Scripts/Catalogos/TipoGastos.js"))"></script>

