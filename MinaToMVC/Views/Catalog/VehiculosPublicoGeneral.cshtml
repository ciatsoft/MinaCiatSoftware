@model MinaTolEntidades.DtoClientes.DtoClientesVehiculoPublicoGral
@{
    ViewBag.Title = "VehiculosPublicoGeneral";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var clientes = (List<MinaTolEntidades.DtoClientes.Cliente>)ViewBag.Clientes;
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;

}

@using (Html.BeginForm("SaveOrUpdateVehiculosPublicoGral", "Catalog", FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmVehiculoPublicoGral", @id = "frmVehiculoPublicoGral" }))
{
    @Html.HiddenFor(x => x.Estatus)
    @Html.HiddenFor(x => x.CreatedDt, new { id = "CreatedDt", @Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") })
    @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", @Value = usuarioToken.UserName })
    @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", @Value = usuarioToken.UserName })
    @Html.HiddenFor(x => x.UpdatedDt, new { id = "UpdatedDt", @Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") })

    <div class="container-fluid" style="padding: 20px 15px;">
        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-truck"></i> Vehículos de Clientes Público General
                        </h1>
                    </div>
                </div>

                <!-- Campos del formulario -->
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-hashtag"></i> ID Vehículo Cliente:</label>
                            @Html.TextBoxFor(x => x.Id, new { @class = "form-control", @min = "0", @readonly = "readonly", @Id = "id" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-building"></i> Cliente:</label>
                            @Html.DropDownListFor(x => x.ClienteID,
                                new SelectList(clientes, "Id", "Nombre", Model.ClienteID),
                                "Seleccione un cliente",
                                new { @class = "form-control", @id = "ddlClientes" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-align-left"></i> Descripción:</label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", @Id = "nombre" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-cube"></i> Capacidad en M³:</label>
                            @Html.TextBoxFor(x => x.Capacidad, new { @class = "form-control", @id = "capacidad", @oninput = "this.value = this.value.replace(/[^0-9]/g, '')" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-paint-bucket"></i> Color:</label>
                            @Html.TextBoxFor(x => x.Color, new { @class = "form-control", @Id = "color" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-id-card"></i> Placa:</label>
                            @Html.TextBoxFor(x => x.Placa, new { @class = "form-control", @Id = "placa" })
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="button" id="btnGuardaru" onclick="SaveOrUpdateVehiculosPublicoGral()" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/Catalog/VehiculosPublicoGeneral" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="container-fluid" style="padding: 0 15px 20px 15px;">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <i class="fa fa-list"></i> Listado de Vehículos de Clientes Público General
            </div>
            <div class="panel-body table-responsive">
                <table id="tblVehiculosPublicoGral" class="table table-bordered table-striped" style="width: 100%;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Descripción</th>
                            <th>Capacidad (m³)</th>
                            <th>Cliente</th>
                            <th>Color</th>
                            <th>Placa</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Antes de cargar el archivo .js -->
<script type="text/javascript">
    var VehiculoPubligoGralJson = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
</script>

<script src="@(Url.StaticFile("Scripts/Catalogos/VehiculosPublicoGral.js"))"></script>

