@{
    var usuarioId = (long)ViewBag.UsuarioId;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var usuario = ViewBag.UserToken.UserName;
}

<style>
    /* Estilos personalizados para mantener la misma apariencia */
    .btn-custom-clean {
        background-color: #5bc0de;
        border-color: #46b8da;
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 12px;
        transition: all 0.3s ease;
    }

        .btn-custom-clean:hover {
            background-color: #31b0d5;
            border-color: #269abc;
            color: white;
        }

    .btn-custom-cancel {
        background-color: #d9534f;
        border-color: #d43f3a;
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 12px;
        transition: all 0.3s ease;
    }

        .btn-custom-cancel:hover {
            background-color: #c9302c;
            border-color: #ac2925;
            color: white;
        }

    .text-success {
        color: #3c763d;
    }

    .fw-bold {
        font-weight: bold;
    }

    .panel-custom {
        margin-bottom: 20px;
        background-color: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        box-shadow: 0 1px 1px rgba(0, 0, 0, 0.05);
    }

    .panel-custom-heading {
        padding: 10px 15px;
        border-bottom: 1px solid #ddd;
        background-color: #f5f5f5;
        border-top-left-radius: 3px;
        border-top-right-radius: 3px;
    }

        .panel-custom-heading h4 {
            margin: 0;
            color: #333;
        }

    .panel-custom-body {
        padding: 15px;
    }

    /* Estilos para DataTables */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        margin-bottom: 15px;
    }

        .dataTables_wrapper .dataTables_filter input {
            border: 1px solid #ccc;
            border-radius: 4px;
            padding: 5px 10px;
            margin-left: 10px;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 5px 12px;
            margin: 0 2px;
            border-radius: 4px;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7;
                color: white !important;
                border: 1px solid #2e6da4;
            }

    .table-bordered {
        border: 1px solid #ddd;
    }

    .table-striped > tbody > tr:nth-of-type(odd) {
        background-color: #f9f9f9;
    }
</style>

<!-- Campos ocultos -->
<input type="hidden" id="ModalidRoll" value="@Model.Id" readonly />
<input type="hidden" id="CreatedBy" value="@ViewBag.UserToken.UserName" />
<input type="hidden" id="UpdatedBy" value="@ViewBag.UserToken.UserName" />
<input type="hidden" id="CreatedDt" value="@ViewBag.CreatedDt" />
<input type="hidden" id="UpdatedDt" value="@ViewBag.UpdatedDt" />

<div class="row">
    <div class="col-md-6">
        <div class="panel-custom">
            <div class="panel-custom-heading">
                <h4><i class="fa fa-list"></i> PERMISOS GLOBALES</h4>
            </div>
            <div class="panel-custom-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped" id="tablePermisos" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>TipoMenu</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="panel-custom">
            <div class="panel-custom-heading">
                <h4><i class="fa fa-check-circle"></i> PERMISOS ASOCIADOS</h4>
            </div>
            <div class="panel-custom-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped" id="tablePermisosRelacionados" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>IdRol</th>
                                <th>PermisoId</th>
                                <th>TipoMenu</th>
                                <th>Nombre</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Arreglo para almacenar los permisos asociados (Ids)
    var permisosCargados = [];

    $(document).ready(function () {
        // Primera tabla - Permisos Globales
        $("#tablePermisos").DataTable({
            data: [],
            columns: [
                { data: 'id', title: 'ID', visible: false },
                { data: 'nombre', title: 'Nombre' },
                { data: 'tipoMenu', title: 'TipoMenu', visible: false },
                {
                    data: "id",
                    title: "Acciones",
                    render: function (data, type, row) {
                        if (permisosCargados.includes(row.id)) {
                            return '<span class="text-success fw-bold"><i class="fa fa-check-circle"></i> Permiso ya asignado</span>';
                        } else {
                            var nombreEscapado = row.nombre.replace(/'/g, "\\'").replace(/"/g, '\\"');
                            var tipoMenu = row.tipoMenu.replace(/'/g, "\\'").replace(/"/g, '\\"');
                            return '<button type="button" class="btn btn-custom-clean" onclick="AgregarPermiso(' + data + ', \'' + nombreEscapado + '\', \'' + tipoMenu + '\')"><i class="fa fa-plus"></i> Agregar</button>';
                        }
                    }
                }
            ],
            language: {
                "decimal": ".",
                "thousands": ",",
                "processing": '<i class="fa fa-spinner fa-spin"></i> Procesando...',
                "lengthMenu": '<i class="fa fa-list"></i> Mostrar _MENU_ registros',
                "zeroRecords": '<i class="fa fa-info-circle"></i> No se encontraron resultados',
                "emptyTable": '<i class="fa fa-database"></i> No hay datos disponibles',
                "info": '<i class="fa fa-info-circle"></i> Mostrando _START_ a _END_ de _TOTAL_ registros',
                "infoEmpty": '<i class="fa fa-info-circle"></i> Mostrando 0 a 0 de 0 registros',
                "infoFiltered": '<i class="fa fa-filter"></i> (filtrado de _MAX_ registros totales)',
                "search": '<i class="fa fa-search"></i> Buscar:',
                "paginate": {
                    "first": '<i class="fa fa-fast-backward"></i> Primero',
                    "last": '<i class="fa fa-fast-forward"></i> Último',
                    "next": '<i class="fa fa-forward"></i> Siguiente',
                    "previous": '<i class="fa fa-backward"></i> Anterior'
                },
                "aria": {
                    "sortAscending": ": activar para ordenar ascendente",
                    "sortDescending": ": activar para ordenar descendente"
                }
            }
        });

        // Segunda tabla - Permisos ya Relacionados
        $("#tablePermisosRelacionados").DataTable({
            data: [],
            columns: [
                { data: 'id', title: 'ID', visible: false },
                { data: 'idRol', title: 'IdRol', visible: false },
                { data: 'permisoId', title: 'PermisoId', visible: false },
                { data: 'tipoMenu', title: 'TipoMenu', visible: false },
                { data: 'nombre', title: 'Nombre' },
                {
                    data: "id",
                    title: "Acciones",
                    render: function (data, type, row) {
                        return '<button type="button" class="btn btn-custom-cancel" onclick="EliminarPermiso(' + row.permisoId + ',' + row.idRol + ')"><i class="fa fa-trash"></i> Eliminar</button>';
                    }
                }
            ],
            language: {
                "decimal": ".",
                "thousands": ",",
                "processing": '<i class="fa fa-spinner fa-spin"></i> Procesando...',
                "lengthMenu": '<i class="fa fa-list"></i> Mostrar _MENU_ registros',
                "zeroRecords": '<i class="fa fa-info-circle"></i> No se encontraron resultados',
                "emptyTable": '<i class="fa fa-database"></i> No hay datos disponibles',
                "info": '<i class="fa fa-info-circle"></i> Mostrando _START_ a _END_ de _TOTAL_ registros',
                "infoEmpty": '<i class="fa fa-info-circle"></i> Mostrando 0 a 0 de 0 registros',
                "infoFiltered": '<i class="fa fa-filter"></i> (filtrado de _MAX_ registros totales)',
                "search": '<i class="fa fa-search"></i> Buscar:',
                "paginate": {
                    "first": '<i class="fa fa-fast-backward"></i> Primero',
                    "last": '<i class="fa fa-fast-forward"></i> Último',
                    "next": '<i class="fa fa-forward"></i> Siguiente',
                    "previous": '<i class="fa fa-backward"></i> Anterior'
                },
                "aria": {
                    "sortAscending": ": activar para ordenar ascendente",
                    "sortDescending": ": activar para ordenar descendente"
                }
            }
        });

        // Cargar permisos del rol actual
        var rolId = $("#ModalidRoll").val();
        GetPermisosByIdRol(rolId);
    });

    // Obtener todos los permisos
    function GetAllPermisos() {
        GetMVC("/Catalog/GetAllPermisos", function (r) {
            if (r.IsSuccess) {
                MapingPropertiesDataTable("tablePermisos", r.Response);
                actualizarEstadoPermisos();
            } else {
                swal("Error", "Error al cargar los Permisos: " + r.ErrorMessage, "error");
            }
        });
    }

    // Obtener permisos asignados a un rol
    function GetPermisosByIdRol(rolId) {
        GetMVC("/Catalog/GetPermisosByIdRol?idRol=" + rolId, function (r) {
            if (r.IsSuccess) {
                permisosCargados = r.Response.map(function (doc) { return doc.permisoId; });
                MapingPropertiesDataTable("tablePermisosRelacionados", r.Response);
                GetAllPermisos();
            } else {
                swal("Error", "Error al cargar los Permisos del Rol: " + r.ErrorMessage, "error");
            }
        });
    }

    // Eliminar permiso
    function EliminarPermiso(permisoId, idRol) {
        swal({
            title: "¿Estás seguro?",
            text: "¿Quieres eliminar este permiso?",
            type: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d9534f",
            cancelButtonColor: "#5bc0de",
            confirmButtonText: "Sí, eliminar",
            cancelButtonText: "Cancelar",
            closeOnConfirm: true
        }, function (isConfirm) {
            if (isConfirm) {
                swal("¡Eliminado!", "El permiso ha sido eliminado correctamente.", "success");
                location.reload();
                PostMVC("/Catalog/DeletePermiso?id=" + permisoId + "&idRol=" + idRol, function (r) {
                    if (r.IsSuccess) {
                        swal("¡Eliminado!", "El permiso ha sido eliminado correctamente.", "success");
                        location.reload();
                    } else {
                        swal("Error!", "Error al eliminar el permiso: " + (r.ErrorMessage || "Error desconocido"), "error");
                    }
                });
            }
        });
    }

    // Agregar permiso
    function AgregarPermiso(idPermiso, Nombre, TipoMenu) {
        var rolId = $("#ModalidRoll").val();
        var data = {
            PermisoId: idPermiso,
            IdRol: rolId,
            TipoMenu: TipoMenu,
            Nombre: Nombre,
            Estatus: 1,
            CreatedBy: $("#CreatedBy").val(),
            CreatedDt: $("#CreatedDt").val(),
            UpdatedBy: $("#UpdatedBy").val(),
            UpdatedDt: $("#UpdatedDt").val()
        };

        $.ajax({
            url: '/Catalog/SaveOrUpdatePermisosRol',
            type: 'POST',
            data: data,
            success: function (response) {
                var r = typeof response === "string" ? JSON.parse(response) : response;

                if (r.IsSuccess) {
                    permisosCargados.push(parseInt(idPermiso));
                    actualizarEstadoPermisos();
                    GetPermisosByIdRol(rolId);
                    swal("¡Éxito!", "Permiso asignado exitosamente.", "success");
                    location.reload();
                } else {
                    swal("Error", r.ErrorMessage || "Error al asignar el permiso.", "error");
                }
            },
            error: function (xhr, status, error) {
                swal("Error", "Error de conexión: " + error, "error");
            }
        });
    }

    // Refrescar estado de botones en tabla de permisos
    function actualizarEstadoPermisos() {
        var table = $("#tablePermisos").DataTable();
        table.rows().invalidate().draw();
    }

    function MapingPropertiesDataTable(tableId, data) {
        var table = $("#" + tableId).DataTable();
        table.clear();
        table.rows.add(data).draw();
    }

    // Función GetMVC
    function GetMVC(url, callback) {
        $.ajax({
            url: url,
            type: 'GET',
            success: function (response) {
                var r = typeof response === "string" ? JSON.parse(response) : response;
                callback(r);
            },
            error: function (xhr, status, error) {
                callback({ IsSuccess: false, ErrorMessage: error });
            }
        });
    }
</script>
