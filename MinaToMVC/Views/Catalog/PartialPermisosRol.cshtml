<h3>Asociar Permisos para el Rol: <span id="lblNombreRol">@Model.Nombre</span></h3>
<div class="form-group">
    <input type="hidden" id="ModalidRoll" value="@Model.Id" class="form-control" readonly />
    <input type="hidden" id="CreatedBy" value="@ViewBag.UserToken.UserName" />
    <input type="hidden" id="UpdatedBy" value="@ViewBag.UserToken.UserName" />
    <input type="hidden" id="CreatedDt" value="@ViewBag.CreatedDt" />
    <input type="hidden" id="UpdatedDt" value="@ViewBag.UpdatedDt" />
</div>

<div class="row">
    <div class="col-md-6">
        <h3>PERMISOS GLOBALES</h3>
        <div class="row">
            <table class="table table-bordered table-striped" id="tablePermisos" style="width: 100%;"></table>
        </div>
    </div>
    <div class="col-md-6">
        <h3>PERMISOS ASOCIADOS</h3>
        <div class="row">
            <table class="table table-bordered table-striped" id="tablePermisosRelacionados" style="width: 100%;"></table>
        </div>
    </div>
</div>

<script>
    // Arreglo para almacenar los permisos asociados (Ids)
    var permisosCargados = [];

    $(document).ready(function () {
        // Primera tabla
        $("#tablePermisos").DataTable({
            data: [],
            columns: [
                { data: 'id', title: 'ID', visible: false },
                { data: 'nombre', title: 'Nombre' },
                { data: 'tipoMenu', title: 'TipoMenu', visible: false },
                {
                    data: "id",
                    title: "Acciones",
                    render: function (data, type, row) {
                        if (permisosCargados.includes(row.id)) {
                            return '<span class="text-success fw-bold">Permiso ya asignado</span>';
                        } else {
                            var nombreEscapado = row.nombre.replace(/'/g, "\\'").replace(/"/g, '\\"');
                            var tipoMenu = row.tipoMenu.replace(/'/g, "\\'").replace(/"/g, '\\"');
                            return '<input type="button" class="btn btn-custom-clean" value="Agregar Rol" onclick="AgregarPermiso(' + data + ', \'' + nombreEscapado + '\', \'' + tipoMenu + '\')" />';
                        }
                    }
                }
            ]
        });

        // Segunda tabla (Permisos ya Relacionados)
        $("#tablePermisosRelacionados").DataTable({
            data: [],
            columns: [
                { data: 'id', title: 'ID', visible: false },
                { data: 'idRol', title: 'IdRol', visible: false },
                { data: 'permisoId', title: 'PermisoId', visible: false },
                { data: 'tipoMenu', title: 'TipoMenu', visible: false },
                { data: 'nombre', title: 'Nombre' },
                {
                    data: "permisoId",
                    title: "Acciones",
                    render: function (data, type, row) {
                        return '<input type="button" value="Eliminar" class="btn btn-custom-cancel" onclick="EliminarPermiso(' + row.permisoId + ',' + row.idRol + ')" />';
                    }
                }
            ]
        });

        // Cargar permisos del rol actual
        var rolId = $("#ModalidRoll").val();
        GetPermisosByIdRol(rolId);
    });

    // Obtener todos los permisos
    function GetAllPermisos() {
        GetMVC("/Catalog/GetAllPermisos", function (r) {
            if (r.IsSuccess) {
                MapingPropertiesDataTable("tablePermisos", r.Response);
                actualizarEstadoPermisos();
            } else {
                Swal.fire("Error", "Error al cargar los Roles: " + r.ErrorMessage, "error");
            }
        });
    }

    // Obtener permisos asignados a un rol
    function GetPermisosByIdRol(rolId) {
        GetMVC("/Catalog/GetPermisosByIdRol?idRol=" + rolId, function (r) {
            if (r.IsSuccess) {
                permisosCargados = r.Response.map(function (doc) { return doc.permisoId; });
                MapingPropertiesDataTable("tablePermisosRelacionados", r.Response);
                GetAllPermisos();
            } else {
                Swal.fire("Error", "Error al cargar los Permisos del Rol: " + r.ErrorMessage, "error");
            }
        });
    }

    // Eliminar permiso
    function EliminarPermiso(permisoId, idRol) {
        Swal.fire({
            title: '¿Estás seguro?',
            text: "¿Quieres eliminar este permiso?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire(
                    '¡Eliminado!',
                    'El permiso ha sido eliminado correctamente.',
                    'success'
                ).then(() => {
                    location.reload();
                });
                // Petición al backend
                GetMVC("/Catalog/DeletePermiso?id=" + permisoId + "&idRol=" + idRol, function (r) {
                });
            }
        });
    }

    // Agregar permiso
    function AgregarPermiso(idPermiso, Nombre, TipoMenu) {
        var rolId = $("#ModalidRoll").val();
        var data = {
            PermisoId: idPermiso,
            IdRol: rolId,
            TipoMenu: TipoMenu,
            Nombre: Nombre,
            Estatus: 1,
            CreatedBy: $("#CreatedBy").val(),
            CreatedDt: $("#CreatedDt").val(),
            UpdatedBy: $("#UpdatedBy").val(),
            UpdatedDt: $("#UpdatedDt").val()
        };

        Swal.fire({
            title: 'Asignando permiso...',
            allowOutsideClick: false,
            didOpen: () => Swal.showLoading()
        });

        $.ajax({
            url: '/Catalog/SaveOrUpdatePermisosRol',
            type: 'POST',
            data: data,
            success: function (response) {
                Swal.close();
                var r = typeof response === "string" ? JSON.parse(response) : response;

                if (r.IsSuccess) {
                    permisosCargados.push(parseInt(idPermiso));
                    actualizarEstadoPermisos();
                    GetPermisosByIdRol(rolId);
                    Swal.fire("¡Éxito!", "Permiso asignado exitosamente.", "success");
                } else {
                    Swal.fire("Error", r.ErrorMessage || "Error al asignar el permiso.", "error");
                }
            },
            error: function (xhr, status, error) {
                Swal.close();
                Swal.fire("Error", "Error de conexión: " + error, "error");
            }
        });
    }

    // Refrescar estado de botones en tabla de permisos
    function actualizarEstadoPermisos() {
        var table = $("#tablePermisos").DataTable();
        table.rows().every(function () {
            var rowData = this.data();
            var node = this.node();
            var accionesCell = $(node).find('td:eq(3)'); // Asumiendo que la columna de acciones es la cuarta (índice 3)

            if (permisosCargados.includes(rowData.id)) {
                accionesCell.html('<span class="text-success fw-bold">Permiso ya asignado</span>');
            } else {
                var nombreEscapado = rowData.nombre.replace(/'/g, "\\'").replace(/"/g, '\\"');
                var tipoMenu = rowData.tipoMenu.replace(/'/g, "\\'").replace(/"/g, '\\"');
                accionesCell.html('<input type="button" class="btn btn-custom-clean" value="Agregar Rol" onclick="AgregarPermiso(' + rowData.id + ', \'' + nombreEscapado + '\', \'' + tipoMenu + '\')" />');
            }
        });
    }

    function MapingPropertiesDataTable(tableId, data) {
        var table = $("#" + tableId).DataTable();
        table.clear();
        table.rows.add(data).draw();
    }

    // Función GetMVC (asumiendo que existe)
    function GetMVC(url, callback) {
        $.ajax({
            url: url,
            type: 'GET',
            success: function (response) {
                var r = typeof response === "string" ? JSON.parse(response) : response;
                callback(r);
            },
            error: function (xhr, status, error) {
                callback({ IsSuccess: false, ErrorMessage: error });
            }
        });
    }
</script>