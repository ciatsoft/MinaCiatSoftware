@model MinaTolEntidades.Dto_Rfid.Rfid
@{
    ViewBag.Title = "RFID";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var rfid = (MinaTolEntidades.Dto_Rfid.Rfid)Model;
}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>
<script src="~/Scripts/RFID/RFID.js"></script>
<style>
    .btn-success {
        background-color: #28a745; /* Verde para el botón Guardar */
        color: white;
        border: none;
        transition: all 0.3s ease; /* Transición suave para el cambio de tamaño y color */
    }

        .btn-success:hover {
            background-color: #218838; /* Color verde más oscuro al pasar el ratón */
            transform: scale(1.3); /* Aumenta el tamaño del botón */
            color: white; /* Color de texto blanco */
        }

    .btn-custom-cancel {
        background-color: red; /*  para el botón Guardar */
        color: white;
        border: none;
        transition: all 0.3s ease; /* Transición suave para el cambio de tamaño y color */
    }

        .btn-custom-cancel:hover {
            background-color: darkred; /* Color  más oscuro al pasar el ratón */
            transform: scale(1.3); /* Aumenta el tamaño del botón */
            color: white; /* Color de texto blanco */
        }

    .btn-custom-clean {
        background-color: dodgerblue; /*  para el botón Guardar */
        color: white;
        border: none;
        transition: all 0.3s ease; /* Transición suave para el cambio de tamaño y color */
    }

        .btn-custom-clean:hover {
            background-color: deepskyblue; /* Color  más oscuro al pasar el ratón */
            transform: scale(1.3); /* Aumenta el tamaño del botón */
            color: white; /* Color de texto blanco */
        }
</style>
<div class="content">

    <form id="frmRFID" name="frmRFID" method="post" enctype="multipart/form-data">
        <br>
        <center><h1>Asignacion de RFID para el Personal</h1></center>
        <div class="tabla-consultas-tableRFID">
            <div class="rectangulos" style="width: 100%;">
                <!-- Mueve el campo oculto junto a los otros campos ocultos -->
                <input type="hidden" id="txtIdRfid" value="" />

                <div class="row">
                    <div class="col-lg-3">
                        <label>RFID Capturado:</label>
                        <input type="text" id="txtRFID" class="form-control" required placeholder="1234567" />
                    </div>
                    <div class="col-lg-3">
                        <label>Trabajador:</label>
                        <select id="txtNombreUsuario" class="form-control" required>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <input type="button" value="Guardar" onclick="SaveOrUpdateRFID()" class="btn btn-success" />
                        <a href="/RFID/RFID" class="btn btn-custom-cancel">Cancelar</a>
                        <button type="button" class="btn btn-custom-cancel" onclick="LimpiarFormulario()">Limpiar Formulario</button>
                    </div>
                </div>

                <input type="hidden" id="txtCreatedBy" value="@User.Identity.Name" />
                <input type="hidden" id="txtCreatedDt" value="@DateTime.Now" />
                <input type="hidden" id="txtUpdatedBy" value="@User.Identity.Name" />
                <input type="hidden" id="txtUpdatedDt" value="@DateTime.Now" />
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <table class="table table-bordered table-striped" id="tableRFID" style="width: 100%;"></table>
            </div>
        </div>
    </form>
    <script>
        var rfidJson = JSON.parse('@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(rfid))');
    </script>
</div>