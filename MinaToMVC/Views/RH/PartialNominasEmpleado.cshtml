@model MinaTolEntidades.DtoEmpleados.NominaEmpleado
@{
    var trabajadorId = (long)ViewBag.TrabajadorId;

    DateTime hoy = DateTime.Today;
    int diferencia1 = hoy.DayOfWeek - DayOfWeek.Monday;
    DateTime lunes = hoy.AddDays(-diferencia1);
    var fechaLunes = lunes.ToString("yyyy-MM-dd");

    DateTime viernes = lunes.AddDays(4);
    var fechaViernes = viernes.ToString("yyyy-MM-dd");

    DateTime sabado = lunes.AddDays(5);
    var fechaSabado = sabado.ToString("yyyy-MM-dd");

    var usuario = @ViewBag.UserToken.UserName;
    var nombreCompleto = ViewBag.NombreTrabajador;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>

<div class="content">
    <div class="tabla-consultas-roll">
        <div class="rectangulos" style="width: 100%;">
            <h2>Generar Nomina para @nombreCompleto</h2>
            <div class="row" style="margin-top: 20px;">
                <div class="col-lg-3">
                    <label>Fecha del Inicio:</label>
                    <input type="date" class="form-control" id="fechaInicio" name="fechaInicio" value="@fechaLunes" readonly>
                </div>
                <div class="col-lg-3">
                    <label>Fecha de Fin:</label>
                    <input type="date" class="form-control" id="fechaFinal" name="fechaFinal" value="" readonly>
                    <input type="hidden" class="form-control" id="diaNomina" name="diaNomina" readonly>
                </div>
                <div class="col-lg-5">
                    <input type="button" value="Calcular Nomina Semanal" onclick="GetAllConceptoEmpleadoByIdEmpleadoDates()" class="btn btn-success" />
                </div>
            </div>
        </div>
    </div>
    <div class="tabla-consultas-roll">
        <div class="rectangulos" style="width: 100%;">
            <h3>Conceptos Acumulados para Nomina Semanal</h3>
            <br />
            <table class="table table-bordered table-striped" id="tblConceptosEmpleado" style="width: 100%;"></table>
            <h3>Prestamos solicitados en la Semana</h3>
            <br />
            <table class="table table-bordered table-striped" id="tblPrestamosEmpleado" style="width: 100%;"></table>
        </div>
    </div>
    @using (Html.BeginForm("SaveOrUpdateConceptoEmpleadoByIdEmpleado", "RH", FormMethod.Post, new { enctype = "multipart/form-data", @id = "frmConceptoEmpleado" }))
    {
        @Html.HiddenFor(x => x.Id, new { @id = "id" })
        @Html.HiddenFor(x => x.IdTrabajador, new { @id = "idTrabajador", Value = trabajadorId })
        @Html.HiddenFor(x => x.Estatus, new { @id = "estatus" })
        @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", Value = usuario })
        @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", Value = usuario })
        @Html.HiddenFor(x => x.CreatedDt, new { id = "createdDt", Value = fechaActual })
        @Html.HiddenFor(x => x.UpdatedDt, new { id = "updatedDt", Value = fechaActual })
        @Html.HiddenFor(x => x.FechaInicio, new { @class = "form-control", @id = "fechaInicioRazor", @readonly = "readonly" })
        @Html.HiddenFor(x => x.FechaFinal, new { @class = "form-control", @id = "fechaFinalRazor", @readonly = "readonly" })
        <div class="tabla-consultas-roll">
            <div class="rectangulos" style="width: 100%;">
                <div class="row" style="margin-top: 20px;">
                    <div class="col-lg-4">
                        <label>Salario Semanal:</label>
                        @Html.TextBoxFor(x => x.SalarioSemanal, new { @class = "form-control", @id = "salarioSemanal", @oninput = "this.value = this.value.replace(/[^0-9.]/g, '')", @readonly = "readonly", @type = "text" })
                    </div>
                    <div class="col-lg-4">
                        <label>Total de Aumento:</label>
                        @Html.TextBoxFor(x => x.Aumento, new { @class = "form-control", @id = "aumento", @oninput = "this.value = this.value.replace(/[^0-9.]/g, '')", @readonly = "readonly", @type = "text" })
                    </div>
                    <div class="col-lg-4">
                        <label>Total de Descuento:</label>
                        @Html.TextBoxFor(x => x.Descuento, new { @class = "form-control", @id = "descuento", @oninput = "this.value = this.value.replace(/[^0-9.]/g, '')", @readonly = "readonly", @type = "text" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4">
                        <label>Salario Final Semanal:</label>
                        @Html.TextBoxFor(x => x.SalarioFinal, new { @class = "form-control", @id = "salarioFinal", @oninput = "this.value = this.value.replace(/[^0-9.]/g, '')", @readonly = "readonly", @type = "text" })
                    </div> 
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-12">
                        <input type="button" value="Guardar" onclick="SearchNominaEmpleadoByDates()" class="btn btn-success" />
                        <a href="/RH/NominaEmpleado" class="btn btn-custom-cancel">Cancelar</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<script>
    $(document).ready(function () {
        ObtenerDatosEmpleadoYSalario(@trabajadorId);
        // Actualizar al cambiar los inputs date
        $('#fechaInicio, #fechaFinal').change(function () {
            $('#fechaInicioRazor').val($('#fechaInicio').val());
            $('#fechaFinalRazor').val($('#fechaFinal').val());
        });

        // Establecer valores iniciales
        $('#fechaInicioRazor').val($('#fechaInicio').val());
        $('#fechaFinalRazor').val($('#fechaFinal').val());

        $("#tblPrestamosEmpleado").DataTable({
            processing: true,
            destroy: true,
            paging: true,
            searching: true,
            columns: [
                { data: "id", visible: false, title: "Id" },
                { data: "nombre", title: "Nombre", visible: false },
                { data: "descripcion", title: "Descripción de Préstamo" },
                {
                    data: "monto",
                    title: "Monto",
                    render: function (data) {
                        return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(data);
                    }
                },
                {
                    data: 'fecha', title: 'Fecha', render: function (data) {
                        return data ? new Date(data).toISOString().split('T')[0] : '';
                    }
                }
            ],
            language: {
                decimal: ",",
                thousands: ".",
                processing: "Procesando...",
                lengthMenu: "Mostrar _MENU_ entradas",
                zeroRecords: "No se encontraron resultados",
                emptyTable: "Ningún dato disponible en esta tabla",
                info: "Mostrando _START_ a _END_ de _TOTAL_ entradas",
                infoEmpty: "Mostrando 0 a 0 de 0 entradas",
                infoFiltered: "(filtrado de un total de _MAX_ entradas)",
                search: "Buscar:",
                loadingRecords: "Cargando...",
                paginate: {
                    first: "Primero",
                    last: "Último",
                    next: "Siguiente",
                    previous: "Anterior"
                },
                aria: {
                    sortAscending: ": activar para ordenar ascendente",
                    sortDescending: ": activar para ordenar descendente"
                }
            },
        });

        // Inicializar DataTable con la función de cálculo automático
        $("#tblConceptosEmpleado").DataTable({
            data: [],
            columns: [
                { data: 'id', title: 'ID', visible: false },
                { data: 'idTrabajador', title: 'Id Trabajador', visible: false },
                { data: 'idConceptoEmpleado', title: 'Id Concepto Empleado', visible: false },
                { data: 'nombreConceptoEmpleado', title: 'Nombre del Concepto' },
                { data: 'cantidad', title: 'Cantidad' },
                {
                    data: 'valor', title: 'Valor', render: function (data) {
                        return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(data);
                    }
                },
                {
                    data: 'totalNeto', title: 'Total Neto', render: function (data) {
                        return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(data);
                    }
                },
                {
                    data: 'fecha', title: 'Fecha', render: function (data) {
                        return data ? new Date(data).toISOString().split('T')[0] : '';
                    }
                },
                { data: 'tipoCargo', title: 'Tipo de Cargo' },
            ],
            order: [[0, 'desc']],
            language: {
                "decimal": ",",
                "thousands": ".",
                "processing": "Procesando...",
                "lengthMenu": "Mostrar _MENU_ entradas",
                "zeroRecords": "No se encontraron resultados",
                "emptyTable": "Ningun dato disponible en esta tabla",
                "info": "Mostrando _START_ a _END_ de _TOTAL_ entradas",
                "infoEmpty": "Mostrando 0 a 0 de 0 entradas",
                "infoFiltered": "(filtrado de un total de _MAX_ entradas)",
                "search": "Buscar:",
                "loadingRecords": "Cargando...",
                "paginate": {
                    "first": "Primero",
                    "last": "Último",
                    "next": "Siguiente",
                    "previous": "Anterior"
                },
                "aria": {
                    "sortAscending": ": activar para ordenar la columna de manera ascendente",
                    "sortDescending": ": activar para ordenar la columna de manera descendente"
                }
            },
            // Calcular automáticamente cuando se modifiquen los datos
            drawCallback: function() {
                calcularSumatoriasYSalario();
            }
        });

        // Actualizar cuando cambie el salario semanal
        $('#salarioSemanal').on('change', function() {
            calcularSumatoriasYSalario();
        });
    });

    // Función para calcular sumatorias y salario final
    function calcularSumatoriasYSalario() {
        var table = $('#tblConceptosEmpleado').DataTable();
        var data = table.data().toArray();

        var table2 = $('#tblPrestamosEmpleado').DataTable();
        var data2 = table2.data().toArray();

        var totalAumento = 0;
        var totalDescuento = 0;
        var totalPrestamos = 0;

        // Calcular sumatorias por tipo de concepto (Aumento y Descuento)
        data.forEach(function (row) {
            if (row.tipoCargo === 'Aumento') {
                totalAumento += parseFloat(row.totalNeto) || 0;
            } else if (row.tipoCargo === 'Descuento') {
                totalDescuento += parseFloat(row.totalNeto) || 0;
            }
        });

        // Calcular sumatoria de préstamos (desde la tabla de préstamos)
        data2.forEach(function (row) {
            totalPrestamos += parseFloat(row.monto) || 0;
        });

        // Obtener salario semanal (limpiar formato de moneda)
        var salarioSemanalTexto = $('#salarioSemanal').val();
        var salarioSemanal = parseFloat(salarioSemanalTexto.replace(/[$,]/g, '')) || 0;

        // Descuento total (descuentos + préstamos)
        var descuentoFinal = totalDescuento + totalPrestamos;

        // Calcular salario final
        var salarioFinal = salarioSemanal + totalAumento - descuentoFinal;

        // Función para formatear como moneda MXN (dentro de la función principal)
        function formatCurrency(value) {
            if (value === '' || value === null || value === undefined) return '';

            let num = parseFloat(value);
            if (isNaN(num)) return value;

            return num.toLocaleString('es-MX', {
                style: 'currency',
                currency: 'MXN',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        // Función para quitar formato de moneda (dentro de la función principal)
        function unformatCurrency(value) {
            if (!value) return '';
            return value.toString().replace(/[^\d.-]/g, '');
        }

        // Actualizar los inputs con formato MXN inmediatamente
        $('#aumento').val(formatCurrency(totalAumento));
        $('#descuento').val(formatCurrency(descuentoFinal));
        $('#salarioFinal').val(formatCurrency(salarioFinal));

        // Configurar eventos para salarioSemanal (si es editable)
        $('#salarioSemanal').off('input blur focus').on('input', function () {
            // Permitir números y un punto decimal
            let input = $(this).val();

            // Remover todo excepto números y un punto decimal
            let value = input.replace(/[^0-9.]/g, '');

            // Permitir solo un punto decimal
            let parts = value.split('.');
            if (parts.length > 2) {
                value = parts[0] + '.' + parts.slice(1).join('');
            }

            // Limitar a 2 decimales
            if (parts.length > 1 && parts[1].length > 2) {
                value = parts[0] + '.' + parts[1].substring(0, 2);
            }

            $(this).val(value);

            // Recalcular automáticamente si se modifica
            setTimeout(function () {
                calcularSumatoriasYSalario();
            }, 100);
        }).on('blur', function () {
            let value = $(this).val();
            if (value && value.trim() !== '') {
                let num = parseFloat(value);
                if (!isNaN(num)) {
                    $(this).val(formatCurrency(num));
                }
            }
        }).on('focus', function () {
            let value = unformatCurrency($(this).val());
            $(this).val(value);
        });

        // Hacer que los campos de resultado sean de solo lectura
        $('#aumento, #descuento, #salarioFinal').prop('readonly', true);

        // Configurar eventos de formato para campos de resultados
        $('#aumento').off('blur focus').on('blur', function () {
            let value = $(this).val();
            if (value && value.trim() !== '') {
                let num = parseFloat(unformatCurrency(value));
                if (!isNaN(num)) {
                    $(this).val(formatCurrency(num));
                }
            }
        }).on('focus', function () {
            let value = unformatCurrency($(this).val());
            $(this).val(value);
        });

        $('#descuento').off('blur focus').on('blur', function () {
            let value = $(this).val();
            if (value && value.trim() !== '') {
                let num = parseFloat(unformatCurrency(value));
                if (!isNaN(num)) {
                    $(this).val(formatCurrency(num));
                }
            }
        }).on('focus', function () {
            let value = unformatCurrency($(this).val());
            $(this).val(value);
        });

        $('#salarioFinal').off('blur focus').on('blur', function () {
            let value = $(this).val();
            if (value && value.trim() !== '') {
                let num = parseFloat(unformatCurrency(value));
                if (!isNaN(num)) {
                    $(this).val(formatCurrency(num));
                }
            }
        }).on('focus', function () {
            let value = unformatCurrency($(this).val());
            $(this).val(value);
        });

        // Para enviar al servidor - quitar formato antes de enviar
        $('form').off('submit').on('submit', function () {
            $('#aumento').val(unformatCurrency($('#aumento').val()));
            $('#descuento').val(unformatCurrency($('#descuento').val()));
            $('#salarioFinal').val(unformatCurrency($('#salarioFinal').val()));
            $('#salarioSemanal').val(unformatCurrency($('#salarioSemanal').val()));
        });

        // También formatear salarioSemanal si tiene valor
        var salarioSemanalFormatted = $('#salarioSemanal').val();
        if (salarioSemanalFormatted && salarioSemanalFormatted.trim() !== '') {
            var salarioNum = parseFloat(unformatCurrency(salarioSemanalFormatted));
            if (!isNaN(salarioNum)) {
                $('#salarioSemanal').val(formatCurrency(salarioNum));
            }
        }
    }

    // Función para formatear visualmente como moneda
    function formatearMonedaVisual() {
        // Formatear aumento
        var aumentoValor = parseFloat($('#aumento').val()) || 0;
        $('#aumento').val(new Intl.NumberFormat('es-MX', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(aumentoValor));

        // Formatear descuento
        var descuentoValor = parseFloat($('#descuento').val()) || 0;
        $('#descuento').val(new Intl.NumberFormat('es-MX', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(descuentoValor));

        // Formatear salario final
        var salarioFinalValor = parseFloat($('#salarioFinal').val()) || 0;
        $('#salarioFinal').val(new Intl.NumberFormat('es-MX', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(salarioFinalValor));

        // También asegurar que el salario semanal esté formateado correctamente
        var salarioSemanalValor = parseFloat($('#salarioSemanal').val().replace(/[$,]/g, '')) || 0;
        $('#salarioSemanal').val(new Intl.NumberFormat('es-MX', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(salarioSemanalValor));
    }

    // Actualizar cuando cambie el salario semanal (usando input event para mayor compatibilidad)
    $('#salarioSemanal').on('input change', function () {
        // Primero formatear el valor
        var valor = parseFloat($(this).val().replace(/[$,]/g, '')) || 0;
        $(this).val(new Intl.NumberFormat('es-MX', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(valor));

        // Luego calcular
        calcularSumatoriasYSalario();
    });

    function SearchConceptosEmpleado() {
        // Asegurar que las fechas estén actualizadas
        $('#fechaInicioRazor').val($('#fechaInicio').val());
        $('#fechaFinalRazor').val($('#fechaFinal').val());
    }

    function GetAllConceptoEmpleadoByIdEmpleadoDates() {
        // Obtener el ID del empleado
        var idEmpleado = @trabajadorId;

        // Obtener valores de los inputs de fecha
        var fechaInicio = document.getElementById('fechaInicio').value;
        var fechaFinal = document.getElementById('fechaFinal').value;

        // Validar que las fechas no estén vacías
        if (!fechaInicio || !fechaFinal) {
            Swal.fire({
                title: 'Advertencia',
                text: 'Por favor, seleccione ambas fechas',
                icon: 'warning',
                confirmButtonText: 'Aceptar'
            });
            return;
        }

        // Convertir strings a objetos Date
        var fechaInicioDate = new Date(fechaInicio);
        var fechaFinalDate = new Date(fechaFinal);

        // Construir la URL
        const url = `/RH/GetAllConceptoEmpleadoByIdEmpleadoDates?id=${idEmpleado}&fechaInicio=${fechaInicio}&fechaFinal=${fechaFinal}`;

        GetMVC(url, function (r) {
            if (r.IsSuccess) {
                MapingPropertiesDataTable("tblConceptosEmpleado", r.Response);
                // Llamar a la función de cálculo después de cargar los datos
                calcularSumatoriasYSalario();
                GetAllPrestamosByIdEmpleadoDates(idEmpleado, fechaInicio, fechaFinal);
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los Conceptos del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function GetAllPrestamosByIdEmpleadoDates(idEmpleado, fechaInicio, fechaFinal) {
        const url = `/RH/GetAllPrestamosByIdEmpleadoDates?id=${idEmpleado}&fechaInicio=${fechaInicio}&fechaFinal=${fechaFinal}`
        GetMVC(url, function (r) {
            if (r.IsSuccess) {
                MapingPropertiesDataTable("tblPrestamosEmpleado", r.Response);
                calcularSumatoriasYSalario();
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los Prestamos del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function ObtenerDatosEmpleadoYSalario(id) {
        GetMVC("/Empleado/ObtenerDatosEmpleado?id=" + id, function (r) {
            if (r.IsSuccess) {
                if (r.Response === null || r.Response === undefined) {
                    Swal.fire({
                        title: 'Error',
                        text: 'Error al cargar datos del Empleado.',
                        icon: 'error',
                        confirmButtonText: 'Aceptar'
                    });
                    setTimeout(function () {
                        $("#genericModal").modal("hide");
                    }, 3000);
                } else {
                    var diaNomina = r.Response.diaNomina;
                    $('#diaNomina').val(diaNomina);

                    // Usar las fechas calculadas en Razor (pasarlas como variables JavaScript)
                    var fechaViernes = '@fechaViernes'; // Viernes
                    var fechaSabado = '@fechaSabado';   // Sábado

                    // Actualizar la fecha final según el día de nómina
                    if (diaNomina === 'S') {
                        $('#fechaFinal').val(fechaSabado);
                    } else if (diaNomina === 'V') {
                        $('#fechaFinal').val(fechaViernes);
                    }

                    // Llamar a la función para obtener el salario
                    GetSalarioActivoByIdEmpleado(id, diaNomina);
                }
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar el Dia de Nomina del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function GetSalarioActivoByIdEmpleado(id, diaNomina) {
        GetMVC("/RH/GetSalarioActivoByIdEmpleado?id=" + id, function (r) {
            if (r.IsSuccess) {
                if (r.Response === null || r.Response === undefined) {
                    Swal.fire({
                        title: 'Error',
                        text: 'El Empleado no tiene un Salario Activo establecido.',
                        icon: 'error',
                        confirmButtonText: 'Aceptar'
                    });
                    setTimeout(function () {
                        $("#genericModal").modal("hide");
                    }, 2000);
                } else {
                    var salarioActual = r.Response.monto;
                    var salarioSemanal;

                    // Aplicar multiplicación según el día de nómina
                    if (diaNomina === 'V') {
                        salarioSemanal = salarioActual * 5; // Viernes
                    } else if (diaNomina === 'S') {
                        salarioSemanal = salarioActual * 6; // Sábado
                    } else {
                        salarioSemanal = salarioActual * 5; // Valor por defecto
                    }

                    // Establecer el valor en el input y bloquearlo
                    $('#salarioSemanal').val(
                        new Intl.NumberFormat('es-MX', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        }).format(parseFloat(salarioSemanal) || 0)
                    );
                }
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar el Salario Activo del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function SaveOrUpdateNominasByIdEmpleado() {
        // Función para limpiar formato de moneda
        function limpiarFormatoMoneda(valor) {
            if (!valor) return "0";
            // Remover comas y convertir a número
            return valor.toString().replace(/,/g, '');
        }

        // Actualizar campos hidden antes de enviar
        $("#fechaInicioRazor").val($("#fechaInicio").val());
        $("#fechaFinalRazor").val($("#fechaFinal").val());

        var parametro = {
            Id: parseInt($("#id").val()) || 0,
            IdTrabajador: parseInt($("#idTrabajador").val()) || 0,
            FechaInicio: $("#fechaInicioRazor").val(),
            FechaFinal: $("#fechaFinalRazor").val(),
            DiaNomina: $("#diaNominaHidden").val() || "5",
            SalarioSemanal: parseFloat(limpiarFormatoMoneda($("#salarioSemanal").val())) || 0,
            Aumento: parseFloat(limpiarFormatoMoneda($("#aumento").val().replace(/[^\d.]/g, ''))) || 0,
            Descuento: parseFloat(limpiarFormatoMoneda($("#descuento").val().replace(/[^\d.]/g, ''))) || 0,
            SalarioFinal: parseFloat(limpiarFormatoMoneda($("#salarioFinal").val().replace(/[^\d.]/g, ''))) || 0,
            Estatus: true,
            CreatedBy: $("#createdBy").val(),
            CreatedDt: $("#createdDt").val(),
            UpdatedBy: $("#updatedBy").val(),
            UpdatedDt: $("#updatedDt").val()
        }

        if (parametro.SalarioFinal == 0) {
            Swal.fire('Error', 'No se ha calculado la nomina aun.', 'error');
            return;
        }

        // Validaciones
        if (!parametro.IdTrabajador || parametro.IdTrabajador <= 0) {
            Swal.fire('Error', 'ID de trabajador no válido', 'error');
            return;
        }

        if (!parametro.FechaInicio || !parametro.FechaFinal) {
            Swal.fire('Error', 'Fechas de inicio y fin son requeridas', 'error');
            return;
        }

        PostMVC('/RH/SaveOrUpdateNominasByIdEmpleado', parametro, function (r) {
            if (r.IsSuccess) {
                Swal.fire({
                    title: "Registro guardado!",
                    text: "El registro se ha guardado correctamente.",
                    icon: "success",
                    confirmButtonText: 'OK'
                }).then(() => {
                    window.location.reload();
                });
            } else {
                Swal.fire({
                    title: "Registro guardado!",
                    text: "El registro se ha guardado correctamente.",
                    icon: "success",
                    confirmButtonText: 'OK'
                }).then(() => {
                    window.location.reload();
                });
            }
        });
    }

    function SearchNominaEmpleadoByDates() {
        // Obtener el ID del empleado
        var idEmpleado = @trabajadorId;

        // Obtener valores de los inputs de fecha
        var fechaInicio = document.getElementById('fechaInicio').value;
        var fechaFinal = document.getElementById('fechaFinal').value;

        // Validar que las fechas no estén vacías
        if (!fechaInicio || !fechaFinal) {
            Swal.fire({
                title: 'Advertencia',
                text: 'Por favor, seleccione ambas fechas',
                icon: 'warning',
                confirmButtonText: 'Aceptar'
            });
            return;
        }

        // Convertir strings a objetos Date
        var fechaInicioDate = new Date(fechaInicio);
        var fechaFinalDate = new Date(fechaFinal);

        // Construir la URL
        const url = `/RH/SearchNominaEmpleadoByDates?id=${idEmpleado}&fechaInicio=${fechaInicio}&fechaFinal=${fechaFinal}`;

        GetMVC(url, function (r) {
            if (r.IsSuccess) {
                // CORRECCIÓN: Lógica invertida
                if (r.Response != null && r.Response.length > 0) {
                    // Si hay datos en la respuesta, significa que YA EXISTE una nómina
                    Swal.fire({
                        title: 'Nómina Ya Generada',
                        text: 'Ya se generó la nómina semanal, no puedes generar una nueva. Por favor consulta el historial de nóminas del empleado y eliminala si es necesario.',
                        icon: 'warning',
                        confirmButtonText: 'Aceptar'
                    });
                    return;
                } else {
                    // Si NO hay datos, podemos generar una nueva nómina
                    SaveOrUpdateNominasByIdEmpleado();
                }
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los Conceptos del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

</script>