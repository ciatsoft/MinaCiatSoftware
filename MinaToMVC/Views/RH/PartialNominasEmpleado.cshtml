</style>

<div class="container-fluid" style="padding: 20px 15px;">
    <!-- Panel Principal con fondo blanco -->
    <div class="panel panel-default" style="background-color: #ffffff;">
        <div class="panel-body" style="background-color: #ffffff; color: #333333;">
            <div class="row">
                <div class="col-md-12">
                    <h1 class="text-primary" style="color: #005c8a !important; margin-top: 0;">
                        <i class="fa fa-file-text-o"></i> Generar Nómina para @nombreCompleto
                    </h1>
                </div>
            </div>

            <div class="row" style="margin-top: 20px;">
                <div class="col-md-6 col-sm-6">
                    <div class="form-group">
                        <label class="control-label" style="color: #333333; font-weight: bold;">
                            <i class="fa fa-calendar"></i> Fecha Inicio:
                        </label>
                        <input type="date" class="form-control" id="fechaInicio" name="fechaInicio" value="@fechaLunes" readonly>
                    </div>
                </div>
                <div class="col-md-6 col-sm-6">
                    <div class="form-group">
                        <label class="control-label" style="color: #333333; font-weight: bold;">
                            <i class="fa fa-calendar"></i> Fecha Fin:
                        </label>
                        <input type="date" class="form-control" id="fechaFinal" name="fechaFinal" value="" readonly>
                        <input type="hidden" id="diaNomina" name="diaNomina" readonly>
                        <input type="hidden" id="diaNominaHidden" name="diaNominaHidden" />
                    </div>
                </div>
            </div>

            <div class="row" style="margin-top: 10px;">
                <div class="col-md-12">
                    <div class="form-group">
                        <button type="button" onclick="GetAllConceptoEmpleadoByIdEmpleadoDates()" class="btn btn-success" style="min-width: 200px; padding: 8px 24px;">
                            <i class="fa fa-calculator"></i> Calcular Nómina Semanal
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tablas de Conceptos y Préstamos -->
