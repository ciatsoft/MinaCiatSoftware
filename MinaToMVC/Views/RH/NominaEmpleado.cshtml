@{
    ViewBag.Title = "NominaEmpleado";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
}
<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>
<div class="content">
    <br />
    <center><h1>Generar Nominas para Empleados</h1></center>
    <br />
    <h3><strong>Generar Reporte de Conceptos Generados</strong></h3>
    <div>
        <div class="row">
            <div class="col-md-2">
                <label for="fechaInicio" class="form-label">Fecha Inicio:</label>
                <input type="date" id="fechaInicio" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label for="fechaFinal" class="form-label">Fecha Final:</label>
                <input type="date" id="fechaFin" name="fechaFiltro" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="mb-3" style="text-align: right;">
                <button id="btnGenerarPDF" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 180px;">
                    Generar Reporte PDF
                </button>
                <button id="btnGenerarExcel" style="background-color: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; width: 180px;">
                    Generar Reporte Excel
                </button>
            </div>
        </div>
    </div>
    <br />
    <table id="tblEmpleados" class="table table-bordered table-striped" style="width: 100%;"></table>
    <br />
</div>

<script src="@(Url.StaticFile("Scripts/Trabajador/Nominas.js"))"></script>