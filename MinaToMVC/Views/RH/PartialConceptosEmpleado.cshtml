@model MinaTolEntidades.DtoEmpleados.ConceptoEmpleado
@{
    var trabajadorId = (long)ViewBag.TrabajadorId;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
    var usuario = @ViewBag.UserToken.UserName;
    var nombreCompleto = ViewBag.NombreTrabajador;

    var idConcepto = Model?.Id ?? 0;

}

<link href="~/Assets/css/EstilosBtnCambios/EstiloBtn.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>

<div class="content">
    @using (Html.BeginForm("SaveOrUpdateConceptoEmpleadoByIdEmpleado", "RH", FormMethod.Post, new { enctype = "multipart/form-data", @id = "frmConceptoEmpleado" }))
    {
        @Html.HiddenFor(x => x.Id, new { @id = "idModal", @Value = idConcepto })
        @Html.HiddenFor(x => x.IdTrabajador, new { @id = "idTrabajador", Value = trabajadorId })
        @Html.HiddenFor(x => x.Estatus)
        @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", Value = usuario })
        @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", Value = usuario })
        @Html.HiddenFor(x => x.CreatedDt, new { id = "CreatedDt", Value = fechaActual })
        @Html.HiddenFor(x => x.UpdatedDt, new { id = "UpdatedDt", Value = fechaActual })

        @Html.HiddenFor(x => x.NombreConceptoEmpleado, new { @id = "nombreConceptoEmpleado" })

        <br />
        <div class="tabla-consultas-roll">
            <div class="rectangulos" style="width: 100%;">
                <h2>Agregar Concepto para @nombreCompleto</h2>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-lg-4">
                        <label>Tipo Concepto:</label>
                        @Html.DropDownListFor(x => x.IdConceptoEmpleado,
                            (IEnumerable<SelectListItem>)ViewBag.ConceptosEmpleados,
                            "Seleccione un Tipo De Concepto",
                            new { @class = "form-control", @id = "ddlConceptoEmpleado", @required = "required" })
                    </div>
                    <div class="col-lg-4">
                        <label>Tipo de Cargo:</label>
                        @Html.TextBoxFor(x => x.TipoCargo, new { @class = "form-control", @id = "TipoCargo", @readonly = "readonly", @required = "required" })
                    </div>

                    <div class="col-lg-4">
                        <label>Cantidad:</label>
                        @Html.TextBoxFor(x => x.Cantidad, new { @class = "form-control", @id = "cantidad", @oninput = "this.value = this.value.replace(/[^0-9.]/g, '')", @required = "required" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4">
                        <label>Valor:</label>
                        @Html.TextBoxFor(x => x.Valor, new { @class = "form-control", @id = "valor", @oninput = "this.value = this.value.replace(/[^0-9.]/g, '')", @required = "required", @type = "text" })
                    </div>

                    <div class="col-lg-4">
                        <label>Total Neto:</label>
                        @Html.TextBoxFor(x => x.TotalNeto, new { @class = "form-control", @id = "totalNeto", @type = "text", @readonly = "readonly", @required = "required" })
                    </div>

                    <div class="col-lg-4">
                        <label>Fecha:</label>
                        @Html.TextBoxFor(x => x.Fecha, new { @class = "form-control", @id = "fecha", Value = fechaActual, @readonly = "readonly", @required = "required" })
                    </div>
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-12">
                        <input type="button" value="Guardar" onclick="SaveOrUpdateConceptoEmpleadoByIdEmpleado()" class="btn btn-success" />
                        <a href="/RH/NominaEmpleado" class="btn btn-custom-cancel">Cancelar</a>
                    </div>
                </div>
            </div>
        </div>
    }
    <br />
    <div class="row">
        <div class="col-lg-12">
            <table class="table table-bordered table-striped" id="tblConceptosEmpleado" style="width: 100%;"></table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Función para formatear como moneda MXN
        function formatCurrency(value) {
            if (value === '' || value === null || value === undefined) return '';

            let num = parseFloat(value);
            if (isNaN(num)) return value;

            return num.toLocaleString('es-MX', {
                style: 'currency',
                currency: 'MXN',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        // Función para quitar el formato de moneda
        function unformatCurrency(value) {
            if (!value) return '';
            return value.toString().replace(/[^\d.-]/g, '');
        }

        // Función para validar entrada numérica para cantidad (entero)
        function validateCantidadInput(input) {
            let value = input.val();

            // Remover todo excepto números (sin punto decimal para cantidad)
            let cleaned = value.replace(/[^0-9]/g, '');

            return cleaned;
        }

        // Función para validar entrada numérica para valor y total (decimal)
        function validateDecimalInput(input) {
            let value = input.val();
            let unformatted = unformatCurrency(value);

            // Remover todo excepto números y un punto decimal
            let cleaned = unformatted.replace(/[^0-9.]/g, '');

            // Permitir solo un punto decimal
            let parts = cleaned.split('.');
            if (parts.length > 2) {
                cleaned = parts[0] + '.' + parts.slice(1).join('');
            }

            // Limitar a 2 decimales
            if (parts.length > 1 && parts[1].length > 2) {
                cleaned = parts[0] + '.' + parts[1].substring(0, 2);
            }

            return cleaned;
        }

        // Función para actualizar el cálculo del total de manera instantánea
        function calcularTotalInstantaneo() {
            var cantidadStr = $('#cantidad').val().replace(/[^\d]/g, ''); // Solo números para cantidad
            var valorStr = unformatCurrency($('#valor').val());

            var cantidad = parseFloat(cantidadStr) || 0;
            var valor = parseFloat(valorStr) || 0;
            var total = cantidad * valor;

            // Actualizar el campo totalNeto con formato monetario
            $('#totalNeto').val(formatCurrency(total));
        }

        // Configurar eventos para CANTIDAD (entero sin formato monetario)
        $('#cantidad').on('input', function () {
            var $input = $(this);
            var cleanedValue = validateCantidadInput($input);

            // Guardar la posición del cursor
            var cursorPosition = this.selectionStart;

            // Actualizar el valor sin formato
            $input.val(cleanedValue);

            // Restaurar la posición del cursor
            this.setSelectionRange(cursorPosition, cursorPosition);

            // Calcular total instantáneamente
            calcularTotalInstantaneo();
        });

        // Configurar eventos para VALOR (con formato monetario)
        $('#valor').on('input', function () {
            var $input = $(this);
            var cleanedValue = validateDecimalInput($input);

            // Guardar la posición del cursor
            var cursorPosition = this.selectionStart;

            // Actualizar el valor sin formato
            $input.val(cleanedValue);

            // Restaurar la posición del cursor
            this.setSelectionRange(cursorPosition, cursorPosition);

            // Calcular total instantáneamente
            calcularTotalInstantaneo();
        });

        // Evento blur para formatear VALOR como moneda cuando pierde el foco
        $('#valor').on('blur', function () {
            var $input = $(this);
            var cleanedValue = unformatCurrency($input.val());

            if (cleanedValue && cleanedValue.trim() !== '') {
                $input.val(formatCurrency(cleanedValue));
            }
        });

        // Evento blur para TOTALNETO (solo formatear, no editar directamente)
        $('#totalNeto').on('blur', function () {
            var $input = $(this);
            var cleanedValue = unformatCurrency($input.val());

            if (cleanedValue && cleanedValue.trim() !== '') {
                $input.val(formatCurrency(cleanedValue));
            }
        });

        // Evento focus para VALOR - quitar formato y permitir edición
        $('#valor').on('focus', function () {
            var $input = $(this);
            var cleanedValue = unformatCurrency($input.val());
            $input.val(cleanedValue);
        });

        // Evento focus para CANTIDAD - mantener como número entero
        $('#cantidad').on('focus', function () {
            var $input = $(this);
            var cleanedValue = $input.val().replace(/[^\d]/g, '');
            $input.val(cleanedValue);
        });

        // TOTALNETO solo lectura - no permitir edición directa
        $('#totalNeto').prop('readonly', true);

        // Para enviar al servidor - convertir a valores numéricos apropiados
        $('form').on('submit', function () {
            // Cantidad como entero
            $('#cantidad').val($('#cantidad').val().replace(/[^\d]/g, ''));

            // Valor y TotalNeto como decimales sin formato
            $('#valor').val(unformatCurrency($('#valor').val()));
            $('#totalNeto').val(unformatCurrency($('#totalNeto').val()));
        });

        // Validación del formulario
        $('form').submit(function (e) {
            if ($('#ddlConceptoEmpleado').val() === '') {
                e.preventDefault();
                alert('Por favor, seleccione un concepto empleado');
                $('#ddlConceptoEmpleado').focus();
            }
        });

        // Inicializar el cálculo al cargar la página
        calcularTotalInstantaneo();

        // Pasamos la lista completa a JS
        var conceptos = @Html.Raw(ViewBag.ConceptosJson);

        $('#ddlConceptoEmpleado').on('change', function () {
            var selectedId = $(this).val();
            var selectedText = $("#ddlConceptoEmpleado option:selected").text();

            // Obtener el ID del empleado
            var idEmpleado = @trabajadorId;

            var concepto = conceptos.find(c => c.Id == selectedId);
            var valor = concepto ? concepto.Valor : '';
            var aumento = concepto ? concepto.Aumento : false;

            $('#nombreConceptoEmpleado').val(selectedText);

            // Formatear el valor con signo de pesos MXN
            if (valor) {
                $('#valor').val(formatCurrency(valor));
            } else {
                $('#valor').val('');
            }

            // Convertir el valor booleano a texto "Aumento" o "Descuento"
            var tipoCargo = aumento ? 'Aumento' : 'Descuento';
            $('#TipoCargo').val(tipoCargo);

            // Verificar si es "Dia Extra" o "Falta"
            if (selectedText.toLowerCase().includes('dia extra') ||
                selectedText.toLowerCase().includes('falta') ||
                selectedText.toLowerCase().includes('día extra')) {

                // Ejecutar la función para obtener el salario
                if (idEmpleado) {
                    GetSalarioActivoByIdEmpleado(idEmpleado);
                } else {
                    Swal.fire({
                        title: 'Advertencia',
                        text: 'Primero debe seleccionar un empleado',
                        icon: 'warning',
                        confirmButtonText: 'Aceptar'
                    });
                }
            } else {
                // Lógica original para otros conceptos
                if (valor === 0 || valor === 0.00 || valor === '0' || valor === '0.00' || valor === '' || valor === null) {
                    $('#valor').prop('readonly', false);
                } else {
                    $('#valor').prop('readonly', true);
                }
            }

            // Recalcular el total después de cambiar el valor
            calcularTotalInstantaneo();
        });

        // Configuración de DataTable
        $("#tblConceptosEmpleado").DataTable({
            data: [],
            columns: [
                { data: 'id', title: 'ID', visible: false },
                { data: 'idTrabajador', title: 'Id Trabajador', visible: false },
                { data: 'idConceptoEmpleado', title: 'Id Concepto Empleado', visible: false },
                { data: 'nombreConceptoEmpleado', title: 'Nombre del Concepto' },
                {
                    data: 'cantidad',
                    title: 'Cantidad',
                    render: function (data) {
                        // Cantidad como número entero sin decimales
                        return data ? parseInt(data).toLocaleString('es-MX') : '0';
                    }
                },
                {
                    data: 'valor',
                    title: 'Valor',
                    render: function (data) {
                        return formatCurrency(data);
                    }
                },
                {
                    data: 'totalNeto',
                    title: 'Total Neto',
                    render: function (data) {
                        return formatCurrency(data);
                    }
                },
                {
                    data: 'fecha',
                    title: 'Fecha',
                    render: function (data) {
                        return data ? new Date(data).toISOString().split('T')[0] : '';
                    }
                },
                { data: 'tipoCargo', title: 'Tipo de Cargo' },
                {
                    data: "id",
                    title: "Acciones",
                    render: function (data) {
                        return ' <input type="button" value="Eliminar" class="btn btn-custom-cancel" onclick="EliminarConceptoEmpleado(' + data + ')"/>';
                    }
                },
            ],
            order: [[0, 'desc']],
            language: {
                "decimal": ",",
                "thousands": ".",
                "processing": "Procesando...",
                "lengthMenu": "Mostrar _MENU_ entradas",
                "zeroRecords": "No se encontraron resultados",
                "emptyTable": "Ningún dato disponible en esta tabla",
                "info": "Mostrando _START_ a _END_ de _TOTAL_ entradas",
                "infoEmpty": "Mostrando 0 a 0 de 0 entradas",
                "infoFiltered": "(filtrado de un total de _MAX_ entradas)",
                "search": "Buscar:",
                "loadingRecords": "Cargando...",
                "paginate": {
                    "first": "Primero",
                    "last": "Último",
                    "next": "Siguiente",
                    "previous": "Anterior"
                },
                "aria": {
                    "sortAscending": ": activar para ordenar la columna de manera ascendente",
                    "sortDescending": ": activar para ordenar la columna de manera descendente"
                }
            }
        });

        // Validación del formulario
        $("#frmConceptoEmpleado").validate({
            rules: {
                nombreConceptoEmpleado: "required",
                nombre: "required",
                tipoCargo: "required",
                cantidad: {
                    required: true,
                    digits: true  // Solo números enteros
                },
                valor: {
                    required: true,
                    number: true  // Números decimales permitidos
                },
                totalNeto: "required",
            },
            messages: {
                nombreConceptoEmpleado: "Por favor ingresa un Concepto",
                nombre: "Por favor ingresa un Nombre",
                tipoCargo: "Por favor ingresa un Tipo de Cargo",
                cantidad: {
                    required: "Por favor ingresa una Cantidad",
                    digits: "La cantidad debe ser un número entero"
                },
                valor: {
                    required: "Por favor ingresa un Valor",
                    number: "El valor debe ser un número válido"
                },
                totalNeto: "Por favor ingresa un Cálculo",
            }
        });

        GetAllConceptoEmpleadoByIdEmpleado(@trabajadorId);
    });

    function GetAllConceptoEmpleadoByIdEmpleado(id) {
        GetMVC("/RH/GetAllConceptoEmpleadoByIdEmpleado?id=" + id, function (r) {
            if (r.IsSuccess) {
                MapingPropertiesDataTable("tblConceptosEmpleado", r.Response);
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los Conceptos del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function GetSalarioActivoByIdEmpleado(id) {
        GetMVC("/RH/GetSalarioActivoByIdEmpleado?id=" + id, function (r) {
            if (r.IsSuccess) {
                if (r.Response === null || r.Response === undefined) {
                    Swal.fire({
                        title: 'Error',
                        text: 'El Empleado no tiene un Salario Activo establecido.',
                        icon: 'error',
                        confirmButtonText: 'Aceptar'
                    });
                    setTimeout(function () {
                        $("#genericModal").modal("hide");
                    }, 4000);
                } else {
                    var salarioActual = r.Response.monto;

                    // Formatear el salario con signo de pesos MXN
                    var formattedSalario = parseFloat(salarioActual).toLocaleString('es-MX', {
                        style: 'currency',
                        currency: 'MXN',
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });

                    // Establecer el valor en el input y bloquearlo
                    $('#valor').val(formattedSalario);
                    $('#valor').prop('readonly', true);

                    // Recalcular el total
                    calcularTotalInstantaneo();
                }
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar el Salario Activo del Empleado: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function SaveOrUpdateConceptoEmpleadoByIdEmpleado() {
        if ($("#frmConceptoEmpleado").valid()) {

            // Función auxiliar para obtener valores sin formato
            function getUnformattedValue(selector) {
                var value = $(selector).val();
                return value ? value.toString().replace(/[^\d.-]/g, '') : '';
            }

            var parametro = {
                id: $("#idModal").val(),
                idTrabajador: $("#idTrabajador").val(),
                idConceptoEmpleado: $("#ddlConceptoEmpleado").val(),
                tipoCargo: $("#TipoCargo").val(),
                nombreConceptoEmpleado: $("#nombreConceptoEmpleado").val(),
                cantidad: $("#cantidad").val().replace(/[^\d]/g, ''), // Solo números para cantidad
                valor: getUnformattedValue('#valor'),
                totalNeto: getUnformattedValue('#totalNeto'),
                fecha: $("#fecha").val(),
                estatus: $("#Estatus").val(),
                createdBy: $("#createdBy").val(),
                createdDt: $("#CreatedDt").val(),
                updatedBy: $("#updatedBy").val(),
                updatedDt: $("#UpdatedDt").val()
            };

            PostMVC('/RH/SaveOrUpdateConceptoEmpleadoByIdEmpleado', parametro, function (r) {
                if (r.IsSuccess) {
                    Swal.fire({
                        title: "Registro guardado!",
                        text: "El registro se ha guardado correctamente.",
                        icon: "success",
                        confirmButtonText: 'OK'
                    }).then(() => {
                        setTimeout(function () {
                            $("#genericModal").modal("hide");
                        }, 2000);
                    });
                } else {
                    Swal.fire({
                        title: "Registro guardado!",
                        text: "El registro se ha guardado correctamente.",
                        icon: "success",
                        confirmButtonText: 'OK'
                    }).then(() => {
                        setTimeout(function () {
                            $("#genericModal").modal("hide");
                        }, 2000);
                    });
                }
            });
        }
    }

    function EliminarConceptoEmpleado(id) {
        Swal.fire({
            title: '¿Estás seguro?',
            text: "¿Quieres eliminar este registro?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                GetMVC("/RH/DeleteConceptoEmpleadoById?id=" + id, function (r) {
                    if (r.IsSuccess) {
                        Swal.fire(
                            'Eliminado!',
                            'El concepto ha sido eliminado.',
                            'success'
                        );
                        setTimeout(function () {
                            $("#genericModal").modal("hide");
                        }, 2000);
                    } else {
                        Swal.fire(
                            'Error!',
                            'Hubo un error al eliminar el concepto.',
                            'error'
                        );
                    }
                });
            }
        });
    }

    // Función global para calcular total
    function calcularTotalInstantaneo() {
        var cantidadStr = $('#cantidad').val().replace(/[^\d]/g, '');
        var valorStr = $('#valor').val().replace(/[^\d.-]/g, '');

        var cantidad = parseFloat(cantidadStr) || 0;
        var valor = parseFloat(valorStr) || 0;
        var total = cantidad * valor;

        // Formatear el total como moneda MXN
        var formattedTotal = total.toLocaleString('es-MX', {
            style: 'currency',
            currency: 'MXN',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });

        $('#totalNeto').val(formattedTotal);
    }
</script>