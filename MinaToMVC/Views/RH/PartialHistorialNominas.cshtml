                    </tr>
                </tbody>
        </table>
    </div>

    <div class="separator"></div>

    <div class="fecha">
        <strong>Calimaya, Estado de México a ${obtenerFechaActual()}</strong>
    </div>

    <div class="separator"></div>

    <div class="datos-contenedor">
        <div style="display: inline-block; width: 60%; vertical-align: top;">
            <strong>Datos del trabajador</strong><br>
            Número: ${numeroEmpleado || datosEmpleado.id || ''}<br>
            Núm. SS: ${datosEmpleado.nss || ''}<br>
            Nombre: ${nombreCompleto}<br>
            <div class="periodo"><strong>Periodo: ${formatearFecha(row.fechaInicio)} al ${formatearFecha(row.fechaFinal)}</strong></div>
        </div>
        <div class="recibo-title" style="display: inline-block; width: 38%; text-align: right; vertical-align: top;">
            Recibo de nómina
        </div>
    </div>

    <div class="separator"></div>

    <table>
        <thead>
            <tr>
                <th>Cpto</th>
                <th>Unidades</th>
                <th>Descripción</th>
                <th>Percepciones</th>
                <th>Deducciones</th>
            </tr>
        </thead>
        <tbody>
            ${conceptos.map(concepto => `
                <tr>
                    <td>${concepto.idConceptoEmpleado || ''}</td>
                    <td>${concepto.cantidad || ''}</td>
                    <td>${concepto.nombreConceptoEmpleado || concepto.descripcion || ''}</td>
                    <td>${concepto.valor > 0 ? formatoMoneda(concepto.valor * concepto.cantidad) : ''}</td>
                    <td>${concepto.valor < 0 ? formatoMoneda(Math.abs(concepto.valor) * concepto.cantidad) : ''}</td>
