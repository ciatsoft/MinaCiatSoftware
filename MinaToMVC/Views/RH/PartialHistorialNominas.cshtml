            `).join('')}
        </tbody>
    </table>

    <div class="texto-moneda">
        <em>*${numeroATexto(totalNeto)}*</em>
    </div>

    <div class="totales">
        <strong>Total de percepciones:</strong> ${formatoMoneda(totalPercepciones)}<br>
        <strong>Total de deducciones:</strong> ${formatoMoneda(totalDeducciones)}<br>
        <strong>Total neto:</strong> ${formatoMoneda(totalNeto)}
    </div>

    <div class="firma">
