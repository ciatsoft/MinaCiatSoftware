        margin-bottom: 10px;
        position: relative;
    }
    .separator {
        border-bottom: 1px solid #000;
        margin: 8px 0;
    }
    table {
        width: 100%;
        border-collapse: collapse;
        margin: 10px 0;
        font-size: 11px;
    }
    th, td {
        border: 1px solid #000;
