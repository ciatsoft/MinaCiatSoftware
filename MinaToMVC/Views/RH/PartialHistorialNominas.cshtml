        GetAllNominasByIdEmpleado(@trabajadorId);
    });

    function GetAllNominasByIdEmpleado(id){
        GetMVC(`/RH/GetAllNominasByIdEmpleado?id=${id}`, function (r) {
            if (r.IsSuccess) {
                MapingPropertiesDataTable("tblHistorialNominas", r.Response);
            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar el Historial de Nominas: ' + r.ErrorMessage,
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function EliminarNomina(id) {
        Swal.fire({
            title: '¿Estas seguro?',
            text: "¿Desea eliminar el siguiente registro?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                var parametro = { Id: id };

                PostMVC('/RH/DeleteNominasByIdEmpleado', parametro, function (r) {
                    if (r.IsSuccess) {
                        Swal.fire('Eliminado', 'La Nomina ha sido eliminada.', 'success')
                            .then(() => { window.location.reload(); });
                    } else {
                        Swal.fire('Eliminado', 'La Nomina ha sido eliminada.', 'success')
                            .then(() => { window.location.reload(); });
                    }
                });
            }
        });
    }

    function ImprimirNominaCompleta(id, rowJson) {
        // Convertir de vuelta a objeto
        const row = JSON.parse(rowJson);

        const fechaInicio = row.fechaInicio;
        const fechaFinal = row.fechaFinal;
        const salarioSemanal = row.salarioSemanal;
        const aumento = row.aumento;

        const url = `/RH/GetAllConceptoEmpleadoByIdEmpleadoDates?id=${id}&fechaInicio=${fechaInicio}&fechaFinal=${fechaFinal}`;
        const url2 = `/RH/GetAllPrestamosByIdEmpleadoDates?id=${id}&fechaInicio=${fechaInicio}&fechaFinal=${fechaFinal}`;
        const url3 = `/Empleado/ObtenerDatosEmpleado?id=${id}`;

        // Usar Promise.all para esperar ambas llamadas
        Promise.all([
            new Promise((resolve) => GetMVC(url, resolve)),
            new Promise((resolve) => GetMVC(url2, resolve)),
            new Promise((resolve) => GetMVC(url3, resolve))
        ]).then(([r, r2, r3]) => {
            if (r.IsSuccess && r2.IsSuccess && r3.IsSuccess) {
                // Generar el HTML con los datos
                const htmlContent = generarHTMLNomina(r.Response, r2.Response, r3.Response, row);

                // Llamar al controlador para generar el PDF
                generarPDF(htmlContent);

            } else {
                Swal.fire({
                    title: 'Error',
                    text: 'Error al cargar los datos: ' + (r.ErrorMessage || r2.ErrorMessage || r3.ErrorMessage),
                    icon: 'error',
                    confirmButtonText: 'Aceptar'
                });
            }
        });
    }

    function generarHTMLNomina(conceptos, prestamos, datosEmpleado, row) {
        // Calcular totales
        const totalPercepciones = conceptos.filter(c => c.valor > 0).reduce((sum, c) => sum + (c.valor * c.cantidad), 0);
        const totalDeducciones = conceptos.filter(c => c.valor < 0).reduce((sum, c) => sum + (Math.abs(c.valor) * c.cantidad), 0) +
            prestamos.reduce((sum, p) => sum + p.monto, 0);
        const totalNeto = totalPercepciones - totalDeducciones;

        // Formatear números a moneda
        const formatoMoneda = (numero) => {
            return new Intl.NumberFormat('es-MX', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(numero);
        };

        // Convertir número a texto
        function numeroATexto(numero) {
            const unidades = ['', 'un', 'dos', 'tres', 'cuatro', 'cinco', 'seis', 'siete', 'ocho', 'nueve'];
            const decenas = ['', 'diez', 'veinte', 'treinta', 'cuarenta', 'cincuenta', 'sesenta', 'setenta', 'ochenta', 'noventa'];
            const especiales = ['diez', 'once', 'doce', 'trece', 'catorce', 'quince', 'dieciséis', 'diecisiete', 'dieciocho', 'diecinueve'];
            const centenas = ['', 'ciento', 'doscientos', 'trescientos', 'cuatrocientos', 'quinientos', 'seiscientos', 'setecientos', 'ochocientos', 'novecientos'];

            if (numero === 0) return 'Cero';

            let texto = '';
            const enteros = Math.floor(numero);
            const decimales = Math.round((numero - enteros) * 100);

            // Manejar miles
            if (enteros >= 1000) {
                const miles = Math.floor(enteros / 1000);
                const resto = enteros % 1000;

                if (miles === 1) {
                    texto = 'mil';
                } else {
                    texto = numeroATextoMiles(miles) + ' mil';
                }

                if (resto > 0) {
                    texto += ' ' + numeroATextoMiles(resto);
                }
            } else {
                texto = numeroATextoMiles(enteros);
            }

            // Capitalizar primera letra
            texto = texto.charAt(0).toUpperCase() + texto.slice(1);

            return texto + ' pesos ' + decimales + '/100 M.N.';

            // Función auxiliar para números menores a 1000
            function numeroATextoMiles(num) {
                if (num === 0) return '';
                if (num === 100) return 'cien';

                let result = '';

                // Centenas
                const c = Math.floor(num / 100);
                if (c > 0) {
                    result = centenas[c];
                }

                // Decenas y unidades
                const resto = num % 100;
                if (resto > 0) {
                    if (result) result += ' ';

                    if (resto < 10) {
                        result += unidades[resto];
                    } else if (resto < 20) {
                        result += especiales[resto - 10];
                    } else {
                        const d = Math.floor(resto / 10);
                        const u = resto % 10;

                        if (u === 0) {
                            result += decenas[d];
                        } else {
                            if (d === 2) {
                                result += 'veinti' + unidades[u];
                            } else {
                                result += decenas[d];
                                if (u > 0) {
                                    result += ' y ' + unidades[u];
                                }
                            }
                        }
                    }
                }

                return result;
            }
        }

        // Formatear fecha en formato dd/mm/yyyy
        function formatearFecha(fecha) {
            const date = new Date(fecha);
            const dia = String(date.getDate()).padStart(2, '0');
            const mes = String(date.getMonth() + 1).padStart(2, '0');
            const año = date.getFullYear();
            return `${dia}/${mes}/${año}`;
        }

        // Obtener fecha actual en formato "3 de octubre de 2025"
        function obtenerFechaActual() {
            const fecha = new Date();
            const opciones = { day: 'numeric', month: 'long', year: 'numeric' };
            return fecha.toLocaleDateString('es-MX', opciones);
        }

        // Usar los datos del empleado que ya tenemos - CORREGIDO
        const nombreCompleto = `${datosEmpleado.nombre || ''} ${datosEmpleado.apellidoPaterno || ''} ${datosEmpleado.apellidoMaterno || ''}`.trim();
        const numeroSeguroSocial = datosEmpleado.numeroSeguroSocial || datosEmpleado.NumeroSeguroSocial || '';
        const numeroEmpleado = datosEmpleado.numeroEmpleado || datosEmpleado.NumeroEmpleado || '';

        return `
<!DOCTYPE html>
<html>
