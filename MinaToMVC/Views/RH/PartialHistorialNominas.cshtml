        margin: 5px 0;
    }
    </style>
</head>
<body>
    <!-- ENCABEZADO CON LOGO EN BASE64 -->
    <div class="header-container">
        <header>
            <div class="container">
                <div class="company-info">
                    <div class="company-name">PLANTA PROCESADORA DE MATERIALES PETREOS SAN MIGUEL, GUTS, SA DE CV</div>
