@model MinaTolEntidades.DtoEmpleados.ConceptosEmpleado
@{
    ViewBag.Title = "ConceptosRH";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarioToken = (MinaTolEntidades.Security.TokenCookie)ViewBag.UserToken;
    var fechaActual = DateTime.Now.ToString("yyyy-MM-dd");
}

<div class="container-fluid" style="padding: 20px 15px;">
    @using (Html.BeginForm("SaveOrUpdateConceptosEmpleados", "RH", FormMethod.Post, new { enctype = "multipart/form-data", @name = "frmConceptosEmpleado", @id = "frmConceptosEmpleado" }))
    {
        @Html.HiddenFor(x => x.Id, new { id = "id" })
        @Html.HiddenFor(x => x.Estatus, new { id = "estatus" })
        @Html.HiddenFor(x => x.CreatedDt, new { id = "createdDt", @Value = fechaActual })
        @Html.HiddenFor(x => x.CreatedBy, new { id = "createdBy", @Value = usuarioToken.UserName })
        @Html.HiddenFor(x => x.UpdatedBy, new { id = "updatedBy", @Value = usuarioToken.UserName })
        @Html.HiddenFor(x => x.UpdatedDt, new { id = "updatedDt", @Value = fechaActual })

        <!-- Panel principal con fondo blanco y sombra -->
        <div class="panel panel-default" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <div class="panel-body">

                <!-- Título centrado -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <h1 class="text-primary" style="color: #005c8a !important; margin-bottom: 20px;">
                            <i class="fa fa-calculator"></i> Conceptos para Empleados
                        </h1>
                    </div>
                </div>

                <!-- Campos del formulario -->
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-tag"></i> Nombre:</label>
                            @Html.TextBoxFor(x => x.Nombre, new { @class = "form-control", @type = "text", id = "nombre", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-align-left"></i> Descripción:</label>
                            @Html.TextBoxFor(x => x.Descripcion, new { @class = "form-control", @type = "text", id = "descripcion", required = "required" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-dollar"></i> Valor:</label>
                            @Html.TextBoxFor(x => x.Valor, new { @class = "form-control", @type = "text", id = "valor" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label" style="font-weight: bold;"><i class="fa fa-arrow-up"></i> Aumento de Salario:</label>
                            <div style="padding-top: 8px;">
                                @Html.CheckBoxFor(x => x.Aumento, new { id = "aumentoCheckbox", style = "transform: scale(1.2); margin-right: 5px;" })
                                <span id="lblAumento">No</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="row">
                    <div class="col-md-12 text-center">
                        <button type="submit" id="btnGuardar" class="btn btn-success">
                            <i class="fa fa-save"></i> Guardar
                        </button>
                        <a href="/RH/ConceptosRH" class="btn btn-danger">
                            <i class="fa fa-times"></i> Cancelar
                        </a>
                    </div>
                </div>

            </div>
        </div>
    }
</div>

<div class="container-fluid" style="padding: 0 15px 20px 15px;">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <i class="fa fa-list"></i> Listado de Conceptos para Empleados
        </div>
        <div class="panel-body table-responsive">
            <table id="tblConceptosRH" class="table table-bordered table-striped" style="width: 100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Valor</th>
                        <th>Tipo de Cargo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Script para el checkbox de Aumento
        var chkAumento = document.getElementById('aumentoCheckbox');
        var lblAumento = document.getElementById('lblAumento');

        if (chkAumento && lblAumento) {
            function updateAumentoLabel() {
                lblAumento.textContent = chkAumento.checked ? 'Sí' : 'No';
                lblAumento.style.color = chkAumento.checked ? '#5cb85c' : '#d9534f';
            }
            chkAumento.addEventListener('change', updateAumentoLabel);
            updateAumentoLabel();
        }

        $('#valor').on('input', function () {
            // Permitir números y un punto decimal
            let input = $(this).val();

            // Remover todo excepto números y un punto decimal
            let value = input.replace(/[^0-9.]/g, '');

            // Permitir solo un punto decimal
            let parts = value.split('.');
            if (parts.length > 2) {
                value = parts[0] + '.' + parts.slice(1).join('');
            }

            // Limitar a 2 decimales
            if (parts.length > 1 && parts[1].length > 2) {
                value = parts[0] + '.' + parts[1].substring(0, 2);
            }

            $(this).val(value);

            // Formatear como moneda cuando pierde el foco
        }).on('blur', function () {
            let value = $(this).val();
            if (value && value.trim() !== '') {
                // Convertir a número y formatear
                let num = parseFloat(value);
                if (!isNaN(num)) {
                    let formatted = '$ ' + num.toLocaleString('es-MX', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                    $(this).val(formatted);
                }
            }
        }).on('focus', function () {
            // Al enfocar, quitar el formato para editar
            let value = $(this).val().replace(/[^0-9.]/g, '');
            $(this).val(value);
        });

        // Para enviar al servidor
        $('form').on('submit', function () {
            let rawValue = $('#valor').val().replace(/[^0-9.]/g, '');
            if (rawValue) {
                let num = parseFloat(rawValue);
                if (!isNaN(num)) {
                    $('#valor').val(num.toFixed(2));
                }
            }
        });
    });
</script>

<script src="@(Url.StaticFile("Scripts/Trabajador/ConceptosRH.js"))"></script>

<style>
    /* Estilos para asegurar que todo el contenido tenga fondo blanco y texto legible */
    .container-fluid {
        background-color: transparent;
    }

    /* Estilos para los botones dentro de las tablas - letras blancas */
    .table .btn {
        color: #ffffff !important;
    }

    .table .btn-primary {
        background-color: #337ab7;
        border-color: #2e6da4;
    }

    .table .btn-danger {
        background-color: #d9534f;
        border-color: #d43f3a;
    }

    .table .btn-warning {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

    .table .btn-info {
        background-color: #5bc0de;
        border-color: #46b8da;
    }

    .table .btn-success {
        background-color: #5cb85c;
        border-color: #4cae4c;
    }

    /* Hover effects */
    .table .btn:hover {
        opacity: 0.9;
        color: #ffffff !important;
    }

    /* Asegurar que el texto de los botones principales también sea blanco */
    .btn-success, .btn-danger, .btn-info, .btn-primary {
        color: #ffffff !important;
    }

    /* Estilos para DataTables - texto oscuro sobre fondo blanco */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_processing,
    .dataTables_wrapper .dataTables_paginate {
        color: #333333 !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #333333 !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #337ab7 !important;
                color: #ffffff !important;
            }

    /* Tablas - celdas con texto oscuro */
    .table tbody tr td {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

    .table thead tr th {
        color: #333333 !important;
        background-color: #f5f5f5 !important;
    }

    /* Inputs y selects dentro del formulario */
    .form-control {
        color: #333333 !important;
        background-color: #ffffff !important;
    }

        .form-control:disabled {
            background-color: #e9ecef !important;
            color: #495057 !important;
        }

    /* Labels */
    .control-label {
        color: #333333 !important;
    }

    /* Estilo para el texto del checkbox */
    #lblAumento {
        font-weight: bold;
        transition: color 0.2s ease;
    }
</style>